<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <base href="/" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Boosting Hub - @ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/img/icon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (ViewData["PageType"]?.ToString() == "landing")
    {
        <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    }
    else if (ViewData["PageType"]?.ToString() == "auth")
    {
        <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    }
    else if (ViewData["BodyClass"]?.ToString() == "dashboard-page" || ViewData["BodyClass"]?.ToString() == "admin-page")
    {
        <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    }
    else if (ViewData["BodyClass"]?.ToString() == "user-dashboard-page")
    {
        <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)
    <script>
        const savedTheme = localStorage.getItem('theme') || 'dark';
        if (savedTheme === 'light') {
            document.documentElement.classList.add('light-mode');
        }
    </script>
</head>
<body class="@ViewData["BodyClass"]">
    <script>
        if(localStorage.getItem('theme')==='light'){
            document.body.classList.add('light-mode');
        }
    </script>
    @if (ViewData["PageType"]?.ToString() == "landing")
    {
        <header class="landing-header" id="landingHeader">
            <div class="header-inner">
                <a href="/" class="header-logo">
                    <div class="header-logo-icon"><i class="bi bi-rocket-takeoff"></i></div>
                    <span class="header-logo-text">Boosting Hub</span>
                </a>
                <nav class="header-nav" id="headerNav">
                    <a href="#features">Features</a>
                    <a href="#stats">Stats</a>
                    <a href="#get-started">Get Started</a>
                    <div class="mobile-nav-cta">
                        <button class="theme-toggle-btn mobile-theme-toggle" onclick="toggleTheme()" aria-label="Toggle Theme">
                            <i class="bi bi-moon-fill dark-icon"></i><i class="bi bi-sun-fill light-icon"></i> <span class="theme-text">Theme</span>
                        </button>
                        <a href="/login" class="btn-ghost"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                        <a href="/register" class="btn-primary-solid"><i class="bi bi-person-plus"></i> Get Started</a>
                    </div>
                </nav>
                <div class="header-cta" id="headerCta">
                    <button class="theme-toggle-btn" id="landingThemeToggle" onclick="toggleTheme()" aria-label="Toggle Theme">
                        <i class="bi bi-moon-fill dark-icon"></i>
                        <i class="bi bi-sun-fill light-icon"></i>
                    </button>
                    <a href="/login" class="btn-ghost"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                    <a href="/register" class="btn-primary-solid"><i class="bi bi-person-plus"></i> Get Started</a>
                </div>
                <button class="mobile-toggle" id="mobileToggle" onclick="toggleMobileNav()">&#9776;</button>
            </div>
        </header>

        <main>
            @RenderBody()

            <section class="hero" id="hero">
                <div class="hero-bg-glow"></div>
                <div class="hero-bg-glow-2"></div>
                <div class="hero-grid">
                    <div>
                        <div class="hero-badge"><i class="bi bi-lightning-fill"></i> Trusted by @((ViewData["LandingTotalUsers"] as int? ?? 0).ToString("N0"))+ creators</div>
                        <h1 class="hero-title">
                            Grow Your Social<br>
                            <span class="hero-title-gradient">Engagement</span><br>
                            Effortlessly
                        </h1>
                        <p class="hero-subtitle">
                            The premier marketplace connecting content creators with real, high-quality engagement.
                            Boost your social presence with authentic likes, followers, and views.
                        </p>
                        <div class="hero-actions">
                            <a href="/register" class="btn-hero-primary">
                                <i class="bi bi-rocket-takeoff"></i> Get Started Free
                            </a>
                            <a href="#features" class="btn-hero-secondary">
                                <i class="bi bi-play-circle"></i> See How It Works
                            </a>
                        </div>

                    </div>
                    <div class="hero-visual">
                        <div class="hero-card-mockup">
                            <div class="hero-card-header">
                                <div class="hero-card-dots"><span></span><span></span><span></span></div>
                                <div class="hero-card-avatar">
                                    <div class="hero-card-avatar-circle">JD</div>
                                    <span>@(User.Identity?.Name ?? "Guest User")</span>
                                </div>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon purple"><i class="bi bi-instagram"></i></div>
                                <div class="hero-card-content"><h4>Instagram Followers</h4><p>1,500 followers &bull; 2h ago</p></div>
                                <span class="hero-card-status live">Live</span>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon green"><i class="bi bi-youtube"></i></div>
                                <div class="hero-card-content"><h4>YouTube Views</h4><p>10,000 views &bull; 30m ago</p></div>
                                <span class="hero-card-status live">Live</span>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon orange"><i class="bi bi-tiktok"></i></div>
                                <div class="hero-card-content"><h4>TikTok Likes</h4><p>5,000 likes &bull; 1h ago</p></div>
                                <span class="hero-card-status pending">Pending</span>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon blue"><i class="bi bi-twitter-x"></i></div>
                                <div class="hero-card-content"><h4>X (Twitter) Followers</h4><p>3,000 followers &bull; 4h ago</p></div>
                                <span class="hero-card-status live">Live</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="section" id="features">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-stars"></i> Features</div>
                    <h2 class="section-title section-title-light">Everything You Need to Grow</h2>
                    <p class="section-subtitle">Powerful tools and real engagement to supercharge your social media presence across all major platforms.</p>
                </div>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon purple"><i class="bi bi-shield-check"></i></div>
                        <h3>Real &amp; Authentic</h3>
                        <p>All engagement comes from real accounts. No bots, no fake profiles, guaranteed authentic growth.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon green"><i class="bi bi-lightning-charge"></i></div>
                        <h3>Lightning Fast</h3>
                        <p>Orders start within minutes of placement. Our automated system delivers results at unprecedented speed.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon blue"><i class="bi bi-graph-up-arrow"></i></div>
                        <h3>Smart Analytics</h3>
                        <p>Track your growth with detailed analytics, real-time reporting, and performance insights dashboard.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon orange"><i class="bi bi-globe2"></i></div>
                        <h3>Multi-Platform</h3>
                        <p>Supporting Instagram, YouTube, TikTok, X (Twitter), Facebook, LinkedIn, and more major platforms.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon pink"><i class="bi bi-lock-fill"></i></div>
                        <h3>Secure &amp; Private</h3>
                        <p>Your data is encrypted end-to-end. We never share your information with third parties.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon teal"><i class="bi bi-headset"></i></div>
                        <h3>24/7 Support</h3>
                        <p>Our dedicated support team is available around the clock to help you with any questions or issues.</p>
                    </div>
                </div>
            </section>

            <section class="section-light" id="stats">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-bar-chart-fill"></i> Our Numbers</div>
                    <h2 class="section-title section-title-dark">Trusted by Creators Worldwide</h2>
                    <p class="section-subtitle section-subtitle-dark">Join thousands of satisfied content creators who trust Boosting Hub for their social media growth.</p>
                </div>
                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-number">@((ViewData["LandingTotalUsers"] as int? ?? 0).ToString("N0"))+</div><div class="stat-label">Users</div></div>
                    <div class="stat-card"><div class="stat-number">@((ViewData["LandingTotalOrders"] as int? ?? 0).ToString("N0"))+</div><div class="stat-label">Orders</div></div>
                    <div class="stat-card"><div class="stat-number">@((ViewData["LandingCompletedTasks"] as int? ?? 0).ToString("N0"))+</div><div class="stat-label">Completed Orders</div></div>
                </div>
            </section>

            <!-- ── How It Works: Earners ── -->
            <section class="section" id="how-earners">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-cash-coin"></i> Earn Money</div>
                    <h2 class="section-title section-title-light">How Earners Work</h2>
                    <p class="section-subtitle">Complete simple social media tasks and earn real money. It's that easy.</p>
                </div>
                <div class="steps-grid">
                    <div class="step-card">
                        <div class="step-number">1</div>
                        <div class="step-icon purple"><i class="bi bi-person-plus"></i></div>
                        <h3>Create Account</h3>
                        <p>Sign up for free in seconds. Link your social media accounts to get started.</p>
                    </div>
                    <div class="step-card">
                        <div class="step-number">2</div>
                        <div class="step-icon green"><i class="bi bi-list-task"></i></div>
                        <h3>Browse Tasks</h3>
                        <p>Explore available tasks like follows, likes, views, and comments across platforms.</p>
                    </div>
                    <div class="step-card">
                        <div class="step-number">3</div>
                        <div class="step-icon blue"><i class="bi bi-check2-all"></i></div>
                        <h3>Complete & Earn</h3>
                        <p>Finish tasks, submit proof, and get paid instantly to your wallet. Withdraw anytime.</p>
                    </div>
                </div>
            </section>

            <!-- ── How It Works: Order Givers ── -->
            <section class="section-light" id="how-orderers">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-rocket-takeoff"></i> Grow Faster</div>
                    <h2 class="section-title section-title-dark">How Order Givers Work</h2>
                    <p class="section-subtitle section-subtitle-dark">Place orders for real social media engagement. Our community handles the rest.</p>
                </div>
                <div class="steps-grid">
                    <div class="step-card light">
                        <div class="step-number">1</div>
                        <div class="step-icon purple"><i class="bi bi-megaphone"></i></div>
                        <h3>Submit Requirements</h3>
                        <p>Choose your platform, service type, and package. Tell us what engagement you need.</p>
                    </div>
                    <div class="step-card light">
                        <div class="step-number">2</div>
                        <div class="step-icon green"><i class="bi bi-clipboard-check"></i></div>
                        <h3>Admin Reviews</h3>
                        <p>Our team reviews your order, publishes tasks for our community of earners to complete.</p>
                    </div>
                    <div class="step-card light">
                        <div class="step-number">3</div>
                        <div class="step-icon blue"><i class="bi bi-graph-up-arrow"></i></div>
                        <h3>Watch Growth</h3>
                        <p>Real users complete your tasks. Track progress on your dashboard and see real results.</p>
                    </div>
                </div>
            </section>

            <!-- ── Clients Section ── -->
            <section class="inquiry-section" id="get-started">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-people-fill"></i> Clients</div>
                    <h2 class="section-title section-title-light">Submit Your Requirements</h2>
                    <p class="section-subtitle">Choose your Platform, Service, and Quantity — available packages appear automatically. Pay to confirm your order.</p>
                    <div id="iq-currency-badge" style="display:inline-flex;align-items:center;gap:6px;margin-top:12px;padding:6px 16px;border-radius:20px;background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.2);color:var(--primary);font-size:0.85rem;font-weight:700;" title="Prices displayed in your local currency"></div>
                </div>

                <div class="inquiry-form-card">
                    <div id="inquirySuccess" style="display:none;" class="inquiry-success">
                        <i class="bi bi-check-circle-fill"></i>&nbsp; Payment confirmed! Your order is now active.
                    </div>
                    <div id="inquiryError" style="display:none;" class="alert alert-danger" style="border-radius:12px;">
                        <i class="bi bi-exclamation-triangle-fill"></i>&nbsp; <span id="inquiryErrorText"></span>
                    </div>
                    <form id="inquiryForm" onsubmit="return false;">
                        <div class="inquiry-section-group">
                            <div class="inquiry-group-title"><i class="bi bi-person-badge"></i> Contact Information</div>
                            <div class="inquiry-grid">
                                <div class="inquiry-field">
                                    <label>Your Name <span>*</span></label>
                                    <input type="text" id="iq-name" placeholder="John Doe" required />
                                </div>
                                <div class="inquiry-field">
                                    <label>Email <span>*</span></label>
                                    <input type="email" id="iq-email" placeholder="john@example.com" required />
                                </div>
                            </div>
                        </div>

                        <div class="inquiry-section-group">
                            <div class="inquiry-group-title"><i class="bi bi-sliders"></i> Campaign Details</div>
                            <div class="inquiry-grid">
                                <div class="inquiry-field inquiry-field-full">
                                    <label>Platform <span>*</span></label>
                                    <select id="iq-platform" required onchange="onIqPlatformChange()">
                                        <option value="">Choose platform...</option>
                                    </select>
                                </div>
                                <div class="inquiry-field inquiry-field-full">
                                    <label>Services <span>*</span></label>
                                    <div class="iq-svc-dropdown" id="iq-svc-dropdown">
                                        <div class="iq-svc-dropdown-btn" onclick="toggleSvcDropdown()">
                                            <span id="iq-svc-label">Choose services...</span>
                                            <i class="bi bi-chevron-down"></i>
                                        </div>
                                        <div class="iq-svc-dropdown-menu" id="iq-svc-menu"></div>
                                    </div>
                                </div>
                                <div class="inquiry-field inquiry-field-full" id="iq-service-qty-container" style="display:none;">
                                    <label>Service Quantities <span>*</span></label>
                                    <div id="iq-service-qty-area"></div>
                                </div>
                                <div class="inquiry-field inquiry-field-full">
                                    <label>Target URL <span>*</span></label>
                                    <input type="url" id="iq-url" placeholder="https://instagram.com/your-profile" required />
                                </div>
                                <div class="inquiry-field inquiry-field-full">
                                    <label>Description <small>(optional)</small></label>
                                    <textarea id="iq-description" rows="3" placeholder="Tell us more about what you need..."></textarea>
                                </div>
                            </div>
                        </div>

                        <div id="iq-services-area"></div>

                        <div id="iq-order-summary" style="display:none;" class="iq-order-summary">
                            <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 0;">
                                <div>
                                    <div style="font-size:0.85rem;color:var(--text-muted);margin-bottom:4px;">Total Amount</div>
                                    <div id="iq-total-price" style="font-size:1.8rem;font-weight:900;color:var(--text-primary);">0.00</div>
                                </div>
                            </div>
                        </div>

                        <button type="button" id="inquirySubmitBtn" class="btn-hero-primary w-100 mt-3" style="justify-content:center;" onclick="openPaymentModal()">
                            <i class="bi bi-credit-card"></i> Proceed to Payment
                        </button>
                    </form>
                </div>
            </section>

            <!-- ── Payment Modal ── -->
            <div class="pkg-modal-overlay" id="paymentOverlay" onclick="closePaymentModal()"></div>
            <div class="pkg-modal" id="paymentModal" style="max-width:520px;">
                <div class="pkg-modal-header">
                    <h5><i class="bi bi-shield-lock" style="color:var(--primary);"></i> Secure Checkout</h5>
                    <button class="pkg-modal-close" onclick="closePaymentModal()">&times;</button>
                </div>
                <div class="pkg-modal-body" style="padding:0;">
                    <div style="padding:24px 24px 0;">
                        <div class="payment-summary" style="background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:16px;padding:20px;margin-bottom:24px;">
                            <div style="display:flex;justify-content:space-between;margin-bottom:14px;">
                                <span style="color:var(--text-secondary);font-size:0.88rem;display:flex;align-items:center;gap:6px;"><i class="bi bi-grid-3x3-gap" style="color:var(--primary);font-size:0.85rem;"></i> Platform</span>
                                <strong id="pay-platform" style="color:var(--text-primary);font-size:0.92rem;">-</strong>
                            </div>
                            <div id="pay-items" style="margin-bottom:14px;"></div>
                            <div style="height:1px;background:var(--border-subtle);margin:14px 0;"></div>
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                                <span style="color:var(--text-secondary);font-size:0.85rem;"><i class="bi bi-cash-stack" style="margin-right:4px;"></i> Currency</span>
                                <select id="pay-currency-select" style="padding:6px 12px;border-radius:8px;border:1px solid var(--border-subtle);background:var(--bg-surface);color:var(--text-primary);font-size:0.85rem;font-weight:600;cursor:pointer;" onchange="updatePayCurrency()">
                                    <option value="PKR">PKR (Rs)</option>
                                    <option value="USD">USD ($)</option>
                                    <option value="EUR">EUR (&euro;)</option>
                                    <option value="GBP">GBP (&pound;)</option>
                                    <option value="INR">INR (&#8377;)</option>
                                    <option value="SAR">SAR</option>
                                    <option value="AED">AED</option>
                                    <option value="CAD">CAD (C$)</option>
                                    <option value="AUD">AUD (A$)</option>
                                    <option value="TRY">TRY</option>
                                    <option value="BDT">BDT</option>
                                    <option value="BRL">BRL (R$)</option>
                                    <option value="JPY">JPY (&yen;)</option>
                                    <option value="CNY">CNY</option>
                                    <option value="KRW">KRW</option>
                                    <option value="NGN">NGN</option>
                                    <option value="PHP">PHP</option>
                                    <option value="IDR">IDR</option>
                                    <option value="MYR">MYR</option>
                                    <option value="THB">THB</option>
                                    <option value="EGP">EGP</option>
                                    <option value="ZAR">ZAR</option>
                                    <option value="MXN">MXN</option>
                                </select>
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="color:var(--text-primary);font-weight:800;font-size:0.95rem;">Total</span>
                                <strong id="pay-total" style="font-size:1.5rem;color:var(--primary);font-weight:900;">0.00</strong>
                            </div>
                        </div>

                        <div style="margin-bottom:20px;">
                            <div style="font-size:0.82rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:12px;">Choose Payment Method</div>
                            <div class="pay-methods-grid">
                                <button type="button" class="pay-method-card" onclick="selectPayMethod(this,'stripe')">
                                    <div class="pay-method-icon" style="background:linear-gradient(135deg,#635BFF,#7A73FF);">
                                        <i class="bi bi-credit-card-2-front"></i>
                                    </div>
                                    <div class="pay-method-info">
                                        <span class="pay-method-name">Card Payment</span>
                                        <span class="pay-method-desc">Visa, Mastercard, AMEX</span>
                                    </div>
                                    <i class="bi bi-chevron-right pay-method-arrow"></i>
                                </button>
                                <button type="button" class="pay-method-card" onclick="selectPayMethod(this,'paypal')">
                                    <div class="pay-method-icon" style="background:linear-gradient(135deg,#0070BA,#003087);">
                                        <i class="bi bi-paypal"></i>
                                    </div>
                                    <div class="pay-method-info">
                                        <span class="pay-method-name">PayPal</span>
                                        <span class="pay-method-desc">Pay with PayPal balance</span>
                                    </div>
                                    <i class="bi bi-chevron-right pay-method-arrow"></i>
                                </button>
                                <button type="button" class="pay-method-card" onclick="selectPayMethod(this,'crypto')">
                                    <div class="pay-method-icon" style="background:linear-gradient(135deg,#F7931A,#E8850E);">
                                        <i class="bi bi-bitcoin"></i>
                                    </div>
                                    <div class="pay-method-info">
                                        <span class="pay-method-name">Cryptocurrency</span>
                                        <span class="pay-method-desc">BTC, ETH, USDT</span>
                                    </div>
                                    <i class="bi bi-chevron-right pay-method-arrow"></i>
                                </button>
                                <button type="button" class="pay-method-card" onclick="selectPayMethod(this,'bank')">
                                    <div class="pay-method-icon" style="background:linear-gradient(135deg,#10B981,#059669);">
                                        <i class="bi bi-bank"></i>
                                    </div>
                                    <div class="pay-method-info">
                                        <span class="pay-method-name">Bank Transfer</span>
                                        <span class="pay-method-desc">Direct bank deposit</span>
                                    </div>
                                    <i class="bi bi-chevron-right pay-method-arrow"></i>
                                </button>
                            </div>
                        </div>

                        <div id="pay-secure-badge" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:10px;background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.15);border-radius:12px;margin-bottom:20px;">
                            <i class="bi bi-shield-lock-fill" style="color:#10B981;font-size:0.9rem;"></i>
                            <span style="color:#10B981;font-size:0.82rem;font-weight:600;">256-bit SSL Encrypted &middot; Your data is secure</span>
                        </div>
                    </div>

                    <div style="padding:16px 24px 24px;border-top:1px solid var(--border-subtle);">
                        <button type="button" id="payConfirmBtn" class="pay-confirm-btn" onclick="confirmPayment()">
                            <i class="bi bi-lock-fill"></i> Confirm & Pay
                        </button>
                        <p style="color:var(--text-muted);font-size:0.75rem;margin-top:10px;text-align:center;">Your order will be reviewed by our admin team after payment.</p>
                    </div>
                </div>
            </div>

            <!-- ── Contact Us Section ── -->
            <section class="section" id="contact">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-envelope-fill"></i> Contact Us</div>
                    <h2 class="section-title section-title-light">Get In Touch</h2>
                    <p class="section-subtitle">Have questions or need custom engagement packages? We're here to help.</p>
                </div>
                <div class="inquiry-form-card">
                    <div id="contactSuccess" style="display:none;" class="inquiry-success">
                        <i class="bi bi-check-circle-fill"></i>&nbsp; Message sent! We'll get back to you within 24 hours.
                    </div>
                    <form id="contactForm" onsubmit="submitContact(event)">
                        <div class="inquiry-grid">
                            <div class="inquiry-field">
                                <label>Name <span>*</span></label>
                                <input type="text" id="ct-name" placeholder="Your name" required />
                            </div>
                            <div class="inquiry-field">
                                <label>Email <span>*</span></label>
                                <input type="email" id="ct-email" placeholder="you@example.com" required />
                            </div>
                            <div class="inquiry-field inquiry-field-full">
                                <label>Subject <span>*</span></label>
