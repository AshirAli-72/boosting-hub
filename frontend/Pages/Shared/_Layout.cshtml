<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <base href="/" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Boosting Hub - @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @if (ViewData["PageType"]?.ToString() == "landing")
    {
        <link rel="stylesheet" href="~/css/landing.css" />
    }
    else if (ViewData["PageType"]?.ToString() == "auth")
    {
        <link rel="stylesheet" href="~/css/auth.css" />
    }
    else if (ViewData["BodyClass"]?.ToString() == "dashboard-page" || ViewData["BodyClass"]?.ToString() == "admin-page")
    {
        <link rel="stylesheet" href="~/css/dashboard.css" />
    }
    else if (ViewData["BodyClass"]?.ToString() == "user-dashboard-page")
    {
        <link rel="stylesheet" href="~/css/dashboard.css" />
    }
    @await RenderSectionAsync("Styles", required: false)
    <script>
        const savedTheme = localStorage.getItem('theme') || 'dark';
        if (savedTheme === 'light') {
            document.documentElement.classList.add('light-mode');
        }
    </script>
</head>
<body class="@ViewData["BodyClass"]" style="background:#0B1120;color:#f1f5f9;">
    <script>if(localStorage.getItem('theme')==='light')document.body.classList.add('light-mode');</script>
    @if (ViewData["PageType"]?.ToString() == "landing")
    {
        <header class="landing-header" id="landingHeader">
            <div class="header-inner">
                <a href="/" class="header-logo">
                    <div class="header-logo-icon"><i class="bi bi-rocket-takeoff"></i></div>
                    <span class="header-logo-text">Boosting Hub</span>
                </a>
                <nav class="header-nav" id="headerNav">
                    <a href="#features">Features</a>
                    <a href="#stats">Stats</a>
                    <a href="#get-started">Get Started</a>
                    <div class="mobile-nav-cta">
                        <a href="/login" class="btn-ghost"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                        <a href="/register" class="btn-primary-solid"><i class="bi bi-person-plus"></i> Get Started</a>
                    </div>
                </nav>
                <div class="header-cta" id="headerCta">
                    <a href="/login" class="btn-ghost"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                    <a href="/register" class="btn-primary-solid"><i class="bi bi-person-plus"></i> Get Started</a>
                </div>
                <button class="mobile-toggle" id="mobileToggle" onclick="toggleMobileNav()">&#9776;</button>
            </div>
        </header>

        <main>
            @RenderBody()

            <section class="hero" id="hero">
                <div class="hero-bg-glow"></div>
                <div class="hero-bg-glow-2"></div>
                <div class="hero-grid">
                    <div>
                        <div class="hero-badge"><i class="bi bi-lightning-fill"></i> Trusted by @((ViewData["LandingTotalUsers"] as int? ?? 0).ToString("N0"))+ creators</div>
                        <h1 class="hero-title">
                            Grow Your Social<br>
                            <span class="hero-title-gradient">Engagement</span><br>
                            Effortlessly
                        </h1>
                        <p class="hero-subtitle">
                            The premier marketplace connecting content creators with real, high-quality engagement.
                            Boost your social presence with authentic likes, followers, and views.
                        </p>
                        <div class="hero-actions">
                            <a href="/register" class="btn-hero-primary">
                                <i class="bi bi-rocket-takeoff"></i> Get Started Free
                            </a>
                            <a href="#features" class="btn-hero-secondary">
                                <i class="bi bi-play-circle"></i> See How It Works
                            </a>
                        </div>

                    </div>
                    <div class="hero-visual">
                        <div class="hero-card-mockup">
                            <div class="hero-card-header">
                                <div class="hero-card-dots"><span></span><span></span><span></span></div>
                                <div class="hero-card-avatar">
                                    <div class="hero-card-avatar-circle">JD</div>
                                    <span>@(User.Identity?.Name ?? "Guest User")</span>
                                </div>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon purple"><i class="bi bi-instagram"></i></div>
                                <div class="hero-card-content"><h4>Instagram Followers</h4><p>1,500 followers &bull; 2h ago</p></div>
                                <span class="hero-card-status live">Live</span>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon green"><i class="bi bi-youtube"></i></div>
                                <div class="hero-card-content"><h4>YouTube Views</h4><p>10,000 views &bull; 30m ago</p></div>
                                <span class="hero-card-status live">Live</span>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon orange"><i class="bi bi-tiktok"></i></div>
                                <div class="hero-card-content"><h4>TikTok Likes</h4><p>5,000 likes &bull; 1h ago</p></div>
                                <span class="hero-card-status pending">Pending</span>
                            </div>
                            <div class="hero-card-row">
                                <div class="hero-card-icon blue"><i class="bi bi-twitter-x"></i></div>
                                <div class="hero-card-content"><h4>X (Twitter) Followers</h4><p>3,000 followers &bull; 4h ago</p></div>
                                <span class="hero-card-status live">Live</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="section" id="features">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-stars"></i> Features</div>
                    <h2 class="section-title section-title-light">Everything You Need to Grow</h2>
                    <p class="section-subtitle">Powerful tools and real engagement to supercharge your social media presence across all major platforms.</p>
                </div>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon purple"><i class="bi bi-shield-check"></i></div>
                        <h3>Real &amp; Authentic</h3>
                        <p>All engagement comes from real accounts. No bots, no fake profiles, guaranteed authentic growth.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon green"><i class="bi bi-lightning-charge"></i></div>
                        <h3>Lightning Fast</h3>
                        <p>Orders start within minutes of placement. Our automated system delivers results at unprecedented speed.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon blue"><i class="bi bi-graph-up-arrow"></i></div>
                        <h3>Smart Analytics</h3>
                        <p>Track your growth with detailed analytics, real-time reporting, and performance insights dashboard.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon orange"><i class="bi bi-globe2"></i></div>
                        <h3>Multi-Platform</h3>
                        <p>Supporting Instagram, YouTube, TikTok, X (Twitter), Facebook, LinkedIn, and more major platforms.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon pink"><i class="bi bi-lock-fill"></i></div>
                        <h3>Secure &amp; Private</h3>
                        <p>Your data is encrypted end-to-end. We never share your information with third parties.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon teal"><i class="bi bi-headset"></i></div>
                        <h3>24/7 Support</h3>
                        <p>Our dedicated support team is available around the clock to help you with any questions or issues.</p>
                    </div>
                </div>
            </section>

            <section class="section-light" id="stats">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-bar-chart-fill"></i> Our Numbers</div>
                    <h2 class="section-title section-title-dark">Trusted by Creators Worldwide</h2>
                    <p class="section-subtitle section-subtitle-dark">Join thousands of satisfied content creators who trust Boosting Hub for their social media growth.</p>
                </div>
                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-number">@((ViewData["LandingTotalUsers"] as int? ?? 0).ToString("N0"))+</div><div class="stat-label">Users</div></div>
                    <div class="stat-card"><div class="stat-number">@((ViewData["LandingTotalOrders"] as int? ?? 0).ToString("N0"))+</div><div class="stat-label">Orders</div></div>
                    <div class="stat-card"><div class="stat-number">@((ViewData["LandingCompletedTasks"] as int? ?? 0).ToString("N0"))+</div><div class="stat-label">Completed Orders</div></div>
                </div>
            </section>

            <section class="section" id="users-section">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-people-fill"></i> Our Community</div>
                    <h2 class="section-title section-title-light">Recently Joined Creators</h2>
                    <p class="section-subtitle">Real people who registered and are growing their social presence with Boosting Hub.</p>
                </div>
                <div class="users-grid">
                    @{
                        var recentUsers = ViewData["RecentUsers"] as List<BoostingHub.backend.Models.User> ?? new();
                        if (recentUsers.Count == 0)
                        {
                            <div class="user-joined-card">
                                <div class="user-joined-avatar" style="background:linear-gradient(135deg,#7C3AED,#0D9488);">BH</div>
                                <div class="user-joined-info">
                                    <h4>Be the First!</h4>
                                    <p>Join our growing community of creators.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            foreach (var user in recentUsers)
                            {
                                var initials = string.IsNullOrEmpty(user.Name) ? "?" : user.Name.Split(' ').Take(2).Aggregate((a, b) => a[..1] + b[..1]).ToUpper();
                                var colors = new[] { "#7C3AED,#0D9488", "#3B82F6,#1D4ED8", "#10B981,#059669", "#F59E0B,#D97706", "#EF4444,#B91C1C", "#EC4899,#BE185D", "#6366F1,#4F46E5", "#0D9488,#0F766E" };
                                var colorIdx = user.Id % colors.Length;
                                var displayName = user.Name ?? "User";
                                var timeAgo = (DateTime.UtcNow - user.CreatedAt).TotalDays switch
                                {
                                    < 1 => "today",
                                    < 2 => "yesterday",
                                    < 7 => $"{(int)(DateTime.UtcNow - user.CreatedAt).TotalDays} days ago",
                                    < 30 => $"{(int)(DateTime.UtcNow - user.CreatedAt).TotalDays / 7} weeks ago",
                                    _ => $"since {user.CreatedAt:MMM yyyy}"
                                };
                                <div class="user-joined-card">
                                    <div class="user-joined-avatar" style="background:linear-gradient(135deg,{colors[colorIdx]});">@initials</div>
                                    <div class="user-joined-info">
                                        <h4>@displayName</h4>
                                        <p>Joined @timeAgo</p>
                                    </div>
                                    <div class="user-joined-badge"><i class="bi bi-patch-check-fill"></i></div>
                                </div>
                            }
                        }
                    }
                </div>
            </section>

            <!-- ── Client Requirements Section ── -->
            <section class="inquiry-section" id="get-started">
                <div class="section-header">
                    <div class="section-label"><i class="bi bi-send-fill"></i> Get Started</div>
                    <h2 class="section-title section-title-light">Submit Your Requirements</h2>
                    <p class="section-subtitle">Tell us what you need — choose your Platforms, Service Types, and Budget. Our admin reviews and publishes tasks for our users.</p>
                </div>
                <div class="inquiry-form-card">
                    <div id="inquirySuccess" style="display:none;" class="inquiry-success">
                        <i class="bi bi-check-circle-fill"></i>&nbsp; Your request has been submitted! We'll review it shortly.
                    </div>
                    <div id="inquiryError" style="display:none;" class="alert alert-danger" style="border-radius:12px;">
                        <i class="bi bi-exclamation-triangle-fill"></i>&nbsp; <span id="inquiryErrorText"></span>
                    </div>
                    <form id="inquiryForm" onsubmit="submitInquiry(event)">
                        <!-- Contact Information -->
                        <div class="inquiry-section-group">
                            <div class="inquiry-group-title"><i class="bi bi-person-badge"></i> Contact Information</div>
                            <div class="inquiry-grid">
                                <div class="inquiry-field">
                                    <label>Your Name <span>*</span></label>
                                    <input type="text" id="iq-name" placeholder="John Doe" required />
                                </div>
                                <div class="inquiry-field">
                                    <label>Email <span>*</span></label>
                                    <input type="email" id="iq-email" placeholder="john@example.com" required />
                                </div>
                            </div>
                        </div>

                        <!-- Campaign Details -->
                        <div class="inquiry-section-group">
                            <div class="inquiry-group-title"><i class="bi bi-sliders"></i> Campaign Details</div>
                            <div class="inquiry-grid">
                                <div class="inquiry-field inquiry-field-full">
                                    <label>Platforms <span>*</span></label>
                                    <div class="iq-cb-dropdown" id="iq-platform-dropdown">
                                        <div class="iq-cb-trigger" onclick="toggleCheckDropdown('iq-platform-dropdown')">
                                            <span class="iq-cb-placeholder">Select Platforms</span>
                                            <span class="iq-cb-selected" style="display:none;"></span>
                                            <i class="bi bi-chevron-down iq-cb-arrow"></i>
                                        </div>
                                        <div class="iq-cb-panel">
                                            <div class="iq-cb-select-all" onclick="toggleSelectAll('iq-platform-dropdown')"><input type="checkbox" class="iq-cb-selectall-cb"> Select All</div>
                                            <label class="iq-cb-item"><input type="checkbox" value="Instagram" onchange="onCheckChange('iq-platform-dropdown')"><span class="iq-cb-check"></span>Instagram</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="YouTube" onchange="onCheckChange('iq-platform-dropdown')"><span class="iq-cb-check"></span>YouTube</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="TikTok" onchange="onCheckChange('iq-platform-dropdown')"><span class="iq-cb-check"></span>TikTok</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="Twitter" onchange="onCheckChange('iq-platform-dropdown')"><span class="iq-cb-check"></span>Twitter / X</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="Facebook" onchange="onCheckChange('iq-platform-dropdown')"><span class="iq-cb-check"></span>Facebook</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="LinkedIn" onchange="onCheckChange('iq-platform-dropdown')"><span class="iq-cb-check"></span>LinkedIn</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="inquiry-field inquiry-field-full">
                                    <label>Service Types <span>*</span></label>
                                    <div class="iq-cb-dropdown" id="iq-service-dropdown">
                                        <div class="iq-cb-trigger" onclick="toggleCheckDropdown('iq-service-dropdown')">
                                            <span class="iq-cb-placeholder">Select Service Types</span>
                                            <span class="iq-cb-selected" style="display:none;"></span>
                                            <i class="bi bi-chevron-down iq-cb-arrow"></i>
                                        </div>
                                        <div class="iq-cb-panel">
                                            <div class="iq-cb-select-all" onclick="toggleSelectAll('iq-service-dropdown')"><input type="checkbox" class="iq-cb-selectall-cb"> Select All</div>
                                            <label class="iq-cb-item"><input type="checkbox" value="Followers" onchange="onCheckChange('iq-service-dropdown')"><span class="iq-cb-check"></span>Followers</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="Likes" onchange="onCheckChange('iq-service-dropdown')"><span class="iq-cb-check"></span>Likes</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="Views" onchange="onCheckChange('iq-service-dropdown')"><span class="iq-cb-check"></span>Views</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="Comments" onchange="onCheckChange('iq-service-dropdown')"><span class="iq-cb-check"></span>Comments</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="Shares" onchange="onCheckChange('iq-service-dropdown')"><span class="iq-cb-check"></span>Shares</label>
                                            <label class="iq-cb-item"><input type="checkbox" value="Subscribers" onchange="onCheckChange('iq-service-dropdown')"><span class="iq-cb-check"></span>Subscribers</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="inquiry-field">
                                    <label>Quantity <span>*</span></label>
                                    <input type="number" id="iq-qty" min="100" max="1000000" placeholder="Min 100" required />
                                </div>
                                <div class="inquiry-field">
                                    <label>Target URL <span>*</span></label>
                                    <input type="url" id="iq-url" placeholder="https://instagram.com/..." required />
                                </div>
                                <div class="inquiry-field">
                                    <label>Budget <span>*</span></label>
                                    <div class="input-group" style="display:flex;gap:0;">
                                        <select id="iq-currency" style="width:90px;border:1px solid var(--border-muted);border-radius:10px 0 0 10px;background:var(--bg-card);color:var(--text-primary);padding:10px 6px;font-size:0.9rem;outline:none;">
                                            <option value="USD">$ USD</option>
                                            <option value="EUR">€ EUR</option>
                                            <option value="GBP">£ GBP</option>
                                            <option value="PKR">₨ PKR</option>
                                            <option value="INR">₹ INR</option>
                                            <option value="BDT">৳ BDT</option>
                                        </select>
                                        <input type="number" id="iq-budget" min="1" step="0.01" placeholder="e.g. 50.00" required style="border-radius:0 10px 10px 0;flex:1;border:1px solid var(--border-muted);border-left:none;background:var(--bg-card);color:var(--text-primary);padding:10px 14px;outline:none;" />
                                    </div>
                                </div>
                                <div class="inquiry-field inquiry-field-full">
                                    <label>Description <small>(optional)</small></label>
                                    <textarea id="iq-description" rows="3" placeholder="Tell us more about what you need..."></textarea>
                                </div>
                            </div>
                        </div>

                        <button type="submit" id="inquirySubmitBtn" class="btn-hero-primary w-100 mt-3" style="justify-content:center;">
                            <i class="bi bi-send"></i> Submit Requirements
                        </button>
                    </form>
                </div>
            </section>

            <section class="cta-section">
                <div class="cta-inner">
                    <h2>Ready to Boost Your Growth?</h2>
                    <p>Join thousands of creators who trust Boosting Hub for their social media engagement. Start growing your audience today.</p>
                    <a href="/register" class="btn-cta">
                        <i class="bi bi-rocket-takeoff"></i> Create Free Account
                    </a>
                </div>
            </section>
        </main>

        <footer class="landing-footer">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a href="/" class="header-logo">
                        <div class="header-logo-icon"><i class="bi bi-rocket-takeoff"></i></div>
                        <span class="header-logo-text">Boosting Hub</span>
                    </a>
                    <p>The premier social engagement marketplace connecting content creators with quality engagement services.</p>
                </div>
                <div class="footer-col">
                    <h4>Platform</h4>
                    <a href="#features">Features</a>
                    <a href="#get-started">Get Started</a>
                    <a href="#">FAQ</a>
                </div>
                <div class="footer-col">
                    <h4>Company</h4>
                    <a href="#">About Us</a>
                    <a href="#">Blog</a>
                    <a href="#">Contact</a>
                </div>
                <div class="footer-col">
                    <h4>Legal</h4>
                    <a href="#">Terms of Service</a>
                    <a href="#">Privacy Policy</a>
                    <a href="#">Refund Policy</a>
                </div>
            </div>
            <div class="footer-bottom">
                <span>&copy; 2026 Boosting Hub. All rights reserved.</span>
                <div class="footer-social">
                    <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="#" aria-label="Discord"><i class="bi bi-discord"></i></a>
                    <a href="#" aria-label="GitHub"><i class="bi bi-github"></i></a>
                </div>
            </div>
        </footer>
    }
    else
    {
        @if (ViewData["PageType"]?.ToString() != "auth" && ViewData["BodyClass"]?.ToString() != "admin-page" && ViewData["BodyClass"]?.ToString() != "user-dashboard-page")
        {
            <header>
                <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
                    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
                        <div style="width:28px;height:28px;background:linear-gradient(135deg,#7C3AED,#0D9488);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:0.9rem;color:#fff;">
                            <i class="bi bi-rocket-takeoff"></i>
                        </div>
                        Boosting Hub
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-person"></i> Profile</a></li>
                                <li class="nav-item"><a class="nav-link" href="/security"><i class="bi bi-shield-lock"></i> Security</a></li>
                                <li class="nav-item"><a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right"></i> Login</a></li>
                                <li class="nav-item"><a class="nav-link" href="/register"><i class="bi bi-person-plus"></i> Register</a></li>
                            }
                        </ul>
                    </div>
                </nav>
            </header>
        }
        var rp = Context.Request.Path.Value?.ToLower() ?? "";
        var isAdm = ViewData["BodyClass"]?.ToString() == "admin-page";
        var isUsr = ViewData["BodyClass"]?.ToString() == "user-dashboard-page";
        @if (isAdm || isUsr)
        {
            <div class="admin-layout">
                @if (isAdm)
                {
                    <aside class="admin-sidebar">
                        <div class="sidebar-brand">
                            <div class="sidebar-brand-icon"><i class="bi bi-rocket-takeoff"></i></div>
                            <span>Boosting Hub</span>
                        </div>
                        <nav class="sidebar-nav">
                            <a href="/admin-panel" class="sidebar-link @(rp == "/admin-panel" ? "active" : "")"><i class="bi bi-speedometer2"></i> Dashboard</a>
                            <a href="/admin/reports" class="sidebar-link @(rp.StartsWith("/admin/reports") ? "active" : "")"><i class="bi bi-bar-chart-line"></i> Reports</a>
                            <a href="/admin/in-progress" class="sidebar-link @(rp == "/admin/in-progress" ? "active" : "")"><i class="bi bi-hourglass-split"></i> In Progress</a>
                            <a href="/admin/completed" class="sidebar-link @(rp == "/admin/completed" ? "active" : "")"><i class="bi bi-check2-all"></i> Completed</a>
                            <a href="/admin/inquiries" class="sidebar-link @(rp == "/admin/inquiries" ? "active" : "")"><i class="bi bi-inbox"></i> Client Requirements</a>
                            <a href="/admin/proof-review" class="sidebar-link @(rp == "/admin/proof-review" ? "active" : "")"><i class="bi bi-shield-check"></i> Proof Review</a>
                            <div class="sidebar-divider"></div>
                            <a href="/admin/settings" class="sidebar-link @(rp.StartsWith("/admin/settings") || rp.StartsWith("/admin/roles") || rp.StartsWith("/admin/users") ? "active" : "")"><i class="bi bi-gear"></i> Settings</a>
                            <a href="/logout" class="sidebar-link sidebar-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                        </nav>
                    </aside>
                }
                else if (isUsr)
                {
                    <aside class="admin-sidebar user-sidebar">
                        <div class="sidebar-brand">
                            <div class="sidebar-brand-icon"><i class="bi bi-rocket-takeoff"></i></div>
                            <span>Boosting Hub</span>
                        </div>
                        <nav class="sidebar-nav">
                            <a href="/dashboard" class="sidebar-link @(rp == "/dashboard" ? "active" : "")"><i class="bi bi-speedometer2"></i> Dashboard</a>
                            <a href="/tasks" class="sidebar-link @(rp == "/tasks" ? "active" : "")"><i class="bi bi-list-task"></i> Available Tasks</a>
                            <a href="/my-tasks" class="sidebar-link @(rp == "/my-tasks" ? "active" : "")"><i class="bi bi-check2-square"></i> My Tasks</a>
                            <a href="/wallet" class="sidebar-link @(rp == "/wallet" ? "active" : "")"><i class="bi bi-wallet2"></i> Wallet</a>
                            <a href="/user/settings" class="sidebar-link @(rp.StartsWith("/user/settings") || rp == "/settings" || rp.StartsWith("/user/accounts") ? "active" : "")"><i class="bi bi-gear"></i> Settings</a>
                            <div class="sidebar-divider"></div>
                            <a href="/logout" class="sidebar-link sidebar-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                        </nav>
                    </aside>
                }
                <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
                <button class="sidebar-mobile-toggle" id="sidebarToggle" onclick="toggleSidebar()" aria-label="Toggle menu">
                    <i class="bi bi-list"></i>
                </button>
                <main class="admin-main">
                    @RenderBody()
                </main>
            </div>
        }
        else
        {
            <main>
                @RenderBody()
            </main>
        }
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/_framework/blazor.server.js"></script>
    <script>
        function toggleMobileNav() {
            document.getElementById('headerNav').classList.toggle('open');
        }
        window.addEventListener('scroll', function () {
            var h = document.getElementById('landingHeader');
            if (h) h.classList.toggle('scrolled', window.scrollY > 50);
        });
        async function submitInquiry(e) {
            e.preventDefault();

            var platform = getCheckedValues('iq-platform-dropdown');
            var service = getCheckedValues('iq-service-dropdown');
            if (!platform) { alert('Please select at least one Platform.'); return; }
            if (!service) { alert('Please select at least one Service Type.'); return; }

            const qty = parseInt(document.getElementById('iq-qty').value);
            const url = document.getElementById('iq-url').value;
            const budget = parseFloat(document.getElementById('iq-budget').value);
            const currency = document.getElementById('iq-currency').value;
            const name = document.getElementById('iq-name').value;
            const email = document.getElementById('iq-email').value;
            const description = document.getElementById('iq-description').value;

            const btn = document.getElementById('inquirySubmitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Submitting...';

            try {
                const resp = await fetch('/api/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        fullName: name,
                        email: email,
                        platform: platform,
                        service: service,
                        quantity: qty,
                        socialMediaUrl: url,
                        budget: budget,
                        currency: currency,
                        description: description
                    })
                });
                const data = await resp.json();
                if (resp.ok) {
                    document.getElementById('inquirySuccess').style.display = 'flex';
                    document.getElementById('inquiryError').style.display = 'none';
                    document.getElementById('inquiryForm').reset();
                    resetCheckDropdowns();
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send"></i> Submit Requirements';
                    setTimeout(function() {
                        document.getElementById('inquirySuccess').style.display = 'none';
                    }, 5000);
                } else {
                    var errEl = document.getElementById('inquiryError');
                    if (errEl) { errEl.style.display = 'block'; document.getElementById('inquiryErrorText').textContent = data.message || 'Submission failed.'; }
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send"></i> Submit Requirements';
                }
            } catch (err) {
                alert('Network error. Please try again.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send"></i> Submit Requirements';
            }
        }
        function toggleCheckDropdown(id) {
            var dd = document.getElementById(id);
            var wasOpen = dd.classList.contains('open');
            document.querySelectorAll('.iq-cb-dropdown.open').forEach(function(el) { el.classList.remove('open'); });
            if (!wasOpen) dd.classList.add('open');
        }
        function onCheckChange(id) {
            var dd = document.getElementById(id);
            var checks = dd.querySelectorAll('.iq-cb-panel input[type="checkbox"]:not(.iq-cb-selectall-cb)');
            var checked = dd.querySelectorAll('.iq-cb-panel input[type="checkbox"]:not(.iq-cb-selectall-cb):checked');
            var selected = dd.querySelector('.iq-cb-selected');
            var placeholder = dd.querySelector('.iq-cb-placeholder');
            var selectAllCb = dd.querySelector('.iq-cb-selectall-cb');
            if (selectAllCb) selectAllCb.checked = checks.length === checked.length && checks.length > 0;
            if (checked.length === 0) {
                selected.style.display = 'none';
                placeholder.style.display = '';
                selected.textContent = '';
            } else {
                placeholder.style.display = 'none';
                selected.style.display = '';
                var names = Array.from(checked).map(function(c) { return c.parentElement.textContent.trim(); });
                selected.textContent = names.length <= 2 ? names.join(', ') : names.slice(0, 2).join(', ') + ' +' + (names.length - 2) + ' more';
            }
        }
        function toggleSelectAll(id) {
            var dd = document.getElementById(id);
            var selectAllCb = dd.querySelector('.iq-cb-selectall-cb');
            var allCbs = dd.querySelectorAll('.iq-cb-panel input[type="checkbox"]:not(.iq-cb-selectall-cb)');
            allCbs.forEach(function(cb) { cb.checked = selectAllCb.checked; });
            onCheckChange(id);
        }
        function getCheckedValues(id) {
            var dd = document.getElementById(id);
            var checks = dd.querySelectorAll('.iq-cb-panel input[type="checkbox"]:not(.iq-cb-selectall-cb):checked');
            return Array.from(checks).map(function(c) { return c.value; }).join(',');
        }
        function resetCheckDropdowns() {
            document.querySelectorAll('.iq-cb-dropdown').forEach(function(dd) {
                dd.querySelectorAll('input[type="checkbox"]').forEach(function(c) { c.checked = false; });
                var selected = dd.querySelector('.iq-cb-selected');
                var placeholder = dd.querySelector('.iq-cb-placeholder');
                if (selected) { selected.textContent = ''; selected.style.display = 'none'; }
                if (placeholder) placeholder.style.display = '';
                dd.classList.remove('open');
            });
        }
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.iq-cb-dropdown')) {
                document.querySelectorAll('.iq-cb-dropdown.open').forEach(function(el) { el.classList.remove('open'); });
            }
        });
        document.addEventListener('DOMContentLoaded', () => {
            const themeToggleBtn = document.getElementById('themeToggle');
            if (themeToggleBtn) {
                const icon = themeToggleBtn.querySelector('i');
                if (document.body.classList.contains('light-mode')) {
                    icon.classList.replace('bi-moon-stars', 'bi-sun');
                }
                themeToggleBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    document.body.classList.toggle('light-mode');
                    document.documentElement.classList.toggle('light-mode');
                    if (document.body.classList.contains('light-mode')) {
                        localStorage.setItem('theme', 'light');
                        icon.classList.replace('bi-moon-stars', 'bi-sun');
                    } else {
                        localStorage.setItem('theme', 'dark');
                        icon.classList.replace('bi-sun', 'bi-moon-stars');
                    }
                });
            }
        });
    </script>
    <script>
        function toggleSidebar() {
            var sidebar = document.querySelector('.admin-sidebar');
            var overlay = document.getElementById('sidebarOverlay');
            if (sidebar && overlay) {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('open');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
