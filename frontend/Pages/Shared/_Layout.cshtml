                            <span>Boosting Hub</span>
                        </div>
                        <nav class="sidebar-nav">
                            <a href="/admin-panel" class="sidebar-link @(rp == "/admin-panel" ? "active" : "")"><i class="bi bi-speedometer2"></i> Dashboard</a>
                            <a href="/admin/reports" class="sidebar-link @(rp.StartsWith("/admin/reports") ? "active" : "")"><i class="bi bi-bar-chart-line"></i> Reports</a>
                            <a href="/admin/in-progress" class="sidebar-link @(rp == "/admin/in-progress" ? "active" : "")"><i class="bi bi-hourglass-split"></i> In Progress</a>
                            <a href="/admin/completed" class="sidebar-link @(rp == "/admin/completed" ? "active" : "")"><i class="bi bi-check2-all"></i> Completed</a>
                            <a href="/admin/inquiries" class="sidebar-link @(rp == "/admin/inquiries" ? "active" : "")"><i class="bi bi-inbox"></i> Clients</a>
                            <a href="/admin/proof-review" class="sidebar-link @(rp == "/admin/proof-review" ? "active" : "")"><i class="bi bi-shield-check"></i> Proof Review</a>
                            <a href="/admin/activity-logs" class="sidebar-link @(rp.StartsWith("/admin/activity-logs") ? "active" : "")"><i class="bi bi-clock-history"></i> Activity Log</a>
                            <div class="sidebar-divider"></div>
                            <a href="/admin/settings" class="sidebar-link @(rp.StartsWith("/admin/settings") || rp.StartsWith("/admin/roles") || rp.StartsWith("/admin/users") ? "active" : "")"><i class="bi bi-gear"></i> Settings</a>
                            <a href="/logout" class="sidebar-link sidebar-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                        </nav>
                    </aside>
                }
                else if (isUsr)
                {
                    <aside class="admin-sidebar user-sidebar">
                        <div class="sidebar-brand">
                            <div class="sidebar-brand-icon"><i class="bi bi-rocket-takeoff"></i></div>
                            <span>Boosting Hub</span>
                        </div>
                        <nav class="sidebar-nav">
                            <a href="/dashboard" class="sidebar-link @(rp == "/dashboard" ? "active" : "")"><i class="bi bi-speedometer2"></i> Dashboard</a>
                            <a href="/tasks" class="sidebar-link @(rp == "/tasks" ? "active" : "")"><i class="bi bi-list-task"></i> Available Tasks</a>
                            <a href="/my-tasks" class="sidebar-link @(rp == "/my-tasks" ? "active" : "")"><i class="bi bi-check2-square"></i> My Tasks</a>
                            <a href="/wallet" class="sidebar-link @(rp == "/wallet" ? "active" : "")"><i class="bi bi-wallet2"></i> Wallet</a>
                            <a href="/user/settings" class="sidebar-link @(rp.StartsWith("/user/settings") || rp == "/settings" || rp.StartsWith("/user/accounts") || rp.StartsWith("/user/social-accounts") ? "active" : "")"><i class="bi bi-gear"></i> Settings</a>
                            <div class="sidebar-divider"></div>
                            <a href="/logout" class="sidebar-link sidebar-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                        </nav>
                    </aside>
                }
                <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
                <button class="sidebar-mobile-toggle" id="sidebarToggle" onclick="toggleSidebar()" aria-label="Toggle menu">
                    <i class="bi bi-list"></i>
                </button>
                <main class="admin-main">
                    @RenderBody()
                </main>
            </div>
        }
        else
        {
            <main>
                @RenderBody()
            </main>
        }
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>
    <script src="/_framework/blazor.server.js"></script>
    <script>
        function toggleMobileNav() {
            document.getElementById('headerNav').classList.toggle('open');
        }
        window.addEventListener('scroll', function () {
            var h = document.getElementById('landingHeader');
            if (h) h.classList.toggle('scrolled', window.scrollY > 50);
        });

        function toggleTheme() {
            const isLight = document.body.classList.toggle('light-mode');
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
            updateThemeIcons(isLight);
        }

        function updateThemeIcons(isLight) {
            document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
                if(isLight) { btn.classList.add('is-light'); }
                else { btn.classList.remove('is-light'); }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('theme') || 'dark';
            updateThemeIcons(savedTheme === 'light');
        });

        var iqServiceData = {};
        var iqDetectedCurrency = 'USD';
        var iqDetectedSymbol = '$';
        var iqBaseCurrency = 'PKR';
        var iqPkrRates = {
            'USD': 285, 'EUR': 310, 'GBP': 360, 'PKR': 1,
            'INR': 3.43, 'BDT': 2.59, 'SAR': 76, 'AED': 77.7,
            'CAD': 208, 'AUD': 186, 'TRY': 8.8,
            'BRL': 56, 'JPY': 1.91, 'CNY': 39.3, 'KRW': 0.21,
            'NGN': 0.18, 'PHP': 5.0, 'IDR': 0.018, 'MYR': 61,
            'THB': 8.0, 'EGP': 5.9, 'ZAR': 15.5, 'MXN': 16.5,
            'KWD': 930, 'QAR': 78, 'BHD': 755, 'OMR': 742
        };

        function convertFromPkr(amountPkr, toCurrency) {
            if (toCurrency === 'PKR') return amountPkr;
            var rate = iqPkrRates[toCurrency];
            if (!rate) return amountPkr;
            return amountPkr / rate;
        }

        var iqCurrencySymbols = {
            'PKR': '\u20A8', 'INR': '\u20B9', 'BDT': '\u09F3', 'GBP': '\u00A3',
            'EUR': '\u20AC', 'USD': '$', 'CAD': 'C$', 'AUD': 'A$', 'NZD': 'NZ$',
            'SAR': '\uFDFC', 'AED': '\u062F. ', 'TRY': '\u20BA', 'BRL': 'R$',
            'JPY': '\u00A5', 'CNY': '\u00A5', 'KRW': '\u20A9', 'NGN': '\u20A6',
            'PHP': '\u20B1', 'IDR': 'Rp', 'MYR': 'RM', 'THB': '\u0E3F',
            'EGP': 'E\u00A3', 'ZAR': 'R', 'MXN': 'Mex$'
        };

        function formatPrice(amount) {
            var converted = convertFromPkr(amount, iqDetectedCurrency);
            return iqDetectedSymbol + parseFloat(converted).toFixed(2);
        }

        function updateCurrencyBadge() {
            var badge = document.getElementById('iq-currency-badge');
            if (badge) {
                badge.textContent = iqDetectedSymbol + ' ' + iqDetectedCurrency;
                badge.title = 'Prices displayed in ' + iqDetectedCurrency + ' (' + iqDetectedSymbol + ')';
            }
        }

        function detectCurrency() {
            fetch('https://ipapi.co/json/')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.currency_code) {
                        iqDetectedCurrency = data.currency_code;
                        iqDetectedSymbol = iqCurrencySymbols[data.currency_code] || '$';
                        if (window.__userCurrencyCache !== undefined) window.__userCurrencyCache = data.currency_code;
                        updateCurrencyBadge();
                        refreshAllPrices();
                    }
                })
                .catch(function() {
                    detectCurrencyFallback();
                });
        }

        function detectCurrencyFallback() {
            try {
                var tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
                var tzMap = {
                    'Karachi': 'PKR', 'Lahore': 'PKR', 'Islamabad': 'PKR',
                    'Kolkata': 'INR', 'Mumbai': 'INR', 'Delhi': 'INR', 'Calcutta': 'INR',
                    'Dhaka': 'BDT',
                    'London': 'GBP',
                    'New_York': 'USD', 'Los_Angeles': 'USD', 'Chicago': 'USD', 'Denver': 'USD', 'Phoenix': 'USD', 'Anchorage': 'USD', 'Honolulu': 'USD',
                    'Toronto': 'CAD', 'Vancouver': 'CAD', 'Winnipeg': 'CAD', 'Halifax': 'CAD', 'Edmonton': 'CAD',
                    'Sydney': 'AUD', 'Melbourne': 'AUD', 'Brisbane': 'AUD', 'Perth': 'AUD', 'Adelaide': 'AUD', 'Darwin': 'AUD',
                    'Auckland': 'NZD',
                    'Riyadh': 'SAR', 'Dubai': 'AED', 'Qatar': 'QAR', 'Bahrain': 'BHD', 'Kuwait': 'KWT', 'Muscat': 'OMR', 'Tehran': 'IRR',
                    'Istanbul': 'TRY',
                    'Sao_Paulo': 'BRL', 'Fortaleza': 'BRL', 'Belem': 'BRL', 'Manaus': 'BRL',
                    'Tokyo': 'JPY', 'Shanghai': 'CNY', 'Chongqing': 'CNY', 'Harbin': 'CNY', 'Urumqi': 'CNY', 'Seoul': 'KRW',
                    'Lagos': 'NGN', 'Johannesburg': 'ZAR', 'Cairo': 'EGP', 'Nairobi': 'KES',
                    'Manila': 'PHP', 'Jakarta': 'IDR', 'Bangkok': 'THB', 'Kuala_Lumpur': 'MYR',
                    'Singapore': 'SGD', 'Hong_Kong': 'HKD', 'Taipei': 'TWD',
                    'Moscow': 'RUB', 'Kiev': 'UAH', 'Warsaw': 'PLN', 'Prague': 'CZK', 'Budapest': 'HUF', 'Bucharest': 'RON',
                    'Stockholm': 'SEK', 'Oslo': 'NOK', 'Copenhagen': 'DKK', 'Helsinki': 'EUR',
                    'Berlin': 'EUR', 'Paris': 'EUR', 'Rome': 'EUR', 'Madrid': 'EUR', 'Amsterdam': 'EUR',
                    'Mexico_City': 'MXN', 'Monterrey': 'MXN', 'Bogota': 'COP', 'Lima': 'PEN', 'Santiago': 'CLP',
                    'Buenos_Aires': 'ARS', 'Montevideo': 'UYU', 'La_Paz': 'BOB',
                    'Colombo': 'LKR', 'Kathmandu': 'NPR', 'Almaty': 'KZT', 'Tashkent': 'UZB'
                };
                for (var key in tzMap) {
                    if (tz.indexOf(key) !== -1) {
                        iqDetectedCurrency = tzMap[key];
                        iqDetectedSymbol = iqCurrencySymbols[tzMap[key]] || '$';
                        if (window.__userCurrencyCache !== undefined) window.__userCurrencyCache = tzMap[key];
                        updateCurrencyBadge();
                        refreshAllPrices();
                        return;
                    }
                }
            } catch(e) {}
        }

        function refreshAllPrices() {
            for (var s in iqServiceData) {
                var d = iqServiceData[s];
                if (d.unitPrice > 0) updateServiceAmount(s);
            }
            updateOrderSummary();
        }

        var iqServiceIcons = {
            'Followers': 'bi-people-fill', 'Likes': 'bi-heart-fill', 'Comments': 'bi-chat-fill',
            'Subscribers': 'bi-play-btn-fill', 'Shares': 'bi-share-fill', 'Views': 'bi-eye-fill',
            'Views/Likes': 'bi-eye-fill', 'Watch Time': 'bi-clock-fill',
            'Impressions': 'bi-lightning-fill', 'Reach': 'bi-broadcast', 'Saves': 'bi-bookmark-fill'
        };

        function getIcon(s) { return iqServiceIcons[s] || 'bi-star-fill'; }

        function getServiceThemeClass(service) {
            var s = service.toLowerCase();
            if (s.indexOf('follower') !== -1 || s.indexOf('subscriber') !== -1) return 'theme-purple';
            if (s.indexOf('like') !== -1) return 'theme-red';
            if (s.indexOf('comment') !== -1 || s.indexOf('chat') !== -1) return 'theme-blue';
            if (s.indexOf('share') !== -1 || s.indexOf('reach') !== -1) return 'theme-green';
            if (s.indexOf('view') !== -1 || s.indexOf('watch') !== -1) return 'theme-yellow';
            return 'theme-gray';
        }

        function onIqPlatformChange() {
            var menu = document.getElementById('iq-svc-menu');
            menu.innerHTML = '<p style="padding:12px 16px;color:var(--text-muted);font-size:0.85rem;">Loading services...</p>';
            menu.classList.remove('open');
            document.querySelectorAll('#iq-svc-menu input[type=checkbox]').forEach(function(cb) { cb.checked = false; });
            updateSvcLabel();
            document.getElementById('iq-service-qty-area').innerHTML = '';
            document.getElementById('iq-services-area').innerHTML = '';
            document.getElementById('iq-order-summary').style.display = 'none';
            iqServiceData = {};
            updateServiceQtyVisibility();
            var platform = document.getElementById('iq-platform').value;
            if (!platform) { menu.innerHTML = ''; return; }
            fetch('/api/packages/services/' + encodeURIComponent(platform))
                .then(function(r) { return r.ok ? r.json() : []; })
                .then(function(services) {
                    if (!services.length) { menu.innerHTML = '<p style="padding:12px 16px;color:var(--text-muted);font-size:0.85rem;">No services available.</p>'; return; }
                    menu.innerHTML = services.map(function(s) {
                        return '<label class="iq-svc-option"><input type="checkbox" value="' + s + '" onchange="onServiceToggle(this)" /> <i class="bi ' + getIcon(s) + '"></i> ' + s + '</label>';
                    }).join('');
                })
                .catch(function() { menu.innerHTML = '<p style="padding:12px 16px;color:var(--danger);font-size:0.85rem;">Failed to load services.</p>'; });
        }

        function toggleSvcDropdown() {
            var menu = document.getElementById('iq-svc-menu');
            menu.classList.toggle('open');
        }

        function updateSvcLabel() {
            var checked = [];
            document.querySelectorAll('#iq-svc-menu input[type=checkbox]:checked').forEach(function(cb) { checked.push(cb.value); });
            document.getElementById('iq-svc-label').textContent = checked.length ? checked.join(', ') : 'Choose services...';
        }

        document.addEventListener('click', function(e) {
            var dd = document.getElementById('iq-svc-dropdown');
            if (dd && !dd.contains(e.target)) { document.getElementById('iq-svc-menu').classList.remove('open'); }
        });

        function onServiceToggle(cb) {
            var service = cb.value;
            var platform = document.getElementById('iq-platform').value;
            if (!platform) { cb.checked = false; updateSvcLabel(); alert('Please select a platform first.'); return; }
            updateSvcLabel();

            if (cb.checked) {
                iqServiceData[service] = { packages: [], selectedPkg: null, qty: 0, price: 0, unitPrice: 0 };
                addServiceSection(service);
                fetchServicePrice(service, platform);
            } else {
                delete iqServiceData[service];
                var sec = document.getElementById('iq-sec-' + service);
                if (sec) sec.remove();
            }
            updateServiceQtyVisibility();
            updateOrderSummary();
        }

        async function fetchServicePrice(service, platform) {
            try {
                var resp = await fetch('/api/packages/by-platform-service?platform=' + encodeURIComponent(platform) + '&service=' + encodeURIComponent(service));
                if (!resp.ok) return;
                var packages = (await resp.json()).filter(function(p) { return p.isActive; });
                iqServiceData[service].packages = packages;
                if (!packages.length) return;
                var pkg = packages[0];
                iqServiceData[service].selectedPkg = pkg.id;
                iqServiceData[service].unitPrice = pkg.price;
                document.getElementById('iq-pkg-id-' + service).value = pkg.id;
                updateServiceAmount(service);
            } catch(e) { console.warn('Failed to fetch price for', service, e); }
        }

        function updateServiceAmount(service) {
            var d = iqServiceData[service];
            var unitEl = document.getElementById('iq-unit-' + service);
            if (!unitEl || !d.unitPrice) return;
            unitEl.innerHTML = formatPrice(d.unitPrice) + ' / unit';
            unitEl.style.display = 'inline-flex';
        }

        function addServiceSection(service) {
            var area = document.getElementById('iq-service-qty-area');
            var div = document.createElement('div');
            div.id = 'iq-sec-' + service;
            div.className = 'iq-svc-qty-section-wrapper';
            
            var iconClass = getIcon(service);
            var themeClass = getServiceThemeClass(service);
            
            div.innerHTML =
                '<div class="iq-svc-qty-row-card">' +
                    '<div class="iq-svc-qty-left">' +
                        '<div class="iq-svc-qty-icon-box ' + themeClass + '">' +
                            '<i class="bi ' + iconClass + '"></i>' +
                        '</div>' +
                        '<span class="iq-svc-qty-title">' + service + '</span>' +
                        '<span class="iq-svc-qty-unit-price" id="iq-unit-' + service + '" style="display:none;"></span>' +
                    '</div>' +
                    '<div class="iq-svc-qty-right">' +
                        '<div class="iq-svc-qty-input-box">' +
                            '<input type="number" id="iq-qty-' + service + '" min="1" placeholder="Enter quantity" oninput="onServiceQtyChange(\'' + service + '\')" onwheel="return false" />' +
                        '</div>' +
                        '<button type="button" class="iq-svc-qty-row-remove" onclick="removeService(\'' + service + '\')" title="Remove"><i class="bi bi-x-lg"></i></button>' +
                    '</div>' +
                '</div>' +
                '<input type="hidden" id="iq-pkg-id-' + service + '" />';
            area.appendChild(div);
        }

        function removeService(service) {
            delete iqServiceData[service];
            var sec = document.getElementById('iq-sec-' + service);
            if (sec) sec.remove();
            var cb = document.querySelector('#iq-svc-menu input[value="' + service + '"]');
            if (cb) cb.checked = false;
            updateSvcLabel();
            updateServiceQtyVisibility();
            updateOrderSummary();
        }

        async         function onServiceQtyChange(service) {
            var qty = parseInt(document.getElementById('iq-qty-' + service).value) || 0;
            iqServiceData[service].qty = qty;
            if (qty > 0 && iqServiceData[service].unitPrice > 0) {
                iqServiceData[service].price = iqServiceData[service].unitPrice * qty;
            } else {
                iqServiceData[service].price = 0;
            }
            updateServiceAmount(service);
            updateOrderSummary();
        }

        function updateOrderSummary() {
            var total = 0;
            var platform = document.getElementById('iq-platform').value;
            for (var s in iqServiceData) {
                var d = iqServiceData[s];
                if (d.selectedPkg && d.unitPrice > 0 && d.qty > 0) {
                    total += d.unitPrice * d.qty;
                }
            }
            var el = document.getElementById('iq-order-summary');
            if (total > 0) {
                el.style.animation = 'none';
                void el.offsetHeight;
                el.style.display = 'block';
                el.style.animation = '';
                document.getElementById('iq-total-price').textContent = formatPrice(total);
            } else {
                el.style.display = 'none';
            }
        }

        function updateServiceQtyVisibility() {
            var container = document.getElementById('iq-service-qty-container');
            var hasServices = Object.keys(iqServiceData).length > 0;
            if (container) {
                container.style.display = hasServices ? 'block' : 'none';
            }
        }

        document.addEventListener('DOMContentLoaded', function() { loadIqPlatforms(); detectCurrency(); updateCurrencyBadge(); });

        async function loadIqPlatforms() {
            try {
                var resp = await fetch('/api/packages/platforms');
                if (!resp.ok) return;
                var platforms = await resp.json();
                var sel = document.getElementById('iq-platform');
                if (!sel) return;
                platforms.forEach(function(p) {
                    var opt = document.createElement('option');
                    opt.value = p; opt.textContent = p;
                    sel.appendChild(opt);
                });
            } catch(e) {}
        }

        var selectedPayMethod = null;
        var payCurrency = 'PKR';

        function updatePayCurrency() {
            var sel = document.getElementById('pay-currency-select');
            if (sel) payCurrency = sel.value;
            refreshPaymentModalPrices();
        }

        function refreshPaymentModalPrices() {
            var curSel = document.getElementById('pay-currency-select');
            var cur = curSel ? curSel.value : payCurrency;
            var sym = iqCurrencySymbols[cur] || '$';
            var total = 0;
            var itemsHtml = '';
            var itemCount = 0;
            for (var s in iqServiceData) {
                var d = iqServiceData[s];
                if (d.selectedPkg) {
                    var pkrTotal = d.unitPrice * d.qty;
                    var converted = iqPkrRates[cur] ? pkrTotal / iqPkrRates[cur] : pkrTotal;
                    total += converted;
                    itemCount++;
                    var unitConverted = iqPkrRates[cur] ? d.unitPrice / iqPkrRates[cur] : d.unitPrice;
                    itemsHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;' + (itemCount > 1 ? 'border-top:1px solid var(--border-subtle);' : '') + '">' +
                        '<div style="flex:1;min-width:0;">' +
                            '<div style="font-size:0.88rem;font-weight:700;color:var(--text-primary);margin-bottom:3px;">' + s + '</div>' +
                            '<div style="font-size:0.78rem;color:var(--text-muted);">' + d.qty.toLocaleString() + ' \u00d7 ' + sym + parseFloat(unitConverted).toFixed(2) + '/unit</div>' +
                        '</div>' +
                        '<div style="font-size:0.95rem;font-weight:800;color:var(--primary);white-space:nowrap;margin-left:16px;">' + sym + parseFloat(converted).toFixed(2) + '</div>' +
                    '</div>';
                }
            }
            var payItems = document.getElementById('pay-items');
            var payTotal = document.getElementById('pay-total');
            if (payItems) payItems.innerHTML = itemsHtml;
            if (payTotal) payTotal.textContent = sym + parseFloat(total).toFixed(2);
        }

        function selectPayMethod(el, method) {
            document.querySelectorAll('.pay-method-card').forEach(function(c) { c.classList.remove('selected'); });
            el.classList.add('selected');
            selectedPayMethod = method;
        }

        function openPaymentModal() {
            selectedPayMethod = null;
            document.querySelectorAll('.pay-method-card').forEach(function(c) { c.classList.remove('selected'); });
            var name = document.getElementById('iq-name').value.trim();
            var email = document.getElementById('iq-email').value.trim();
            var platform = document.getElementById('iq-platform').value;
            var url = document.getElementById('iq-url').value.trim();

            if (!name || !email || !platform || !url) {
                alert('Please fill in all required fields.'); return;
            }

            // Set currency selector to detected currency
            var curSel = document.getElementById('pay-currency-select');
            if (curSel && iqDetectedCurrency) {
                var optExists = false;
                for (var i = 0; i < curSel.options.length; i++) {
                    if (curSel.options[i].value === iqDetectedCurrency) { optExists = true; break; }
                }
                if (optExists) curSel.value = iqDetectedCurrency;
            }
            payCurrency = curSel ? curSel.value : 'PKR';

            var hasSelection = false;
            var total = 0;
            var itemCount = 0;
            var cur = payCurrency;
            var sym = iqCurrencySymbols[cur] || '$';
            var itemsHtml = '';
            for (var s in iqServiceData) {
                var d = iqServiceData[s];
                if (d.selectedPkg) {
                    var pkrTotal = d.unitPrice * d.qty;
                    var converted = iqPkrRates[cur] ? pkrTotal / iqPkrRates[cur] : pkrTotal;
                    hasSelection = true;
                    total += converted;
                    itemCount++;
                    var unitConverted = iqPkrRates[cur] ? d.unitPrice / iqPkrRates[cur] : d.unitPrice;
                    itemsHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;' + (itemCount > 1 ? 'border-top:1px solid var(--border-subtle);' : '') + '">' +
                        '<div style="flex:1;min-width:0;">' +
                            '<div style="font-size:0.88rem;font-weight:700;color:var(--text-primary);margin-bottom:3px;">' + s + '</div>' +
                            '<div style="font-size:0.78rem;color:var(--text-muted);">' + d.qty.toLocaleString() + ' \u00d7 ' + sym + parseFloat(unitConverted).toFixed(2) + '/unit</div>' +
                        '</div>' +
                        '<div style="font-size:0.95rem;font-weight:800;color:var(--primary);white-space:nowrap;margin-left:16px;">' + sym + parseFloat(converted).toFixed(2) + '</div>' +
                    '</div>';
                }
            }
            if (!hasSelection) { alert('Please select a package for at least one service.'); return; }

            document.getElementById('pay-platform').textContent = platform;
            document.getElementById('pay-items').innerHTML = itemsHtml;
            document.getElementById('pay-total').textContent = sym + parseFloat(total).toFixed(2);

            document.getElementById('paymentOverlay').style.display = 'block';
            document.getElementById('paymentModal').style.display = 'block';
        }

        function closePaymentModal() {
            document.getElementById('paymentOverlay').style.display = 'none';
            document.getElementById('paymentModal').style.display = 'none';
            selectedPayMethod = null;
            document.querySelectorAll('.pay-method-card').forEach(function(c) { c.classList.remove('selected'); });
            var btn = document.getElementById('payConfirmBtn');
            if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-lock-fill"></i> Confirm & Pay'; }
        }

        async function confirmPayment() {
            if (!selectedPayMethod) {
                alert('Please select a payment method to continue.');
                return;
            }
            var btn = document.getElementById('payConfirmBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';

            var name = document.getElementById('iq-name').value.trim();
            var email = document.getElementById('iq-email').value.trim();
            var platform = document.getElementById('iq-platform').value;
            var url = document.getElementById('iq-url').value.trim();
            var description = document.getElementById('iq-description').value.trim();
            var payMethodLabel = selectedPayMethod.charAt(0).toUpperCase() + selectedPayMethod.slice(1);

            var selectedServices = [];
            for (var s in iqServiceData) {
                var d = iqServiceData[s];
                if (d.selectedPkg) {
                    selectedServices.push({ service: s, packageId: d.selectedPkg, quantity: d.qty });
                }
            }

            var allOk = true;
            var lastMsg = '';
            for (var i = 0; i < selectedServices.length; i++) {
                var item = selectedServices[i];
                try {
                    var resp = await fetch('/api/orders', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            fullName: name, email: email, platform: platform,
                            service: item.service, quantity: item.quantity, socialMediaUrl: url,
                            packageId: item.packageId, description: description || '',
                            currency: payCurrency
                        })
                    });
                    var data = await resp.json();
                    if (!resp.ok) { allOk = false; lastMsg = data.message || 'Failed'; break; }
                } catch(err) { allOk = false; lastMsg = 'Network error'; break; }
            }

            if (allOk) {
                closePaymentModal();
                document.getElementById('inquirySuccess').style.display = 'flex';
                document.getElementById('inquiryError').style.display = 'none';
                document.getElementById('inquiryForm').reset();
                document.querySelectorAll('#iq-svc-menu input[type=checkbox]').forEach(function(cb) { cb.checked = false; });
                updateSvcLabel();
                document.getElementById('iq-service-qty-area').innerHTML = '';
                document.getElementById('iq-services-area').innerHTML = '';
                document.getElementById('iq-order-summary').style.display = 'none';
                iqServiceData = {};
                updateServiceQtyVisibility();
                selectedPayMethod = null;
                document.querySelectorAll('.pay-method-card').forEach(function(c) { c.classList.remove('selected'); });
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-lock-fill"></i> Confirm & Pay';
                setTimeout(function() { document.getElementById('inquirySuccess').style.display = 'none'; }, 5000);
            } else {
                var errEl = document.getElementById('inquiryError');
                if (errEl) { errEl.style.display = 'block'; document.getElementById('inquiryErrorText').textContent = lastMsg; }
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-lock-fill"></i> Confirm & Pay';
            }
        }


        function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

        async function submitContact(e) {
            e.preventDefault();
            const name = document.getElementById('ct-name').value.trim();
            const email = document.getElementById('ct-email').value.trim();
            const subject = document.getElementById('ct-subject').value;
            const message = document.getElementById('ct-message').value.trim();
            if (!name || !email || !subject || !message) { alert('Please fill in all fields.'); return; }
            const btn = document.getElementById('contactSubmitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Sending...';
            try {
                const resp = await fetch('/api/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        fullName: name, email: email, platform: 'Contact',
                        service: subject, quantity: 1, socialMediaUrl: '',
                        packageId: null, description: 'Contact Form: ' + message
                    })
                });
                if (resp.ok) {
                    document.getElementById('contactSuccess').style.display = 'flex';
                    document.getElementById('contactForm').reset();
                    setTimeout(function() { document.getElementById('contactSuccess').style.display = 'none'; }, 5000);
                }
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send"></i> Send Message';
            } catch(err) {
                alert('Network error. Please try again.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send"></i> Send Message';
            }
        }
        document.addEventListener('DOMContentLoaded', () => {
            const themeToggleBtn = document.getElementById('themeToggle');
            if (themeToggleBtn) {
                const icon = themeToggleBtn.querySelector('i');
                if (document.body.classList.contains('light-mode')) {
                    icon.classList.replace('bi-moon-stars', 'bi-sun');
                }
                themeToggleBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    document.body.classList.toggle('light-mode');
                    document.documentElement.classList.toggle('light-mode');
                    if (document.body.classList.contains('light-mode')) {
                        localStorage.setItem('theme', 'light');
                        icon.classList.replace('bi-moon-stars', 'bi-sun');
                    } else {
                        localStorage.setItem('theme', 'dark');
                        icon.classList.replace('bi-sun', 'bi-moon-stars');
                    }
                });
            }
        });
    </script>
    <script>
        function toggleSidebar() {
            var sidebar = document.querySelector('.admin-sidebar');
            var overlay = document.getElementById('sidebarOverlay');
            if (sidebar && overlay) {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('open');
            }
        }
    </script>
    <script>
        function toggleNotifDropdown() {
            var dd = document.getElementById('notifDropdown');
            if (!dd) return;
            var isOpen = dd.classList.contains('show');
            dd.classList.toggle('show');
            if (!isOpen) {
                loadNotifications();
            }
        }

        document.addEventListener('click', function(e) {
            var wrapper = document.getElementById('notifBellWrapper');
            var dd = document.getElementById('notifDropdown');
            if (wrapper && dd && !wrapper.contains(e.target)) {
                dd.classList.remove('show');
            }
        });

        var notifTypeMap = {
            'NewOrder': { icon: 'bi-cart-check', css: 'notif-new-order' },
            'ProofReview': { icon: 'bi-shield-check', css: 'notif-proof-review' },
            'ProofApproved': { icon: 'bi-check-circle', css: 'notif-proof-approved' },
            'ProofRejected': { icon: 'bi-x-circle', css: 'notif-proof-rejected' },
            'TaskCompleted': { icon: 'bi-trophy', css: 'notif-task-completed' },
            'NewTaskAvailable': { icon: 'bi-lightning', css: 'notif-new-task' },
            'NewUserRegistered': { icon: 'bi-person-plus', css: 'notif-new-order' }
        };

        function timeAgo(dateStr) {
            var now = new Date();
            var date = new Date(dateStr);
            var seconds = Math.floor((now - date) / 1000);
            if (seconds < 60) return 'just now';
            var minutes = Math.floor(seconds / 60);
            if (minutes < 60) return minutes + 'm ago';
            var hours = Math.floor(minutes / 60);
            if (hours < 24) return hours + 'h ago';
            var days = Math.floor(hours / 24);
            if (days < 7) return days + 'd ago';
            return date.toLocaleDateString();
        }

        function renderNotifItem(n) {
            var typeInfo = notifTypeMap[n.type] || { icon: 'bi-bell', css: 'notif-new-order' };
            var unreadClass = n.isRead ? '' : ' unread';
            return '<div class="notif-item' + unreadClass + '" onclick="markNotifRead(' + n.id + ')">' +
                '<div class="notif-icon ' + typeInfo.css + '"><i class="bi ' + typeInfo.icon + '"></i></div>' +
                '<div class="notif-content">' +
                    '<div class="notif-title">' + escapeHtml(n.title) + '</div>' +
                    '<div class="notif-message">' + escapeHtml(n.message) + '</div>' +
                    '<div class="notif-time">' + timeAgo(n.createdAt) + '</div>' +
                '</div>' +
            '</div>';
        }

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function updateBadge(count) {
            var badge = document.getElementById('notifBadge');
            var bell = document.querySelector('.notification-bell-btn');
            if (!badge) return;
            if (count > 0) {
                badge.textContent = count > 99 ? '99+' : count;
                badge.style.display = 'block';
                if (bell) bell.classList.add('has-unread');
            } else {
                badge.style.display = 'none';
                if (bell) bell.classList.remove('has-unread');
            }
        }

        async function loadNotifications() {
            try {
                var resp = await fetch('/api/notifications?pageSize=15');
                console.log('[Notif] API status:', resp.status);
                if (!resp.ok) {
                    var errText = await resp.text();
                    console.warn('[Notif] API error:', resp.status, errText);
                    return;
                }
                var data = await resp.json();
                console.log('[Notif] data:', data);
                var list = document.getElementById('notifList');
                if (!list) return;

                updateBadge(data.unreadCount);

                if (!data.notifications || data.notifications.length === 0) {
                    list.innerHTML = '<div class="notif-empty"><i class="bi bi-bell-slash"></i><p>No notifications yet</p></div>';
                    return;
                }

                list.innerHTML = data.notifications.map(renderNotifItem).join('');
            } catch (e) {
                console.warn('Failed to load notifications', e);
            }
        }

        async function markNotifRead(id) {
            try {
                await fetch('/api/notifications/' + id + '/read', { method: 'PUT' });
                loadNotifications();
            } catch (e) {
                console.warn('Failed to mark notification read', e);
            }
        }

        async function markAllNotifsRead() {
            try {
                await fetch('/api/notifications/read-all', { method: 'PUT' });
                loadNotifications();
            } catch (e) {
                console.warn('Failed to mark all notifications read', e);
            }
        }

        (function initNotifications() {
            var headerRights = document.querySelectorAll('.admin-header-right');
            if (!headerRights.length) return;

            var bellHtml = '<div class="notification-bell-wrapper" id="notifBellWrapper">' +
                '<button class="notification-bell-btn" id="notifBellBtn" onclick="toggleNotifDropdown()">' +
                    '<i class="bi bi-bell"></i>' +
                    '<span class="notif-badge" id="notifBadge" style="display:none;">0</span>' +
                '</button>' +
                '<div class="notif-dropdown" id="notifDropdown">' +
                    '<div class="notif-dropdown-header">' +
                        '<h6>Notifications</h6>' +
                        '<button class="notif-mark-all" onclick="markAllNotifsRead()">Mark all read</button>' +
                    '</div>' +
                    '<div class="notif-dropdown-body" id="notifList">' +
                        '<div class="notif-empty"><i class="bi bi-bell-slash"></i><p>No notifications yet</p></div>' +
                    '</div>' +
                '</div>' +
            '</div>';

            headerRights.forEach(function(el) {
                el.insertAdjacentHTML('afterbegin', bellHtml);
            });

            loadNotifications();
            setInterval(loadNotifications, 30000);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
