@page "/forgot-password"
@model BoostingHub.frontend.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    ViewData["PageType"] = "auth";
    ViewData["BodyClass"] = "auth-page-body";
}

<div class="auth-page">
    <button class="theme-toggle-btn auth-theme-toggle" onclick="toggleTheme()" aria-label="Toggle Theme">
        <i class="bi bi-moon-stars dark-icon"></i>
        <i class="bi bi-sun light-icon"></i>
    </button>
    <div class="auth-container">
        <div class="auth-brand">
            <div class="auth-brand-content">
                <div class="auth-brand-icon"><i class="bi bi-shield-lock"></i></div>
                <h2>Forgot Password</h2>
                <p>Enter your email and we'll send you a reset link.</p>
                <div class="decor-circles">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
        <div class="auth-form">
            <div class="auth-form-inner">
                <h3 class="auth-form-title">Reset Password</h3>
                <p class="auth-form-subtitle">Enter your registered email</p>

                @if (Model.Success)
                {
                    <div class="auth-alert auth-alert-success">Password reset link sent! Check your email.</div>
                    <div class="text-center auth-muted-text mt-3">
                        <a href="/login" class="auth-link">Back to Login</a>
                    </div>
                }
                else
                {
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-danger" style="display:none;"></div>

                    <div class="input-group-custom">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <div class="input-icon-wrapper">
                            <input asp-for="Input.Email" class="form-control" type="email" placeholder="Your email address" />
                            <i class="input-icon bi bi-envelope"></i>
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-auth w-100">
                        <i class="bi bi-send"></i> Send Reset Link
                    </button>
                </form>

                <div class="auth-divider">or</div>

                <div class="text-center auth-muted-text">
                    <a href="/login" class="auth-link">Back to Login</a>
                </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
