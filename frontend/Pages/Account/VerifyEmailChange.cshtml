@page
@model BoostingHub.frontend.Pages.Account.VerifyEmailChangeModel
@{
    ViewData["Title"] = "Verify Email Change";
    ViewData["BodyClass"] = "auth-page d-flex align-items-center justify-content-center min-vh-100";
}

<div class="auth-page" style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px;">
    <button class="theme-toggle-btn auth-theme-toggle" onclick="toggleTheme()" aria-label="Toggle Theme">
        <i class="bi bi-moon-stars dark-icon"></i>
        <i class="bi bi-sun light-icon"></i>
    </button>
    <div class="auth-card glass-panel w-100 mx-auto" style="max-width: 450px;">
    <div class="auth-card-body p-4 p-md-5 text-center">
        <div class="auth-brand mb-4">
            <div class="auth-brand-icon mx-auto"><i class="bi bi-rocket-takeoff"></i></div>
            <h3 class="auth-brand-text">Boosting Hub</h3>
        </div>

        @if (Model.Verified)
        {
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            </div>
            <h4 class="mb-3">Email Updated!</h4>
            <p class="text-muted mb-4">@Model.SuccessMessage</p>
            <a href="/settings" class="btn btn-auth w-100">Return to Settings</a>
        }
        else if (Model.Error)
        {
            <div class="mb-4">
                <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
            </div>
            <h4 class="mb-3">Verification Failed</h4>
            <p class="text-muted mb-4">@Model.ErrorMessage</p>
            <a href="/settings" class="btn btn-outline-secondary w-100">Return to Settings</a>
        }
        else
        {
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Verifying your email change...</p>
        }
    </div>
</div>
