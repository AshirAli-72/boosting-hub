@page "/reset-password"
@model BoostingHub.frontend.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["PageType"] = "auth";
    ViewData["BodyClass"] = "auth-page-body";
}

<div class="auth-page">
    <button class="theme-toggle-btn auth-theme-toggle" onclick="toggleTheme()" aria-label="Toggle Theme">
        <i class="bi bi-moon-stars dark-icon"></i>
        <i class="bi bi-sun light-icon"></i>
    </button>
    <div class="auth-container">
        <div class="auth-brand">
            <div class="auth-brand-content">
                <div class="auth-brand-icon"><i class="bi bi-key"></i></div>
                <h2>Set New Password</h2>
                <p>Choose a strong password to secure your account.</p>
                <div class="decor-circles">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
        <div class="auth-form">
            <div class="auth-form-inner">
                <h3 class="auth-form-title">New Password</h3>
                <p class="auth-form-subtitle">Enter your new password</p>

                @if (Model.Success)
                {
                    <div class="auth-alert auth-alert-success">Password reset successfully. <a href="/login" class="auth-link">Sign in</a></div>
                }
                else
                {
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-danger" style="display:none;"></div>

                        <div class="input-group-custom">
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <div class="input-icon-wrapper">
                                <input asp-for="Input.Email" class="form-control" type="email" placeholder="Your email address" />
                                <i class="input-icon bi bi-envelope"></i>
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="input-group-custom">
                            <label asp-for="Input.Token" class="form-label">Reset Token</label>
                            <div class="input-icon-wrapper">
                                <input asp-for="Input.Token" class="form-control" placeholder="Paste your reset token" />
                                <i class="input-icon bi bi-key"></i>
                            </div>
                            <span asp-validation-for="Input.Token" class="text-danger"></span>
                        </div>

                        <div class="input-group-custom">
                            <label asp-for="Input.Password" class="form-label">New Password</label>
                            <div class="input-icon-wrapper">
                                <input asp-for="Input.Password" class="form-control" type="password" placeholder="Enter new password" />
                                <i class="input-icon bi bi-lock"></i>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="input-group-custom">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                            <div class="input-icon-wrapper">
                                <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="Repeat new password" />
                                <i class="input-icon bi bi-lock-fill"></i>
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-auth w-100">
                            <i class="bi bi-arrow-repeat"></i> Reset Password
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
