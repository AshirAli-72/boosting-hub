@page "/settings"
@model BoostingHub.frontend.Pages.Users.Settings.SecurityModel
@{
    ViewData["Title"] = "Settings";
    var isAdmin = HttpContext.Session.GetString("UserRole") == "Admin";
    ViewData["BodyClass"] = isAdmin ? "admin-page" : "user-dashboard-page";
}

        <div class="admin-header">
            <div class="d-flex align-items-center gap-3">
                <a href="@(isAdmin ? "/admin/settings" : "/user/settings")" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
                <h3 class="mb-0"><i class="bi bi-gear text-primary"></i> Settings</h3>
            </div>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> @(isAdmin ? "Admin" : Model.CurrentUserName)
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin-content">
            <ul class="nav nav-tabs custom-tabs mb-4" id="settingsTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(Model.ActiveTab == "configuration" ? "active" : "")" id="config-tab" data-bs-toggle="tab" data-bs-target="#config-tab-pane" type="button" role="tab" aria-controls="config-tab-pane" aria-selected="@(Model.ActiveTab == "configuration" ? "true" : "false")">
                        <i class="bi bi-person-lines-fill"></i> Configuration
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(Model.ActiveTab == "security" ? "active" : "")" id="security-tab" data-bs-toggle="tab" data-bs-target="#security-tab-pane" type="button" role="tab" aria-controls="security-tab-pane" aria-selected="@(Model.ActiveTab == "security" ? "true" : "false")">
                        <i class="bi bi-shield-lock"></i> Security
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="settingsTabContent">
                <div class="tab-pane fade @(Model.ActiveTab == "configuration" ? "show active" : "")" id="config-tab-pane" role="tabpanel" aria-labelledby="config-tab" tabindex="0">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="admin-card">
                                <div class="admin-card-header">
                                    <h5><i class="bi bi-person text-primary"></i> Personal Details</h5>
                                </div>
                                <div class="admin-card-body">
                                    <form method="post" asp-page-handler="UpdateProfile">
                                        <div class="input-group-custom mb-3">
                                            <label class="form-label">Email Address</label>
                                            <div class="input-icon-wrapper">
                                                <input type="email" id="newEmailInput" class="form-control" placeholder="Enter new email" value="@Model.CurrentUserEmail" onchange="handleEmailChange()" />
                                                <i class="input-icon bi bi-envelope"></i>
                                            </div>
                                            <div id="emailLinkMsg" class="mt-2" style="display:none;"></div>
                                            <div id="emailOtpMsg" class="mt-1"></div>
                                        </div>
                                        <div class="input-group-custom mb-3">
                                            <label asp-for="UpdateProfile.Name" class="form-label">Full Name</label>
                                            <div class="input-icon-wrapper">
                                                <input asp-for="UpdateProfile.Name" class="form-control" type="text" placeholder="Enter your name" />
                                                <i class="input-icon bi bi-person"></i>
                                            </div>
                                            <span asp-validation-for="UpdateProfile.Name" class="text-danger small"></span>
                                        </div>
                                        <div class="input-group-custom mb-3">
                                            <label asp-for="UpdateProfile.Phone" class="form-label">Phone Number</label>
                                            <div class="input-icon-wrapper">
                                                <input asp-for="UpdateProfile.Phone" class="form-control" type="tel" placeholder="Enter phone number" />
                                                <i class="input-icon bi bi-telephone"></i>
                                            </div>
                                            <span asp-validation-for="UpdateProfile.Phone" class="text-danger small"></span>
                                        </div>
                                        <button type="submit" class="btn btn-auth w-100" id="saveProfileBtn" onclick="return checkEmailBeforeSave(event)"><i class="bi bi-save"></i> Save Changes</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade @(Model.ActiveTab == "security" ? "show active" : "")" id="security-tab-pane" role="tabpanel" aria-labelledby="security-tab" tabindex="0">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="admin-card">
                                <div class="admin-card-header">
                                    <h5><i class="bi bi-key text-primary"></i> Change Password</h5>
                                </div>
                                <div class="admin-card-body">
                                    <form method="post" asp-page-handler="ChangePassword">
                                        <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-danger" style="display:none;"></div>
                                        <div class="input-group-custom mb-3">
                                            <label asp-for="ChangePassword.CurrentPassword" class="form-label">Current Password</label>
                                            <div class="input-icon-wrapper">
                                                <input asp-for="ChangePassword.CurrentPassword" class="form-control" type="password" placeholder="Enter current password" />
                                                <i class="input-icon bi bi-lock"></i>
                                            </div>
                                            <span asp-validation-for="ChangePassword.CurrentPassword" class="text-danger small"></span>
                                        </div>
                                        <div class="input-group-custom mb-3">
                                            <label asp-for="ChangePassword.NewPassword" class="form-label">New Password</label>
                                            <div class="input-icon-wrapper">
                                                <input asp-for="ChangePassword.NewPassword" class="form-control" type="password" placeholder="Enter new password" />
                                                <i class="input-icon bi bi-lock-fill"></i>
                                            </div>
                                            <span asp-validation-for="ChangePassword.NewPassword" class="text-danger small"></span>
                                        </div>
                                        <div class="input-group-custom mb-3">
                                            <label asp-for="ChangePassword.ConfirmNewPassword" class="form-label">Confirm New Password</label>
                                            <div class="input-icon-wrapper">
                                                <input asp-for="ChangePassword.ConfirmNewPassword" class="form-control" type="password" placeholder="Repeat new password" />
                                                <i class="input-icon bi bi-lock-fill"></i>
                                            </div>
                                            <span asp-validation-for="ChangePassword.ConfirmNewPassword" class="text-danger small"></span>
                                        </div>
                                        <button type="submit" class="btn btn-auth w-100"><i class="bi bi-arrow-repeat"></i> Change Password</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

@section Styles {
<style>
    .input-icon-wrapper { position: relative; }
    .input-icon-wrapper .input-icon {
        position: absolute; left: 16px; top: 50%;
        transform: translateY(-50%);
        color: #94A3B8; font-size: 1.1rem;
        z-index: 4; pointer-events: none; transition: color 0.2s;
    }
    .input-icon-wrapper .form-control {
        padding-left: 46px; height: 50px;
        border: 2px solid var(--border-muted, #E2E8F0); border-radius: 12px;
        font-size: 0.95rem; transition: all 0.25s;
        background: var(--bg-card, #fff);
        color: var(--text-primary, #1E293B);
    }
    .input-icon-wrapper .form-control:focus {
        border-color: #7C3AED;
        box-shadow: 0 0 0 4px rgba(124,58,237,0.10);
    }
    .input-icon-wrapper .form-control:focus ~ .input-icon { color: #7C3AED; }
    .input-group-custom .form-label {
        font-weight: 600; font-size: 0.875rem; color: var(--text-secondary, #475569); margin-bottom: 6px;
    }
    .btn-auth {
        height: 50px; border-radius: 12px;
        font-weight: 600; font-size: 1rem;
        background: linear-gradient(135deg, #7C3AED 0%, #0D9488 100%);
        border: none; color: #fff;
        transition: all 0.3s; position: relative; overflow: hidden;
    }
    .btn-auth:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(124,58,237,0.35);
        color: #fff;
    }
    .btn-auth:active { transform: translateY(0); }
    .input-validation-error {
        border-color: #EF4444 !important;
        box-shadow: 0 0 0 4px rgba(239,68,68,0.10) !important;
    }
    .input-validation-error ~ .input-icon { color: #EF4444 !important; }
    .field-validation-error {
        display: block; color: #EF4444; font-size: 0.8rem; margin-top: 4px;
    }
    .auth-alert {
        border-radius: 12px; padding: 14px 16px;
        border: none; font-size: 0.9rem; margin-bottom: 20px;
    }
    .auth-alert-success { background: rgba(16,185,129,0.12); color: var(--success, #166534); border-left: 4px solid #10B981; }
    .auth-alert-danger  { background: rgba(248,113,113,0.12); color: var(--danger, #991B1B); border-left: 4px solid #EF4444; }
</style>
}
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/site.js"></script>
    <script>
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <text>document.addEventListener('DOMContentLoaded', function() { showToast('@Model.SuccessMessage', 'success'); });</text>
        }

        (function() {
            var params = new URLSearchParams(window.location.search);
            if (params.get('email_verified') === '1') {
                document.addEventListener('DOMContentLoaded', function() { showToast('Email verified and updated successfully!', 'success'); });
                window.history.replaceState({}, '', '@(isAdmin ? "/admin/settings" : "/settings")');
            }
        })();

        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });

        var _originalEmail = '@Model.CurrentUserEmail';

        function handleEmailChange() {
            var current = document.getElementById('newEmailInput').value.trim();
            if (current !== _originalEmail) {
                document.getElementById('emailLinkMsg').style.display = 'none';
                document.getElementById('emailOtpMsg').innerHTML = '';
            }
        }

        function checkEmailBeforeSave(e) {
            var newEmail = document.getElementById('newEmailInput').value.trim();
            if (newEmail === _originalEmail) {
                return true;
            }
            e.preventDefault();
            sendEmailLink();
            return false;
        }

        function sendEmailLink() {
            var email = document.getElementById('newEmailInput').value.trim();
            if (!email || email.indexOf('@@') === -1) {
                showOtpMsg('Please enter a valid email address.', 'danger');
                return;
            }
            var saveBtn = document.getElementById('saveProfileBtn');
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Sending verification link…';
            fetch('/api/email-update/send-link', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' },
                body: JSON.stringify({ newEmail: email })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="bi bi-save"></i> Save Changes';
                if (data.success) {
                    var linkMsg = document.getElementById('emailLinkMsg');
                    linkMsg.style.display = 'block';
                    linkMsg.innerHTML = '<div class="alert alert-success py-2 px-3 mb-0 small"><i class="bi bi-envelope-check me-1"></i>' + data.message + '</div>';
                    document.getElementById('emailOtpMsg').innerHTML = '';
                } else {
                    showOtpMsg(data.message, 'danger');
                }
            })
            .catch(function() {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="bi bi-save"></i> Save Changes';
                showOtpMsg('Request failed. Please try again.', 'danger');
            });
        }

        function showOtpMsg(msg, type) {
            var el = document.getElementById('emailOtpMsg');
            el.innerHTML = '<div class="alert alert-' + type + ' py-2 px-3 mb-0 small">' + msg + '</div>';
        }

        var triggerTabList = [].slice.call(document.querySelectorAll('#settingsTab button'))
        triggerTabList.forEach(function (triggerEl) {
            var tabTrigger = new bootstrap.Tab(triggerEl)
            triggerEl.addEventListener('click', function (event) {
                event.preventDefault()
                tabTrigger.show()
            })
        })
    </script>
}
