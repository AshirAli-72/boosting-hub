@page "/dashboard"
@model BoostingHub.frontend.Pages.Users.DashboardModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    ViewData["BodyClass"] = "user-dashboard-page";

    string CurrencySymbol(string? currency) => (currency?.ToUpper() ?? "USD") switch {
        "PKR" => "₨",
        "EUR" => "€",
        "GBP" => "£",
        "INR" => "₹",
        "BDT" => "৳",
        _ => "$"
    };
    var sym = CurrencySymbol(Model.Dashboard.WalletCurrency);
}

        <div class="admin-header">
            <h3><i class="bi bi-speedometer2 text-primary"></i> Dashboard</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> @Model.Dashboard.UserName
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin-content">
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#7C3AED 0%,#5B21B6 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-list-task"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">Available</span>
                            <span class="stat-value" style="color:#fff;">@Model.Dashboard.TotalTasks</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#0D9488 0%,#0F766E 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-check-circle"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">Completed</span>
                            <span class="stat-value" style="color:#fff;">@Model.Dashboard.CompletedTasks</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#F59E0B 0%,#D97706 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-hourglass"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">In Progress</span>
                            <span class="stat-value" style="color:#fff;">@Model.Dashboard.PendingTasks</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-wallet2"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">Wallet Balance</span>
                            <span class="stat-value" style="color:#fff;">@sym@Model.Dashboard.WalletBalance.ToString("N2")</span>
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);font-size:0.7rem;">@Model.Dashboard.WalletStatus</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row g-4">
                <div class="col-md-7">
                    <div class="card shadow-sm border-0 chart-card chart-line">
                        <div class="card-body">
                            <h5 class="card-title fw-semibold mb-3"><i class="bi bi-graph-up text-primary"></i> Weekly Tasks</h5>
                            <canvas id="lineChart" style="width:100%!important;height:280px!important;"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="card shadow-sm border-0 chart-card chart-pie">
                        <div class="card-body">
                            <h5 class="card-title fw-semibold mb-3"><i class="bi bi-pie-chart text-primary"></i> Task Status</h5>
                            <canvas id="pieChart" style="width:100%!important;max-width:360px!important;height:300px!important;margin:0 auto;"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

@section Scripts {
    @if (TempData["Success"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof showToast === 'function') {
                    showToast('@TempData["Success"]', 'success');
                }
            });
        </script>
    }
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        var lineLabels = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.LineChart.Labels));
        var lineData   = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.LineChart.Data));
        var pieLabels  = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.PieChart.Labels));
        var pieData    = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.PieChart.Data));
        var pieColors  = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.PieChart.BackgroundColors));

        function isLight() { return document.body.classList.contains('light-mode'); }

        var lineChart = new Chart(document.getElementById('lineChart'), {
            type: 'line',
            data: {
                labels: lineLabels,
                datasets: [{
                    label: 'Tasks',
                    data: lineData,
                    borderColor: '#7C3AED',
                    backgroundColor: 'rgba(124,58,237,0.12)',
                    fill: true, tension: 0.4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: isLight() ? '#64748B' : 'rgba(241,245,249,0.4)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } },
                    y: { beginAtZero: true, ticks: { stepSize: 1, color: isLight() ? '#64748B' : 'rgba(241,245,249,0.4)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } }
                }
            }
        });

        var pieChart = new Chart(document.getElementById('pieChart'), {
            type: 'doughnut',
            data: { labels: pieLabels, datasets: [{ data: pieData, backgroundColor: pieColors }] },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { color: isLight() ? '#334155' : 'rgba(241,245,249,0.65)' } } }
            }
        });

        function updateChartTheme() {
            var light = isLight();
            lineChart.options.scales.x.ticks.color = light ? '#64748B' : 'rgba(241,245,249,0.4)';
            lineChart.options.scales.x.grid.color = light ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)';
            lineChart.options.scales.y.ticks.color = light ? '#64748B' : 'rgba(241,245,249,0.4)';
            lineChart.options.scales.y.grid.color = light ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)';
            lineChart.update();
            pieChart.options.plugins.legend.labels.color = light ? '#334155' : 'rgba(241,245,249,0.65)';
            pieChart.update();
        }

        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });

        var themeObserver = new MutationObserver(function() { updateChartTheme(); });
        themeObserver.observe(document.body, { attributes: true, attributeFilter: ['class'] });
    </script>
}

<!-- ── Success Toast ─────────────────────────────────────── -->
<div id="successToast" style="display:none;position:fixed;top:24px;right:24px;z-index:99999;background:#10B981;color:#fff;padding:14px 24px;border-radius:12px;box-shadow:0 12px 40px rgba(16,185,129,0.35);font-weight:600;font-size:0.92rem;align-items:center;gap:10px;">
    <i class="bi bi-check-circle-fill" style="font-size:1.1rem;"></i>
    <span id="toastMessage">Email updated successfully!</span>
</div>

<script>
    /* Show toast if redirected from email verification */
    (function() {
        var params = new URLSearchParams(window.location.search);
        if (params.get('email_verified') === '1') {
            var toast = document.getElementById('successToast');
            toast.style.display = 'flex';
            setTimeout(function() { toast.style.display = 'none'; }, 5000);
            window.history.replaceState({}, '', '/dashboard');
        }
    })();
</script>

