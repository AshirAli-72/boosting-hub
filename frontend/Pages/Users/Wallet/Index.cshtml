@page "/wallet"
@model BoostingHub.frontend.Pages.Users.Wallet.IndexModel
@using BoostingHub.backend.Common
@{
    ViewData["Title"] = "Wallet";
    ViewData["BodyClass"] = "user-dashboard-page";
}

        <div class="admin-header">
            <h3><i class="bi bi-wallet2 text-primary"></i> Wallet</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> User
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin-content">
            <div class="card shadow-sm border-0">
                <div class="card-header">
                    <h5 class="mb-0 fw-semibold"><i class="bi bi-wallet2 text-primary me-2"></i> Wallet Overview</h5>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle admin-table">
                                <thead class="admin-thead">
                                <tr>
                                    <th>Total Balance</th>
                                    <th>Currency</th>
                                    <th>Withdrawn</th>
                                    <th>Created At</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold fs-5" id="displayBalance">@Model.WalletData.Currency @Model.WalletData.TotalBalance.ToString("N2")</td>
                                    <td>
                                        <select class="form-select form-select-sm" style="width:auto;display:inline-block;" id="currencySelect" onchange="changeCurrency(this.value)">
                                            <option value="USD" selected="@(Model.WalletData.Currency == "USD")">$ USD</option>
                                            <option value="EUR" selected="@(Model.WalletData.Currency == "EUR")">€ EUR</option>
                                            <option value="GBP" selected="@(Model.WalletData.Currency == "GBP")">£ GBP</option>
                                            <option value="PKR" selected="@(Model.WalletData.Currency == "PKR")">₨ PKR</option>
                                            <option value="INR" selected="@(Model.WalletData.Currency == "INR")">₹ INR</option>
                                            <option value="BDT" selected="@(Model.WalletData.Currency == "BDT")">৳ BDT</option>
                                        </select>
                                    </td>
                                    <td id="displayWithdrawn">@Model.WalletData.Currency @Model.WalletData.Withdrawn.ToString("N2")</td>
                                    <td>@Model.WalletData.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (StatusHelper.WalletStatusToInt(Model.WalletData.Status) == StatusHelper.WalletActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#withdrawModal">
                                            <i class="bi bi-box-arrow-up"></i> Withdraw
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

<!-- Withdraw Modal -->
<div class="modal fade" id="withdrawModal" tabindex="-1" aria-labelledby="withdrawModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-semibold" id="withdrawModalLabel"><i class="bi bi-box-arrow-up text-warning"></i> Withdraw Funds</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                @if (Model.WalletData.TotalBalance <= 0)
                {
                    <div class="alert alert-warning mb-4 py-2 small"><i class="bi bi-exclamation-triangle"></i> Your balance is @Model.WalletData.Currency 0.00. Withdrawal is not possible.</div>
                }
                <form method="post" asp-page-handler="Withdraw">
                    <div class="mb-4">
                        <label class="form-label fw-medium text-secondary">Withdrawal Method</label>
                        <div class="p-3 rounded border bg-light">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-credit-card fs-4 text-primary me-3"></i>
                                <div>
                                    <strong>EasyPaisa</strong>
                                    @if (Model.DefaultAccount != null)
                                    {
                                        <div class="text-muted small">@Model.DefaultAccount.AccountTitle - @Model.DefaultAccount.MobileNumber</div>
                                    }
                                    else
                                    {
                                        <div class="text-danger small">No account found. <a href="/user/accounts">Add one</a>.</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="WithdrawAmount" class="form-label fw-medium text-secondary">Amount (<span id="modalCurrencySymbol">$</span>)</label>
                        <input asp-for="WithdrawAmount" class="form-control" type="number" step="0.01" min="0.01" placeholder="Enter amount" />
                        <span asp-validation-for="WithdrawAmount" class="text-danger small"></span>
                        <div class="text-muted small mt-1">Available balance: <span id="modalBalance">@Model.WalletData.Currency @Model.WalletData.TotalBalance.ToString("N2")</span></div>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-warning py-2" @(Model.DefaultAccount == null ? "disabled" : "")>
                            <i class="bi bi-send"></i> Submit Withdraw
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/site.js"></script>
    <script>
        var originalBalance = @Model.WalletData.TotalBalance;
        var originalWithdrawn = @Model.WalletData.Withdrawn;
        var originalCurrency = '@Model.WalletData.Currency';
        var currentDisplayCurrency = originalCurrency;

        var currencySymbols = { USD: '$', EUR: '€', GBP: '£', PKR: '₨', INR: '₹', BDT: '৳' };

        var exchangeRates = {
            USD: 1,
            EUR: 0.92,
            GBP: 0.79,
            PKR: 278.50,
            INR: 83.12,
            BDT: 109.85
        };

        function convertAmount(amount, fromCurrency, toCurrency) {
            var inUSD = amount / exchangeRates[fromCurrency];
            return inUSD * exchangeRates[toCurrency];
        }

        function updateDisplay(currency) {
            var convertedBalance = convertAmount(originalBalance, originalCurrency, currency);
            var convertedWithdrawn = convertAmount(originalWithdrawn, originalCurrency, currency);
            var symbol = currencySymbols[currency] || '$';

            document.getElementById('displayBalance').textContent = symbol + ' ' + convertedBalance.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            document.getElementById('displayWithdrawn').textContent = symbol + ' ' + convertedWithdrawn.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            document.getElementById('modalCurrencySymbol').textContent = symbol;
            document.getElementById('modalBalance').textContent = symbol + ' ' + convertedBalance.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            currentDisplayCurrency = currency;
        }

        async function changeCurrency(currency) {
            updateDisplay(currency);
            try {
                const resp = await fetch('/wallet?handler=ChangeCurrency&currency=' + encodeURIComponent(currency), {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }
                });
                const data = await resp.json();
                if (!resp.ok) {
                    showToast(data.message || 'Failed to update currency', 'danger');
                    document.getElementById('currencySelect').value = currentDisplayCurrency;
                }
            } catch (e) {
                showToast('Network error - display updated locally', 'warning');
            }
        }

        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });

        @if (TempData["Success"] != null)
        {
            <text>document.addEventListener('DOMContentLoaded', function() { showToast('@TempData["Success"]', 'success'); });</text>
        }
        @if (TempData["Error"] is string eMsg && !string.IsNullOrEmpty(eMsg))
        {
            <text>document.addEventListener('DOMContentLoaded', function() { showToast('@eMsg', 'danger'); });</text>
        }

        function showToast(message, type) {
            var toast = document.createElement('div');
            toast.className = 'toast align-items-center text-bg-' + type + ' border-0 show';
            toast.style.position = 'fixed';
            toast.style.bottom = '20px';
            toast.style.right = '20px';
            toast.style.zIndex = '9999';
            toast.style.minWidth = '280px';
            toast.style.borderRadius = '12px';
            toast.innerHTML = '<div class="d-flex"><div class="toast-body"><i class="bi bi-' + (type === 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill') + ' me-2"></i>' + message + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
            document.body.appendChild(toast);
            setTimeout(function() { toast.remove(); }, 5000);
        }
    </script>
}
