@page "/admin/activity-logs"
@model BoostingHub.frontend.Pages.Admin.ActivityLogs.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Activity Log";
    ViewData["BodyClass"] = "admin-page";

    string Initials(string? name) {
        var src = name ?? "?";
        var parts = src.Split(' ', '@').Where(p => !string.IsNullOrEmpty(p)).Take(2).ToArray();
        return parts.Length > 1
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : src[..Math.Min(2, src.Length)].ToUpper();
    }

    string EventBg(string? ev) => (ev ?? "") switch {
        "LoggedIn" or "Registered"   => "act-ev-logged-in",
        "LoggedOut"                  => "act-ev-logged-out",
        "TaskAccepted"              => "act-ev-task-accepted",
        "ProofSubmitted"            => "act-ev-proof-submitted",
        "ProofApproved"             => "act-ev-proof-approved",
        "ProofRejected"             => "act-ev-proof-rejected",
        "OrderSubmitted"            => "act-ev-order-submitted",
        "OrderApproved"             => "act-ev-order-approved",
        "OrderRejected"             => "act-ev-order-rejected",
        "WalletCredited"            => "act-ev-wallet-credited",
        "WalletWithdrawn"           => "act-ev-wallet-withdrawn",
        "PasswordChanged"           => "act-ev-password-changed",
        _                           => "act-ev-default"
    };

    string EventText(string? ev) => (ev ?? "") switch {
        "LoggedIn" or "Registered"   => "act-ev-logged-in",
        "LoggedOut"                  => "act-ev-logged-out",
        "TaskAccepted"              => "act-ev-task-accepted",
        "ProofSubmitted"            => "act-ev-proof-submitted",
        "ProofApproved"             => "act-ev-proof-approved",
        "ProofRejected"             => "act-ev-proof-rejected",
        "OrderSubmitted"            => "act-ev-order-submitted",
        "OrderApproved"             => "act-ev-order-approved",
        "OrderRejected"             => "act-ev-order-rejected",
        "WalletCredited"            => "act-ev-wallet-credited",
        "WalletWithdrawn"           => "act-ev-wallet-withdrawn",
        "PasswordChanged"           => "act-ev-password-changed",
        _                           => "act-ev-default"
    };

    string FriendlyEvent(string? ev) => (ev ?? "") switch {
        "LoggedIn" => "Logged In",
        "LoggedOut" => "Logged Out",
        "Registered" => "Registered",
        "TaskAccepted" => "Accepted Task",
        "ProofSubmitted" => "Submitted Proof",
        "ProofApproved" => "Approved Proof",
        "ProofRejected" => "Rejected Proof",
        "WalletCredited" => "Wallet Credited",
        "WalletWithdrawn" => "Wallet Withdrawn",
        "PasswordChanged" => "Changed Password",
        "ProfileUpdated" => "Updated Profile",
        "OrderApproved" => "Approved Order",
        "OrderRejected" => "Rejected Order",
        _ => ev?.Replace("_", " ") ?? "Unknown"
    };

    string BuildUrl(int pg) {
        var qs = new System.Collections.Specialized.NameValueCollection();
        if (!string.IsNullOrEmpty(Model.Filter.Search))   qs["search"]   = Model.Filter.Search;
        if (!string.IsNullOrEmpty(Model.Filter.Event))    qs["event"]    = Model.Filter.Event;
        if (!string.IsNullOrEmpty(Model.Filter.Role))     qs["role"]     = Model.Filter.Role;
        if (Model.Filter.DateFrom.HasValue)               qs["dateFrom"] = Model.Filter.DateFrom.Value.ToString("yyyy-MM-dd");
        if (Model.Filter.DateTo.HasValue)                 qs["dateTo"]   = Model.Filter.DateTo.Value.ToString("yyyy-MM-dd");
        qs["page"] = pg.ToString();
        var parts = qs.AllKeys.Where(k => k != null).Select(k => $"{k}={Uri.EscapeDataString(qs[k]!)}");
        return "/admin/activity-logs?" + string.Join("&", parts);
    }
}

<div class="admin-header">
    <h3><i class="bi bi-clock-history text-primary"></i> Activity Log</h3>
    <div class="admin-header-right">
        <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
            <i class="bi bi-moon-stars fs-5"></i>
        </button>
        <div class="user-profile-dropdown" id="profileDropdown">
            <span class="admin-user-badge" onclick="toggleProfileMenu()">
                <i class="bi bi-person-circle"></i> Admin
                <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
            </span>
            <div class="profile-menu" id="profileMenu" style="display:none;">
                <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </div>
</div>

<div class="admin-content">

    <!-- ── Stats Row ── -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#6366F1 0%,#4F46E5 100%);border:none;">
                <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-calendar-check"></i></div>
                <div class="stat-info">
                    <span class="stat-label" style="color:rgba(255,255,255,0.75);">Today</span>
                    <span class="stat-value" style="color:#fff;">@Model.Stats.TotalToday</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);border:none;">
                <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-calendar-week"></i></div>
                <div class="stat-info">
                    <span class="stat-label" style="color:rgba(255,255,255,0.75);">This Week</span>
                    <span class="stat-value" style="color:#fff;">@Model.Stats.TotalThisWeek</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#10B981 0%,#059669 100%);border:none;">
                <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-calendar-month"></i></div>
                <div class="stat-info">
                    <span class="stat-label" style="color:rgba(255,255,255,0.75);">This Month</span>
                    <span class="stat-value" style="color:#fff;">@Model.Stats.TotalThisMonth</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#F59E0B 0%,#D97706 100%);border:none;">
                <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-person-fill"></i></div>
                <div class="stat-info">
                    <span class="stat-label" style="color:rgba(255,255,255,0.75);">Most Active</span>
                    <span class="stat-value" style="color:#fff;font-size:1rem;">@Model.Stats.MostActiveUser</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Charts ── -->
    <div class="row g-4 mb-4">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 chart-card chart-line">
                <div class="card-body">
                    <h5 class="card-title fw-semibold mb-3"><i class="bi bi-graph-up text-primary"></i> Activity Over Time</h5>
                    <canvas id="activityLineChart" style="width:100%!important;height:280px!important;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card shadow-sm border-0 chart-card chart-pie">
                <div class="card-body">
                    <h5 class="card-title fw-semibold mb-3"><i class="bi bi-pie-chart text-primary"></i> By Event Type</h5>
                    <canvas id="activityPieChart" style="width:100%!important;max-width:360px!important;height:300px!important;margin:0 auto;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Activity Feed ── -->
    <div class="activity-log-card mt-2">
        <div class="activity-log-header">
            <h5 class="activity-log-title">
                <i class="bi bi-activity"></i>
                User Activity
                <span class="activity-log-badge">@Model.ActivityLogs.TotalCount total</span>
            </h5>
            <div style="font-size:0.8rem;color:var(--text-muted);">
                Showing @((Model.ActivityLogs.Page - 1) * Model.ActivityLogs.PageSize + 1)–@(Math.Min(Model.ActivityLogs.Page * Model.ActivityLogs.PageSize, Model.ActivityLogs.TotalCount)) of @Model.ActivityLogs.TotalCount
            </div>
        </div>

        <!-- Filter Bar -->
        <form method="get" action="/admin/activity-logs" class="activity-filter-bar">
            <input type="text" name="search" placeholder="Search user, email, description…"
                   value="@Model.Filter.Search" autocomplete="off" />

            <div class="activity-filter-sep"></div>

            <select name="event">
                <option value="">All Events</option>
                @foreach (var ev in new[] { "LoggedIn", "LoggedOut", "Registered", "TaskAccepted", "ProofSubmitted", "ProofApproved", "ProofRejected", "WalletCredited", "WalletWithdrawn", "PasswordChanged", "ProfileUpdated" })
                {
                    <option value="@ev" selected="@(Model.Filter.Event == ev ? "selected" : null)">@ev</option>
                }
            </select>

            <select name="role">
                <option value="">All Roles</option>
                <option value="Admin" selected="@(Model.Filter.Role == "Admin" ? "selected" : null)">Admin</option>
                <option value="User"  selected="@(Model.Filter.Role == "User"  ? "selected" : null)">User</option>
            </select>

            <input type="date" name="dateFrom" value="@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))" title="From date" />
            <input type="date" name="dateTo"   value="@(Model.Filter.DateTo?.ToString("yyyy-MM-dd"))"   title="To date" />

            <button type="submit" class="btn-filter-apply">
                <i class="bi bi-funnel"></i> Filter
            </button>
            <a href="/admin/activity-logs" class="btn-filter-reset">
                <i class="bi bi-x-circle"></i> Reset
            </a>

            <input type="hidden" name="page" value="1" />
        </form>

        <!-- Data Table -->
        @if (!Model.ActivityLogs.Items.Any())
        {
            <div class="activity-empty">
                <div class="activity-empty-icon"><i class="bi bi-inbox"></i></div>
                <h5>No activity logs found</h5>
                <p>Try adjusting your filters or check back later.</p>
            </div>
        }
        else
        {
            <div class="act-table-wrap">
                <table class="act-table">
                    <thead>
                        <tr>
                            <th class="act-th-num">#</th>
                            <th class="act-th-user">User</th>
                            <th class="act-th-event">Event</th>
                            <th class="act-th-desc">Description</th>
                            <th class="act-th-ip">IP</th>
                            <th class="act-th-time">Date & Time</th>
                        </tr>
                    </thead>
                    <tbody>
                    @{ var rowNum = (Model.ActivityLogs.Page - 1) * Model.ActivityLogs.PageSize; }
                    @foreach (var log in Model.ActivityLogs.Items)
                    {
                        rowNum++;
                        var roleCls = log.UserRole?.ToLower() == "admin" ? "act-role-admin" : "act-role-user";
                        var eventIcon = (log.Event ?? "") switch {
                            "LoggedIn" or "LoggedOut" => "bi-box-arrow-in-right",
                            "Registered"             => "bi-person-plus",
                            "TaskAccepted"           => "bi-clipboard-check",
                            "ProofSubmitted"         => "bi-cloud-upload",
                            "ProofApproved"          => "bi-check-circle-fill",
                            "ProofRejected"          => "bi-x-circle-fill",
                            "OrderSubmitted"         => "bi-receipt",
                            "OrderApproved"          => "bi-check2-circle",
                            "OrderRejected"          => "bi-x-octagon",
                            "WalletCredited"         => "bi-wallet2",
                            "WalletWithdrawn"        => "bi-cash-stack",
                            "PasswordChanged"        => "bi-shield-lock",
                            "ProfileUpdated"         => "bi-person-gear",
                            _                        => "bi-dot"
                        };
                        <tr>
                            <td class="act-td-num">@rowNum</td>
                            <td class="act-td-user">
                                <div class="act-user-cell">
                                    <div class="act-avatar @EventBg(log.Event) @EventText(log.Event)">
                                        @Initials(log.UserName)
                                    </div>
                                    <div class="act-user-info">
                                        <span class="act-user-name">@(log.UserName ?? "—")</span>
                                        <span class="act-role-chip @roleCls">@log.UserRole</span>
                                    </div>
                                </div>
                            </td>
                            <td class="act-td-event">
                                <span class="act-event-badge @EventBg(log.Event) @EventText(log.Event)">
                                    <i class="bi @eventIcon"></i>
                                    @FriendlyEvent(log.Event)
                                </span>
                            </td>
                            <td class="act-td-desc" title="@log.Description">
                                @if (!string.IsNullOrWhiteSpace(log.Description))
                                {
                                    @log.Description
                                }
                                else
                                {
                                    <span class="act-desc-empty">—</span>
                                }
                            </td>
                            <td class="act-td-ip">
                                @if (!string.IsNullOrEmpty(log.IpAddress))
                                {
                                    <code>@log.IpAddress</code>
                                }
                                else
                                {
                                    <span class="act-desc-empty">—</span>
                                }
                            </td>
                            <td class="act-td-time">
                                <span class="act-time-date">@log.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                                <span class="act-time-clock">@log.CreatedAt.ToLocalTime().ToString("h:mm tt")</span>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }

        <!-- Pagination -->
        @if (Model.ActivityLogs.TotalPages > 1)
        {
            <div class="activity-pagination">
                <span class="activity-pagination-info">
                    Page @Model.ActivityLogs.Page of @Model.ActivityLogs.TotalPages
                </span>
                <div class="activity-pagination-controls">
                    @if (Model.ActivityLogs.HasPrevious)
                    {
                        <a href="@BuildUrl(1)" class="page-btn" title="First"><i class="bi bi-chevron-double-left"></i></a>
                        <a href="@BuildUrl(Model.ActivityLogs.Page - 1)" class="page-btn"><i class="bi bi-chevron-left"></i></a>
                    }
                    else
                    {
                        <span class="page-btn disabled"><i class="bi bi-chevron-double-left"></i></span>
                        <span class="page-btn disabled"><i class="bi bi-chevron-left"></i></span>
                    }

                    @{
                        var startPage = Math.Max(1, Model.ActivityLogs.Page - 2);
                        var endPage   = Math.Min(Model.ActivityLogs.TotalPages, startPage + 4);
                    }
                    @for (int p = startPage; p <= endPage; p++)
                    {
                        if (p == Model.ActivityLogs.Page)
                        {
                            <span class="page-btn active">@p</span>
                        }
                        else
                        {
                            <a href="@BuildUrl(p)" class="page-btn">@p</a>
                        }
                    }

                    @if (Model.ActivityLogs.HasNext)
                    {
                        <a href="@BuildUrl(Model.ActivityLogs.Page + 1)" class="page-btn"><i class="bi bi-chevron-right"></i></a>
                        <a href="@BuildUrl(Model.ActivityLogs.TotalPages)" class="page-btn" title="Last"><i class="bi bi-chevron-double-right"></i></a>
                    }
                    else
                    {
                        <span class="page-btn disabled"><i class="bi bi-chevron-right"></i></span>
                        <span class="page-btn disabled"><i class="bi bi-chevron-double-right"></i></span>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        var lineLabels = @Html.Raw(JsonSerializer.Serialize(Model.Stats.ByDay.Select(d => d.Day).ToList()));
        var lineData   = @Html.Raw(JsonSerializer.Serialize(Model.Stats.ByDay.Select(d => d.Count).ToList()));
        var pieLabels  = @Html.Raw(JsonSerializer.Serialize(Model.Stats.ByEvent.Select(e => e.Event).ToList()));
        var pieData    = @Html.Raw(JsonSerializer.Serialize(Model.Stats.ByEvent.Select(e => e.Count).ToList()));
        var pieColors  = new ['#6366F1','#3B82F6','#10B981','#F59E0B','#EC4899','#8B5CF6','#14B8A6','#EF4444'];

        function isLight() { return document.body.classList.contains('light-mode'); }

        var activityLineChart = new Chart(document.getElementById('activityLineChart'), {
            type: 'line',
            data: {
                labels: lineLabels,
                datasets: [{
                    label: 'Activities',
                    data: lineData,
                    borderColor: '#6366F1',
                    backgroundColor: 'rgba(99,102,241,0.12)',
                    fill: true, tension: 0.4,
                    pointBackgroundColor: '#6366F1',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 5
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: isLight() ? '#71717A' : 'rgba(250,250,250,0.45)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } },
                    y: { beginAtZero: true, ticks: { stepSize: 1, color: isLight() ? '#71717A' : 'rgba(250,250,250,0.45)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } }
                }
            }
        });

        var activityPieChart = new Chart(document.getElementById('activityPieChart'), {
            type: 'doughnut',
            data: { labels: pieLabels, datasets: [{ data: pieData, backgroundColor: pieColors, borderWidth: 0 }] },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { color: isLight() ? '#3F3F46' : 'rgba(250,250,250,0.70)', padding: 16 } } },
                cutout: '65%'
            }
        });
    </script>
}
