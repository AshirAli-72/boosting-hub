@page "/admin/in-progress"
@model BoostingHub.frontend.Pages.Admin.Tasks.InProgressModel
@{
    ViewData["Title"] = "In Progress Tasks";
    ViewData["BodyClass"] = "admin-page";
}

        <div class="admin-header">
            <h3><i class="bi bi-hourglass-split text-primary"></i> In Progress Tasks</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> Admin
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin-content">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    @if (Model.Tasks.Count == 0)
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-check2-all fs-1"></i>
                            <p class="mt-2">All tasks are completed!</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle admin-table">
                                <thead class="admin-thead">
                                    <tr>
                                        <th>ID</th>
                                        <th>Platform</th>
                                        <th>Service</th>
                                        <th>Remaining Slots</th>
                                        <th>Completed</th>
                                        <th>Reward</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.Tasks)
                                    {
                                        <tr>
                                            <td>#@task.Id</td>
                                            <td>@task.Platform</td>
                                            <td>@task.Service</td>
                                            <td>@(task.Quantity - task.CompletedCount)</td>
                                            <td>@task.CompletedCount</td>
                                            <td>@Model.GetCurrencySymbol(task.Currency)@task.Reward.ToString("N2")</td>
                                            <td>@task.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (Model.TotalPages > 1)
                        {
                            <nav class="mt-4">
                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                    <span class="text-muted small">Showing @(((Model.CurrentPage - 1) * 10) + 1)-@(Math.Min(Model.CurrentPage * 10, Model.TotalCount)) of @Model.TotalCount tasks</span>
                                    <ul class="pagination mb-0">
                                        <li class="page-item @(!Model.HasPrevious ? "disabled" : "")">
                                            <a class="page-link" href="?page=@(Model.CurrentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                                        </li>
                                        @for (int i = 1; i <= Model.TotalPages; i++)
                                        {
                                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                                <a class="page-link" href="?page=@i">@i</a>
                                            </li>
                                        }
                                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                                            <a class="page-link" href="?page=@(Model.CurrentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                                        </li>
                                    </ul>
                                </div>
                            </nav>
                        }
                    }
                </div>
            </div>
        </div>

@section Scripts {
    <script>
        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });
    </script>
}
