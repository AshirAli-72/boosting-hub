@page "/admin/settings"
@model BoostingHub.frontend.Pages.Admin.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
    ViewData["BodyClass"] = "admin-page";
}

        <div class="admin-header">
            <h3><i class="bi bi-gear text-primary"></i> Settings</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> Admin
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin-content">
            <div class="row g-4">
                <div class="col-md-4">
                    <a href="/admin/roles" class="text-decoration-none">
                        <div class="card shadow-sm border-0 h-100" style="cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                            <div class="card-body text-center py-5">
                                <div style="font-size:3rem;color:#7C3AED;margin-bottom:16px;"><i class="bi bi-shield-lock"></i></div>
                                <h5 class="fw-semibold">Roles & Permissions</h5>
                                <p class="text-muted mb-0">Create and manage roles, assign permissions to control access</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="/admin/users" class="text-decoration-none">
                        <div class="card shadow-sm border-0 h-100" style="cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                            <div class="card-body text-center py-5">
                                <div style="font-size:3rem;color:#0D9488;margin-bottom:16px;"><i class="bi bi-people"></i></div>
                                <h5 class="fw-semibold">User Management</h5>
                                <p class="text-muted mb-0">Create users, assign roles, and manage user accounts</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="/settings" class="text-decoration-none">
                        <div class="card shadow-sm border-0 h-100" style="cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                            <div class="card-body text-center py-5">
                                <div style="font-size:3rem;color:#F59E0B;margin-bottom:16px;"><i class="bi bi-person-gear"></i></div>
                                <h5 class="fw-semibold">Account Settings</h5>
                                <p class="text-muted mb-0">Security, password, and profile preferences</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

@section Scripts {
    <script>
        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });
    </script>
}
