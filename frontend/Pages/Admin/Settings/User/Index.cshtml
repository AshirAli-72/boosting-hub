@page "/admin/users"
@model BoostingHub.frontend.Pages.Admin.Settings.User.IndexModel
@{
    ViewData["Title"] = "User Management";
    ViewData["BodyClass"] = "admin-page";
}

        <div class="admin-header">
            <h3 class="mb-0"><i class="bi bi-people text-primary"></i> User Management</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> Admin
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin-content">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success alert-dismissible fade show">@Model.SuccessMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show">@Model.ErrorMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-people text-primary me-2"></i>Users List</span>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createUserModal">
                            <i class="bi bi-person-plus"></i> Create New User
                        </button>
                        <a href="/admin/settings" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="admin-table mb-0 align-middle">
                            <thead class="admin-thead">
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Roles</th>
                                    <th>Verified</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td class="fw-medium">@user.Name</td>
                                        <td class="text-muted">@user.Email</td>
                                        <td>
                                            @if (user.Roles.Any())
                                            {
                                                @foreach (var r in user.Roles)
                                                {
                                                    <span class="badge bg-secondary me-1">@r.RoleTitle</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="badge bg-info text-dark">No Role</span>
                                            }
                                        </td>
                                        <td>
                                            @if (user.EmailVerifiedAt != null)
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-2">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-2">No</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a href="/admin/users?edit=@user.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Roles</a>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.Users.Any())
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-5">No users found</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Create User Modal -->
            <div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header border-bottom-0">
                            <h5 class="modal-title fw-semibold" id="createUserModalLabel"><i class="bi bi-person-plus text-primary"></i> Create New User</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-4">
                            <form method="post" asp-page-handler="Create">
                                <div class="mb-3">
                                    <label class="form-label fw-medium text-secondary">Full Name</label>
                                    <input asp-for="CreateInput.Name" class="form-control" placeholder="Enter full name" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium text-secondary">Email</label>
                                    <input asp-for="CreateInput.Email" class="form-control" type="email" placeholder="name@example.com" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium text-secondary">Phone</label>
                                    <input asp-for="CreateInput.Phone" class="form-control" placeholder="Enter phone number" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium text-secondary">Password</label>
                                    <input asp-for="CreateInput.Password" class="form-control" type="password" placeholder="Enter password" required />
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-medium text-secondary">Assign Roles</label>
                                    <div class="roles-list p-3 rounded border custom-modal-bg" style="max-height:200px;overflow-y:auto;">
                                        @if (Model.AllRoles.Any())
                                        {
                                            @foreach (var role in Model.AllRoles)
                                            {
                                                <div class="form-check mb-2">
                                                    <input type="checkbox" class="form-check-input" name="CreateInput.RoleIds" value="@role.Id" id="create_role_@role.Id" />
                                                    <label class="form-check-label" for="create_role_@role.Id">@role.RoleTitle</label>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <p class="text-muted mb-0 small">No roles created yet. <a href="/admin/roles">Create roles first</a>.</p>
                                        }
                                    </div>
                                </div>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary py-2"><i class="bi bi-plus-circle"></i> Create User</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.IsEditing)
            {
                var editUser = Model.Users.FirstOrDefault(u => u.Id == Model.EditUserId);
                if (editUser != null)
                {
                    <div class="modal fade show" id="editUserModal" tabindex="-1" style="display:block; background:rgba(0,0,0,0.5);" aria-modal="true" role="dialog">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg">
                                <div class="modal-header border-bottom-0">
                                    <h5 class="modal-title fw-semibold"><i class="bi bi-pencil text-primary"></i> Edit Roles: @editUser.Name</h5>
                                    <a href="/admin/users" class="btn-close" aria-label="Close"></a>
                                </div>
                                <div class="modal-body p-4">
                                    <form method="post" asp-page-handler="UpdateRoles" asp-route-userId="@Model.EditUserId">
                                        <div class="mb-4">
                                            <label class="form-label fw-medium text-secondary">Roles</label>
                                            <div class="roles-list p-3 rounded border custom-modal-bg" style="max-height:250px;overflow-y:auto;">
                                                @foreach (var role in Model.AllRoles)
                                                {
                                                    <div class="form-check mb-2">
                                                        <input type="checkbox" class="form-check-input" name="EditRoleIds" value="@role.Id" id="edit_role_@role.Id" checked="@Model.EditRoleIds.Contains(role.Id)" />
                                                        <label class="form-check-label" for="edit_role_@role.Id">@role.RoleTitle</label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="/admin/users" class="btn btn-outline-secondary">Cancel</a>
                                            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save"></i> Save Roles</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

@section Scripts {
    <script>
        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });
    </script>
}
