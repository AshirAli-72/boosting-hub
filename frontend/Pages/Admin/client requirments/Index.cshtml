@page "/admin/inquiries"
@model BoostingHub.frontend.Pages.Admin.Inquiries.IndexModel
@using BoostingHub.backend.Common
@{
    ViewData["Title"] = "Clients";
    ViewData["BodyClass"] = "admin-page";
}

        <div class="admin-header">
            <h3><i class="bi bi-inbox text-primary"></i> Clients</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> Admin
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin-content">
            <div class="admin-card mb-4 border-0 shadow-sm" style="background:var(--bg-card); border-radius:16px;">
                <div class="admin-card-header d-flex justify-content-between align-items-center" style="padding:20px 24px; border-bottom:1px solid var(--border-subtle);">
                    <h5 class="m-0"><i class="bi bi-list-check text-primary me-2"></i> All Orders</h5>
                        <span class="badge" style="background:var(--primary); color:#fff; font-size:0.85rem; padding:6px 12px; border-radius:20px;">@Model.Orders.Count Total</span>
                </div>
                <div class="admin-card-body p-0">
                    <div class="table-responsive">
                        <table class="table admin-table mb-0 align-middle">
                            <thead class="admin-thead">
                                <tr>
                                    <th>ID</th>
                                    <th>Name / Email</th>
                                    <th>Platform(s)</th>
                                    <th>Service(s)</th>
                                    <th>Quantity</th>
                                    <th>Amount</th>
                                    <th>URL</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Orders.Any())
                                {
                                    foreach (var item in Model.Orders)
                                    {
                                        <tr>
                                            <td class="fw-semibold">#@item.Id</td>
                                            <td>
                                                <div class="fw-semibold">@(item.FullName ?? "—")</div>
                                                <div class="admin-td-small opacity-75">@(item.Email ?? "—")</div>
                                            </td>
                                            <td>
                                                @foreach (var p in item.Platform.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                                {
                                                    <span class="admin-badge me-1" style="background:rgba(124,58,237,0.15); color:var(--primary-light);">@p</span>
                                                }
                                            </td>
                                            <td>
                                                @foreach (var s in item.Service.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                                {
                                                    <span class="admin-badge me-1" style="background:rgba(13,148,136,0.15); color:#0D9488;">@s</span>
                                                }
                                            </td>
                                            <td><span class="fw-semibold">@item.Quantity</span></td>
                                            <td><span class="fw-bold text-success">@item.Budget.ToString("N2")</span></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.SocialMediaUrl))
                                                {
                                                    <a href="@item.SocialMediaUrl" target="_blank" class="text-truncate d-inline-block text-primary" style="max-width:120px; text-decoration:none;" title="@item.SocialMediaUrl">
                                                        <i class="bi bi-link-45deg"></i> Link
                                                    </a>
                                                }
                                                else { <span class="opacity-50">—</span> }
                                            </td>
                                            <td>
                                                    @if (item.Status == StatusHelper.OrderPending)
                                                {
                                                    <span class="inquiry-status-badge inquiry-status-pending">Pending</span>
                                                }
                                                else if (item.Status == StatusHelper.OrderApproved)
                                                {
                                                    <span class="inquiry-status-badge inquiry-status-approved">Paid</span>
                                                }
                                                else
                                                {
                                                    <span class="inquiry-status-badge inquiry-status-rejected">@StatusHelper.OrderStatusToString(item.Status)</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="admin-td-small">@item.CreatedAt.ToString("MMM dd, yyyy")</span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex gap-2 justify-content-end align-items-center flex-wrap">
                                                    <button class="btn btn-sm btn-outline-primary" type="button"
                                                            data-bs-toggle="collapse" data-bs-target="#collapse-@item.Id"
                                                            style="border-radius:8px; font-weight:500; padding:4px 10px;">
                                                        <i class="bi bi-chevron-down"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr class="collapse" id="collapse-@item.Id" style="border-bottom:1px solid var(--border-subtle);">
                                            <td colspan="10" style="background-color: rgba(0,0,0,0.1); padding: 20px 24px; border-top:none;">
                                                <div class="row g-3">
                                                    @if (!string.IsNullOrEmpty(item.Description))
                                                    {
                                                        <div class="col-md-6">
                                                            <div style="background:var(--bg-elevated); padding:16px; border-radius:12px; border:1px solid var(--border-muted);">
                                                                <h6 class="stat-label-upper mb-2"><i class="bi bi-chat-left-text text-primary me-2"></i> Description / Notes</h6>
                                                                <p class="mb-0 text-secondary" style="font-size:0.9rem; line-height:1.5;">@item.Description</p>
                                                            </div>
                                                        </div>
                                                    }
                                                    <div class="col-md-6">
                                                        <div style="background:var(--bg-elevated); padding:16px; border-radius:12px; border:1px solid var(--border-muted);">
                                                            <h6 class="stat-label-upper mb-2"><i class="bi bi-info-circle text-warning me-2"></i> Order Summary</h6>
                                                            <ul class="mb-0 list-unstyled" style="font-size:0.9rem;">
                                                                <li><strong>Platforms:</strong> @item.Platform</li>
                                                                <li><strong>Services:</strong> @item.Service</li>
                                                                <li><strong>Quantity:</strong> @item.Quantity</li>
                                                                <li><strong>Description:</strong> @item.Description</li>
                                                                <li><strong>Amount:</strong> @item.Budget.ToString("N2")</li>
                                                                <li><strong>Status:</strong> @StatusHelper.OrderStatusToString(item.Status)</li>
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="10" class="text-center py-5 text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                            <span style="font-size:1.1rem; font-weight:500;">No client orders found.</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

@section Scripts {
    <script src="~/js/site.js"></script>
    <script>
        function toggleProfileMenu() {
            var menu = document.getElementById('profileMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var pd = document.getElementById('profileDropdown');
            if (pd && !pd.contains(e.target)) {
                var m = document.getElementById('profileMenu');
                if (m) m.style.display = 'none';
            }
        });
    </script>
}
