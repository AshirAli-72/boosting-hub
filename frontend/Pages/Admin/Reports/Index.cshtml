                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Tasks Report Hub</h5>
                            <small style="color:var(--text-muted);">Task completion and proof analytics</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="printHub('tasksHub')">
                            <i class="bi bi-printer"></i> Print
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="closeHub('tasksHub')">
                            <i class="bi bi-x-lg"></i> Close
                        </button>
                    </div>
                </div>
                <div class="rhp-filters">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Date From</label>
                            <input type="date" id="tsk-from" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Date To</label>
                            <input type="date" id="tsk-to" class="form-control form-control-sm" />
