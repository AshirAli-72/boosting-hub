@page "/admin/reports"
@model BoostingHub.frontend.Pages.Admin.Reports.IndexModel
@{
    ViewData["Title"] = "Reports Hub";
    ViewData["BodyClass"] = "admin-page";
}

        <div class="admin-header">
            <h3><i class="bi bi-bar-chart-line-fill text-primary"></i> Reports Hub</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> Admin
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-content">
            <div class="mb-4">
                <p style="color:var(--text-secondary);margin:0;font-size:0.9rem;">
                    Global platform-wide analytics — click <strong>View Report</strong> on any card to explore detailed reports.
                </p>
            </div>

            <!-- ── Report Cards Row ── -->
            <div class="row g-4">

                <!-- Revenue Card -->
                <div class="col-lg-3 col-md-6">
                    <div class="report-hub-card">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);">
                            <div class="rhc-icon"><i class="bi bi-currency-dollar"></i></div>
                            <div class="rhc-badge">Revenue</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Revenue</span>
                                    <span class="rhc-stat-value">$@Model.TotalRevenue.ToString("N2")</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Avg Order</span>
                                    <span class="rhc-stat-value">$@Model.AvgOrderValue.ToString("N2")</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Approved</span>
                                    <span class="rhc-stat-value">@Model.OrdersCompleted</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Pending</span>
                                    <span class="rhc-stat-value">@Model.OrdersPending</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <a href="/admin/reports/revenue" class="rhc-btn"><i class="bi bi-bar-chart-line"></i> View Report</a>
                        </div>
                    </div>
                </div>

                <!-- Users Card -->
                <div class="col-lg-3 col-md-6">
                    <div class="report-hub-card">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#7C3AED 0%,#5B21B6 100%);">
                            <div class="rhc-icon"><i class="bi bi-people-fill"></i></div>
                            <div class="rhc-badge">Users</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Users</span>
                                    <span class="rhc-stat-value">@Model.TotalUsers</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Verified</span>
                                    <span class="rhc-stat-value">@Model.VerifiedUsers</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Active</span>
                                    <span class="rhc-stat-value">@Model.ActiveUsers</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Locked</span>
                                    <span class="rhc-stat-value">@Model.LockedUsers</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <a href="/admin/reports/users" class="rhc-btn"><i class="bi bi-people"></i> View Report</a>
                        </div>
                    </div>
                </div>

                <!-- Tasks Card -->
                <div class="col-lg-3 col-md-6">
                    <div class="report-hub-card">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#10B981 0%,#059669 100%);">
                            <div class="rhc-icon"><i class="bi bi-list-task"></i></div>
                            <div class="rhc-badge">Tasks</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Tasks</span>
                                    <span class="rhc-stat-value">@Model.TotalTasks</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Completed</span>
                                    <span class="rhc-stat-value">@Model.CompletedTasks</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Active</span>
                                    <span class="rhc-stat-value">@Model.ActiveTasks</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Pending Proofs</span>
                                    <span class="rhc-stat-value">@Model.PendingProofs</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <a href="/admin/reports/tasks" class="rhc-btn"><i class="bi bi-check2-all"></i> View Report</a>
                        </div>
                    </div>
                </div>

                <!-- Orders Card -->
                <div class="col-lg-3 col-md-6">
                    <div class="report-hub-card">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#0D9488 0%,#0F766E 100%);">
                            <div class="rhc-icon"><i class="bi bi-cart-check-fill"></i></div>
                            <div class="rhc-badge">Orders</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Orders</span>
                                    <span class="rhc-stat-value">@Model.TotalOrders</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Approved</span>
                                    <span class="rhc-stat-value">@Model.OrdersCompleted</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Pending</span>
                                    <span class="rhc-stat-value">@Model.OrdersPending</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">In Progress</span>
                                    <span class="rhc-stat-value">@Model.OrdersInProgress</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <a href="/admin/reports/orders" class="rhc-btn"><i class="bi bi-cart3"></i> View Report</a>
                        </div>
                    </div>
                </div>

            </div><!-- /row -->
        </div><!-- /admin-content -->

@section Scripts {
<style>
/* ── Report Hub Cards ── */
.report-hub-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.25s, box-shadow 0.25s;
}
.report-hub-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-glow), var(--shadow-card); }
.rhc-header {
    padding: 18px 20px 14px;
    display: flex; align-items: center; justify-content: space-between;
}
.rhc-icon {
    width: 44px; height: 44px; border-radius: 12px;
    background: rgba(255,255,255,0.2); color: #fff;
    display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
}
.rhc-badge {
    background: rgba(255,255,255,0.18); color: #fff;
    padding: 3px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
}
.rhc-body { padding: 16px 20px 10px; }
.rhc-stat-row { display: flex; gap: 16px; }
.rhc-stat { flex: 1; }
.rhc-stat-label {
    font-size: 0.72rem; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.05em; display: block;
}
.rhc-stat-value {
    font-size: 1.15rem; font-weight: 800; color: var(--text-primary);
    display: block; line-height: 1.3;
}
.rhc-footer { padding: 10px 20px 16px; }
.rhc-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 9px 0; border-radius: 10px;
    background: var(--primary); color: #fff; border: none;
    font-weight: 600; font-size: 0.85rem; cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
}
.rhc-btn:hover { background: var(--primary-dark); box-shadow: 0 4px 12px var(--primary-glow); color: #fff; }
</style>
<script>
    function toggleProfileMenu() {
        var menu = document.getElementById('profileMenu');
        menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    }
    document.addEventListener('click', function(e) {
        var pd = document.getElementById('profileDropdown');
        if (pd && !pd.contains(e.target)) {
            var m = document.getElementById('profileMenu');
            if (m) m.style.display = 'none';
        }
    });
</script>
}
