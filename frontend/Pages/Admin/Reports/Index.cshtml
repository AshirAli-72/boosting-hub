                <div class="row g-3 mb-4 mt-1">
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#0D9488 0%,#0F766E 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-cart-check-fill"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Total Orders</span>
                                <span class="stat-value" style="color:#fff;">@Model.TotalOrders</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#10B981 0%,#059669 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-check-circle"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Approved</span>
                                <span class="stat-value" style="color:#fff;">@Model.OrdersCompleted</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#F59E0B 0%,#D97706 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-hourglass-split"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Pending</span>
                                <span class="stat-value" style="color:#fff;">@Model.OrdersPending</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-arrow-repeat"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">In Progress</span>
                                <span class="stat-value" style="color:#fff;">@Model.OrdersInProgress</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card shadow-sm border-0 chart-card chart-line">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold mb-3"><i class="bi bi-graph-up text-primary"></i> Daily Orders (Last 7 Days)</h6>
                                <canvas id="ordLineChart" style="width:100%!important;height:260px!important;"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0 chart-card chart-pie">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold mb-3"><i class="bi bi-pie-chart text-primary"></i> Order Status</h6>
                                <canvas id="ordPieChart" style="width:100%!important;max-width:300px!important;height:260px!important;margin:0 auto;"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Orders Detail Table -->
                <div class="row g-4 mt-1 no-print-charts">
                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-0">
                                <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom" style="border-color:var(--border-subtle)!important;">
                                    <h6 class="fw-bold mb-0"><i class="bi bi-table text-primary me-2"></i>All Orders — Detail</h6>
                                    <span class="badge bg-info">@Model.TotalOrders records</span>
                                </div>
                                <div class="table-responsive">
                                    <table class="admin-table mb-0 align-middle" id="ordTable">
                                        <thead class="admin-thead">
                                            <tr>
                                                <th>#</th><th>Client</th><th>Platform</th><th>Service</th><th>Budget</th><th>Status</th><th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var o in Model.OrdersTableData)
                                            {
                                                <tr>
                                                    <td>@o.Id</td>
                                                    <td>@(o.FullName ?? o.Email ?? "—")</td>
                                                    <td>@o.Platform</td>
                                                    <td>@o.Service</td>
                                                    <td class="fw-semibold">$@o.Budget.ToString("N2")</td>
