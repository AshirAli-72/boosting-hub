                                                    <td>@t.Platform</td>
                                                    <td>@t.Service</td>
                                                    <td>@t.Quantity</td>
                                                    <td class="fw-semibold">$@t.Reward.ToString("N2")</td>
                                                    <td>
                                                        @{
