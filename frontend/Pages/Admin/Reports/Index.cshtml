                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- /tasksHub -->

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- ORDERS HUB PANEL                                          -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <div id="ordersHub" class="report-hub-panel" style="display:none;">
                <div class="rhp-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rhp-icon-badge" style="background:linear-gradient(135deg,#0D9488,#0F766E);">
                            <i class="bi bi-cart-check-fill"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Orders Report Hub</h5>
                            <small style="color:var(--text-muted);">Order volume and status breakdown</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="printHub('ordersHub')">
