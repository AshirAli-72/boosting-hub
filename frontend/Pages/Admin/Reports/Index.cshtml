@page "/admin/reports"
@model BoostingHub.frontend.Pages.Admin.Reports.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Reports Hub";
    ViewData["BodyClass"] = "admin-page";
}

<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon"><i class="bi bi-rocket-takeoff"></i></div>
            <span>Boosting Hub</span>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin-panel" class="sidebar-link"><i class="bi bi-speedometer2"></i> Dashboard</a>
            <a href="/admin/reports" class="sidebar-link active"><i class="bi bi-bar-chart-line"></i> Reports Hub</a>
            <a href="/admin/in-progress" class="sidebar-link"><i class="bi bi-hourglass-split"></i> In Progress</a>
            <a href="/admin/completed" class="sidebar-link"><i class="bi bi-check2-all"></i> Completed</a>
            <a href="/admin/inquiries" class="sidebar-link"><i class="bi bi-inbox"></i> Client Requirements</a>
            <a href="/admin/proof-review" class="sidebar-link"><i class="bi bi-shield-check"></i> Proof Review</a>
            <div class="sidebar-divider"></div>
            <a href="/admin/settings" class="sidebar-link"><i class="bi bi-gear"></i> Settings</a>
            <a href="/logout" class="sidebar-link sidebar-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </nav>
    </aside>
    <main class="admin-main">
        <div class="admin-header">
            <h3><i class="bi bi-bar-chart-line-fill text-primary"></i> Reports Hub</h3>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> Admin
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-content">
            <div class="mb-4">
                <p style="color:var(--text-secondary,rgba(241,245,249,0.6));margin:0;font-size:0.9rem;">
                    Global platform-wide analytics — click <strong>Report Hub</strong> on any card to explore detailed reports.
                </p>
            </div>

            <!-- ── Report Cards Row ──────────────────────────────────────────── -->
            <div class="row g-4 mb-2">

                <!-- Revenue Card -->
                <div class="col-xl-3 col-md-6">
                    <div class="report-hub-card" onclick="openHub('revenueHub')">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);">
                            <div class="rhc-icon"><i class="bi bi-currency-dollar"></i></div>
                            <div class="rhc-badge">Revenue</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Revenue</span>
                                    <span class="rhc-stat-desc">All-time approved income</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Avg Order</span>
                                    <span class="rhc-stat-desc">Per order average</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Approved</span>
                                    <span class="rhc-stat-desc">Successfully closed</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Pending</span>
                                    <span class="rhc-stat-desc">Awaiting approval</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <button class="rhc-btn" type="button"><i class="bi bi-bar-chart-line"></i> Report Hub</button>
                        </div>
                    </div>
                </div>

                <!-- Users Card -->
                <div class="col-xl-3 col-md-6">
                    <div class="report-hub-card" onclick="openHub('usersHub')">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#7C3AED 0%,#5B21B6 100%);">
                            <div class="rhc-icon"><i class="bi bi-people-fill"></i></div>
                            <div class="rhc-badge">Users</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Users</span>
                                    <span class="rhc-stat-desc">All registered accounts</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Verified</span>
                                    <span class="rhc-stat-desc">Email-confirmed users</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Active</span>
                                    <span class="rhc-stat-desc">Currently active</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Locked</span>
                                    <span class="rhc-stat-desc">Suspended accounts</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <button class="rhc-btn" type="button"><i class="bi bi-people"></i> Report Hub</button>
                        </div>
                    </div>
                </div>

                <!-- Tasks Card -->
                <div class="col-xl-3 col-md-6">
                    <div class="report-hub-card" onclick="openHub('tasksHub')">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#10B981 0%,#059669 100%);">
                            <div class="rhc-icon"><i class="bi bi-list-task"></i></div>
                            <div class="rhc-badge">Tasks</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Tasks</span>
                                    <span class="rhc-stat-desc">All generated tasks</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Completed</span>
                                    <span class="rhc-stat-desc">Successfully finished</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Active</span>
                                    <span class="rhc-stat-desc">Open for workers</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Pending Proofs</span>
                                    <span class="rhc-stat-desc">Awaiting review</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <button class="rhc-btn" type="button"><i class="bi bi-check2-all"></i> Report Hub</button>
                        </div>
                    </div>
                </div>

                <!-- Orders Card -->
                <div class="col-xl-3 col-md-6">
                    <div class="report-hub-card" onclick="openHub('ordersHub')">
                        <div class="rhc-header" style="background:linear-gradient(135deg,#0D9488 0%,#0F766E 100%);">
                            <div class="rhc-icon"><i class="bi bi-cart-check-fill"></i></div>
                            <div class="rhc-badge">Orders</div>
                        </div>
                        <div class="rhc-body">
                            <div class="rhc-stat-row">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Total Orders</span>
                                    <span class="rhc-stat-desc">All client orders</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Approved</span>
                                    <span class="rhc-stat-desc">Delivered orders</span>
                                </div>
                            </div>
                            <div class="rhc-stat-row mt-2">
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">Pending</span>
                                    <span class="rhc-stat-desc">Queued for processing</span>
                                </div>
                                <div class="rhc-stat">
                                    <span class="rhc-stat-label">In Progress</span>
                                    <span class="rhc-stat-desc">Currently active</span>
                                </div>
                            </div>
                        </div>
                        <div class="rhc-footer">
                            <button class="rhc-btn" type="button"><i class="bi bi-cart3"></i> Report Hub</button>
                        </div>
                    </div>
                </div>

            </div><!-- /row -->

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- REVENUE HUB PANEL                                         -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <div id="revenueHub" class="report-hub-panel" style="display:none;">
                <div class="rhp-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rhp-icon-badge" style="background:linear-gradient(135deg,#3B82F6,#1D4ED8);">
                            <i class="bi bi-currency-dollar"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Revenue Report Hub</h5>
                            <small style="color:var(--text-muted);">Filter and analyse revenue data</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="printHub('revenueHub')">
                            <i class="bi bi-printer"></i> Print
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="closeHub('revenueHub')">
                            <i class="bi bi-x-lg"></i> Close
                        </button>
                    </div>
                </div>

                <!-- Filters -->
                <div class="rhp-filters">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Date From</label>
                            <input type="date" id="rev-from" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Date To</label>
                            <input type="date" id="rev-to" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Status</label>
                            <select id="rev-status" class="form-select form-select-sm">
                                <option value="all">All Statuses</option>
                                <option value="Approved">Approved</option>
                                <option value="Pending">Pending</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary btn-sm w-100" onclick="applyRevenueFilter()">
                                <i class="bi bi-funnel"></i> Apply Filter
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Revenue Summary Stats -->
                <div class="row g-3 mb-4 mt-1">
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-currency-dollar"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Total Revenue</span>
                                <span class="stat-value" style="color:#fff;" id="rev-stat-total">$@Model.TotalRevenue.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#10B981 0%,#059669 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-check-circle"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Approved Orders</span>
                                <span class="stat-value" style="color:#fff;" id="rev-stat-approved">@Model.OrdersCompleted</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#F59E0B 0%,#D97706 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-hourglass-split"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Pending Orders</span>
                                <span class="stat-value" style="color:#fff;" id="rev-stat-pending">@Model.OrdersPending</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#8B5CF6 0%,#6D28D9 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-calculator"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Avg Order Value</span>
                                <span class="stat-value" style="color:#fff;" id="rev-stat-avg">$@Model.AvgOrderValue.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts -->
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card shadow-sm border-0 chart-card chart-line">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold mb-3"><i class="bi bi-graph-up text-primary"></i> Daily Revenue (Last 7 Days)</h6>
                                <canvas id="revLineChart" style="width:100%!important;height:260px!important;"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0 chart-card chart-pie">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold mb-3"><i class="bi bi-pie-chart text-primary"></i> Order Status</h6>
                                <canvas id="revPieChart" style="width:100%!important;max-width:300px!important;height:260px!important;margin:0 auto;"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Revenue Detail Table -->
                <div class="row g-4 mt-1 no-print-charts">
                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-0">
                                <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom" style="border-color:var(--border-subtle)!important;">
                                    <h6 class="fw-bold mb-0"><i class="bi bi-table text-primary me-2"></i>Approved Orders — Detail</h6>
                                    <span class="badge bg-success">@Model.OrdersCompleted records</span>
                                </div>
                                <div class="table-responsive">
                                    <table class="admin-table mb-0 align-middle" id="revTable">
                                        <thead class="admin-thead">
                                            <tr>
                                                <th>#</th><th>Client</th><th>Platform</th><th>Service</th><th>Budget</th><th>Status</th><th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var o in Model.RevenueTableData)
                                            {
                                                <tr>
                                                    <td>@o.Id</td>
                                                    <td>@(o.FullName ?? o.Email ?? "—")</td>
                                                    <td>@o.Platform</td>
                                                    <td>@o.Service</td>
                                                    <td class="fw-semibold">$@o.Budget.ToString("N2")</td>
                                                    <td><span class="badge bg-success bg-opacity-15 text-success border border-success border-opacity-25 rounded-pill px-2">@o.Status</span></td>
                                                    <td>@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                                                </tr>
                                            }
                                            @if (!Model.RevenueTableData.Any())
                                            {
                                                <tr><td colspan="7" class="text-center text-muted py-4">No approved orders found</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- /revenueHub -->

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- USERS HUB PANEL                                           -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <div id="usersHub" class="report-hub-panel" style="display:none;">
                <div class="rhp-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rhp-icon-badge" style="background:linear-gradient(135deg,#7C3AED,#5B21B6);">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Users Report Hub</h5>
                            <small style="color:var(--text-muted);">User registration and activity analytics</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="printHub('usersHub')">
                            <i class="bi bi-printer"></i> Print
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="closeHub('usersHub')">
                            <i class="bi bi-x-lg"></i> Close
                        </button>
                    </div>
                </div>
                <!-- Filters -->
                <div class="rhp-filters">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Registered From</label>
                            <input type="date" id="usr-from" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Registered To</label>
                            <input type="date" id="usr-to" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label rhp-label">Status</label>
                            <select id="usr-status" class="form-select form-select-sm">
                                <option value="all">All Users</option>
                                <option value="verified">Verified Only</option>
                                <option value="unverified">Unverified Only</option>
                                <option value="locked">Locked Only</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary btn-sm w-100" onclick="applyUsersFilter()">
                                <i class="bi bi-funnel"></i> Apply Filter
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Users Stats -->
                <div class="row g-3 mb-4 mt-1">
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#7C3AED 0%,#5B21B6 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-people-fill"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Total Users</span>
                                <span class="stat-value" style="color:#fff;">@Model.TotalUsers</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#10B981 0%,#059669 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-envelope-check"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Verified</span>
                                <span class="stat-value" style="color:#fff;">@Model.VerifiedUsers</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-person-check"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Active</span>
                                <span class="stat-value" style="color:#fff;">@Model.ActiveUsers</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card" style="background:linear-gradient(135deg,#EF4444 0%,#B91C1C 100%);border:none;">
                            <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-shield-exclamation"></i></div>
                            <div class="stat-info">
                                <span class="stat-label" style="color:rgba(255,255,255,0.75);">Locked</span>
                                <span class="stat-value" style="color:#fff;">@Model.LockedUsers</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card shadow-sm border-0 chart-card chart-line">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold mb-3"><i class="bi bi-graph-up text-primary"></i> Daily Registrations (Last 7 Days)</h6>
                                <canvas id="usrLineChart" style="width:100%!important;height:260px!important;"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0 chart-card chart-pie">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold mb-3"><i class="bi bi-pie-chart text-primary"></i> User Status</h6>
                                <canvas id="usrPieChart" style="width:100%!important;max-width:300px!important;height:260px!important;margin:0 auto;"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Users Detail Table -->
                <div class="row g-4 mt-1 no-print-charts">
                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-0">
                                <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom" style="border-color:var(--border-subtle)!important;">
                                    <h6 class="fw-bold mb-0"><i class="bi bi-table text-primary me-2"></i>Registered Users — Detail</h6>
                                    <span class="badge bg-primary">@Model.TotalUsers records</span>
                                </div>
                                <div class="table-responsive">
                                    <table class="admin-table mb-0 align-middle" id="usrTable">
                                        <thead class="admin-thead">
                                            <tr>
                                                <th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Email Verified</th><th>Status</th><th>Joined</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var u in Model.UsersTableData)
                                            {
                                                <tr>
                                                    <td>@u.Id</td>
                                                    <td class="fw-medium">@(u.Name ?? "—")</td>
                                                    <td>@(u.Email ?? "—")</td>
                                                    <td>@(u.Phone ?? "—")</td>
                                                    <td>
                                                        @if (u.EmailVerifiedAt != null)
                                                        {
                                                            <span class="badge bg-success bg-opacity-15 text-success border border-success border-opacity-25 rounded-pill px-2">Verified</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning bg-opacity-15 text-warning border border-warning border-opacity-25 rounded-pill px-2">Pending</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (u.Status == 1)
                                                        {
                                                            <span class="badge bg-success bg-opacity-15 text-success border border-success border-opacity-25 rounded-pill px-2">Active</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger bg-opacity-15 text-danger border border-danger border-opacity-25 rounded-pill px-2">Locked</span>
                                                        }
                                                    </td>
                                                    <td>@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                                                </tr>
                                            }
                                            @if (!Model.UsersTableData.Any())
                                            {
                                                <tr><td colspan="7" class="text-center text-muted py-4">No users found</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- /usersHub -->

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- TASKS HUB PANEL                                           -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <div id="tasksHub" class="report-hub-panel" style="display:none;">
                <div class="rhp-header">
                    <div class="d-flex align-items-center gap-3">
