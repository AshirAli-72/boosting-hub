                                                            var oBadge = o.Status == "Approved" ? "success" : o.Status == "Pending" ? "warning" : o.Status == "in_progress" ? "info" : "danger";
                                                            var oLabel = o.Status == "in_progress" ? "In Progress" : o.Status;
                                                        }
                                                        <span class="badge bg-@oBadge bg-opacity-15 text-@oBadge border border-@oBadge border-opacity-25 rounded-pill px-2">@oLabel</span>
                                                    </td>
                                                    <td>@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                                                </tr>
                                            }
                                            @if (!Model.OrdersTableData.Any())
                                            {
                                                <tr><td colspan="7" class="text-center text-muted py-4">No orders found</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- /ordersHub -->

        </div><!-- /admin-content -->
    </main>
</div><!-- /admin-layout -->

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<style>
.rhc-stat-desc { font-size: 0.8rem; color: var(--text-muted); display: block; line-height: 1.4; }
/* ── Report Hub Cards ── */
.report-hub-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s;
}
.report-hub-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-glow), var(--shadow-card); }
.rhc-header {
    padding: 18px 20px 14px;
    display: flex; align-items: center; justify-content: space-between;
}
.rhc-icon {
    width: 44px; height: 44px; border-radius: 12px;
    background: rgba(255,255,255,0.2); color: #fff;
    display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
}
.rhc-badge {
    background: rgba(255,255,255,0.18); color: #fff;
    padding: 3px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
}
.rhc-body { padding: 16px 20px 10px; }
.rhc-stat-row { display: flex; gap: 16px; }
.rhc-stat { flex: 1; }
.rhc-stat-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; display: block; }
.rhc-stat-value { font-size: 1.15rem; font-weight: 800; color: var(--text-primary); display: block; line-height: 1.3; }
.rhc-footer { padding: 10px 20px 16px; }
.rhc-btn {
    width: 100%; padding: 9px 0; border-radius: 10px;
    background: var(--primary); color: #fff; border: none;
    font-weight: 600; font-size: 0.85rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background 0.2s, box-shadow 0.2s;
}
.rhc-btn:hover { background: var(--primary-dark); box-shadow: 0 4px 12px var(--primary-glow); }

/* ── Report Hub Panel ── */
.report-hub-panel {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 18px;
    padding: 0 0 28px;
    margin-top: 8px;
    box-shadow: var(--shadow-card);
    animation: slideDown 0.25s ease;
}
@@keyframes slideDown { from { opacity:0; transform:translateY(-12px); } to { opacity:1; transform:translateY(0); } }
.rhp-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 28px;
    border-bottom: 1px solid var(--border-subtle);
}
.rhp-icon-badge {
    width: 46px; height: 46px; border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.3rem; flex-shrink: 0;
}
.rhp-filters {
    padding: 18px 28px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-subtle);
}
.rhp-label { font-size: 0.78rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px; }
.report-hub-panel .row.g-3, .report-hub-panel .row.g-4 { padding: 0 28px; }

/* ── Print styles ── */
@@media print {
    /* Hide everything except the active hub's table */
    .admin-sidebar, .admin-header, .report-hub-card,
    .rhp-filters, .rhp-header, .row.g-4.mb-4,
    .chart-card, canvas, .no-print-charts .chart-card,
    script { display: none !important; }

    /* Show ONLY the active panel's table section */
    .report-hub-panel { display: none !important; }
    .report-hub-panel.printing {
        display: block !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        margin: 0 !important;
        background: #fff !important;
    }
    .report-hub-panel.printing .row.g-4 { padding: 0 !important; }
    .report-hub-panel.printing canvas,
    .report-hub-panel.printing .chart-card { display: none !important; }
    .report-hub-panel.printing .no-print-charts { display: block !important; }

    .admin-main { margin-left: 0 !important; }
    body, html { background: #fff !important; color: #000 !important; font-size: 12px !important; }

    /* ── Print header injected via JS ── */
    .print-report-header {
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        border-bottom: 2px solid #7C3AED;
        padding-bottom: 12px;
        margin-bottom: 20px;
    }
    .print-report-header .prt-brand { font-size: 1.1rem; font-weight: 800; color: #7C3AED; }
    .print-report-header .prt-meta  { font-size: 0.75rem; color: #64748b; text-align: right; }

    /* ── Print summary stats row ── */
    .print-stats-row {
        display: flex !important;
        gap: 12px;
        margin-bottom: 18px;
    }
    .print-stat-box {
        flex: 1;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 14px;
        background: #f8fafc;
    }
    .print-stat-box .ps-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; display: block; }
    .print-stat-box .ps-value { font-size: 1rem; font-weight: 800; color: #1e293b; display: block; }

    /* ── Print table ── */
    .admin-table { width: 100% !important; border-collapse: collapse !important; font-size: 11px !important; }
    .admin-table th { background: #7C3AED !important; color: #fff !important; padding: 8px 10px !important; text-align: left; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .admin-table td { padding: 7px 10px !important; border-bottom: 1px solid #e2e8f0 !important; color: #334155 !important; }
    .admin-table tr:nth-child(even) td { background: #f8fafc !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .badge { border: 1px solid #cbd5e1 !important; background: #f1f5f9 !important; color: #475569 !important; font-size: 10px !important; padding: 2px 6px !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

    /* Print footer */
    .print-footer {
        display: block !important;
        text-align: center;
        margin-top: 24px;
        font-size: 0.7rem;
        color: #94a3b8;
        border-top: 1px solid #e2e8f0;
        padding-top: 8px;
    }

    @@page { margin: 18mm 14mm; }
}
</style>

<script>
    // ── Server data ──────────────────────────────────────────────────────────
    var revLineLabels  = @Html.Raw(JsonSerializer.Serialize(Model.OrderTrendLabels));
    var revLineData    = @Html.Raw(JsonSerializer.Serialize(Model.OrderTrendData));
    var usrLineLabels  = @Html.Raw(JsonSerializer.Serialize(Model.UserTrendLabels));
    var usrLineData    = @Html.Raw(JsonSerializer.Serialize(Model.UserTrendData));
    var tskLineLabels  = @Html.Raw(JsonSerializer.Serialize(Model.TaskTrendLabels));
    var tskLineData    = @Html.Raw(JsonSerializer.Serialize(Model.TaskTrendData));

    var charts = {};

    function isLight() { return document.body.classList.contains('light-mode'); }

    // ── Open / Close hub panels ───────────────────────────────────────────────
    function openHub(id) {
        // Close all others first
        ['revenueHub','usersHub','tasksHub','ordersHub'].forEach(function(h) {
            if (h !== id) document.getElementById(h).style.display = 'none';
        });
        var el = document.getElementById(id);
        el.style.display = 'block';
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // Init chart for this hub on first open
        if (id === 'revenueHub' && !charts.revLine)  initRevenueCharts();
        if (id === 'usersHub'   && !charts.usrLine)  initUsersCharts();
        if (id === 'tasksHub'   && !charts.tskLine)  initTasksCharts();
        if (id === 'ordersHub'  && !charts.ordLine)  initOrdersCharts();
    }

    function closeHub(id) {
        document.getElementById(id).style.display = 'none';
    }

    function printHub(id) {
        var hubTitles = {
            revenueHub: 'Revenue Report',
            usersHub:   'Users Report',
            tasksHub:   'Tasks Report',
            ordersHub:  'Orders Report'
        };

        // Stats to show per hub
        var hubStats = {
            revenueHub: [
                { label: 'Total Revenue',   value: '$@Model.TotalRevenue.ToString("N2")' },
                { label: 'Total Orders',    value: '@Model.TotalOrders' },
                { label: 'Approved Orders', value: '@Model.OrdersCompleted' },
                { label: 'Pending Orders',  value: '@Model.OrdersPending' },
                { label: 'Avg Order Value', value: '$@Model.AvgOrderValue.ToString("N2")' }
            ],
            usersHub: [
                { label: 'Total Users',    value: '@Model.TotalUsers' },
                { label: 'Verified',       value: '@Model.VerifiedUsers' },
                { label: 'Active',         value: '@Model.ActiveUsers' },
                { label: 'Locked',         value: '@Model.LockedUsers' }
            ],
            tasksHub: [
                { label: 'Total Tasks',    value: '@Model.TotalTasks' },
                { label: 'Active Tasks',   value: '@Model.ActiveTasks' },
                { label: 'Completed',      value: '@Model.CompletedTasks' },
                { label: 'Pending Proofs', value: '@Model.PendingProofs' },
                { label: 'Approved Proofs',value: '@Model.ApprovedProofs' }
            ],
            ordersHub: [
                { label: 'Total Orders',   value: '@Model.TotalOrders' },
                { label: 'Approved',       value: '@Model.OrdersCompleted' },
                { label: 'Pending',        value: '@Model.OrdersPending' },
                { label: 'In Progress',    value: '@Model.OrdersInProgress' },
                { label: 'Total Revenue',  value: '$@Model.TotalRevenue.ToString("N2")' }
            ]
        };

        var panel = document.getElementById(id);
        panel.classList.add('printing');

        // Build and inject print header
        var now = new Date().toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });
        var statsHtml = (hubStats[id] || []).map(function(s) {
            return '<div class="print-stat-box"><span class="ps-label">' + s.label + '</span><span class="ps-value">' + s.value + '</span></div>';
        }).join('');

        var headerEl = document.createElement('div');
        headerEl.className = 'print-report-header';
        headerEl.id = '__printHeader';
        headerEl.innerHTML =
            '<div class="prt-brand"><i class="bi bi-rocket-takeoff"></i> Boosting Hub &nbsp;|&nbsp; ' + (hubTitles[id] || 'Report') + '</div>' +
            '<div class="prt-meta">Generated: ' + now + '<br>Boosting Hub &mdash; Admin Panel</div>';

        var statsEl = document.createElement('div');
        statsEl.className = 'print-stats-row';
        statsEl.id = '__printStats';
        statsEl.innerHTML = statsHtml;

        var footerEl = document.createElement('div');
        footerEl.className = 'print-footer';
        footerEl.id = '__printFooter';
        footerEl.innerHTML = 'Boosting Hub &bull; ' + (hubTitles[id] || 'Report') + ' &bull; Generated ' + now + ' &bull; Confidential';

        panel.insertBefore(statsEl, panel.firstChild);
        panel.insertBefore(headerEl, panel.firstChild);
        panel.appendChild(footerEl);

        window.print();

        // Clean up
        panel.classList.remove('printing');
        document.getElementById('__printHeader').remove();
        document.getElementById('__printStats').remove();
        document.getElementById('__printFooter').remove();
    }

    // ── Shared chart factory ─────────────────────────────────────────────────
    function makeLineChart(canvasId, labels, data, color) {
        return new Chart(document.getElementById(canvasId), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{ label: '', data: data,
                    borderColor: color, backgroundColor: color.replace('1)', '0.12)').replace('#', 'rgba(').replace(/([0-9a-f]{2})/gi, function(m){ return parseInt(m,16)+','; }).slice(0,-1)+'0.12)',
                    fill: true, tension: 0.4,
                    pointBackgroundColor: color, pointRadius: 4 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: isLight() ? '#64748B' : 'rgba(241,245,249,0.4)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } },
                    y: { beginAtZero: true, ticks: { stepSize: 1, color: isLight() ? '#64748B' : 'rgba(241,245,249,0.4)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } }
                }
            }
        });
    }

    function makePieChart(canvasId, labels, data, colors) {
        return new Chart(document.getElementById(canvasId), {
            type: 'doughnut',
            data: { labels: labels, datasets: [{ data: data, backgroundColor: colors, borderWidth: 0, hoverOffset: 6 }] },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '65%',
                plugins: { legend: { position: 'bottom', labels: { color: isLight() ? '#334155' : 'rgba(241,245,249,0.65)', padding: 14 } } }
            }
        });
    }
</script>

<script>
    // ── Revenue charts ────────────────────────────────────────────────────────
    function initRevenueCharts() {
        charts.revLine = makeLineChart('revLineChart', revLineLabels, revLineData, '#3B82F6');
        charts.revPie  = makePieChart('revPieChart',
            ['Approved', 'Pending', 'Rejected'],
            [@Model.OrdersCompleted, @Model.OrdersPending, @Model.TotalOrders - @Model.OrdersCompleted - @Model.OrdersPending],
            ['#10B981','#F59E0B','#EF4444']);
    }

    function applyRevenueFilter() {
        var from   = document.getElementById('rev-from').value;
        var to     = document.getElementById('rev-to').value;
        var status = document.getElementById('rev-status').value;
        // Client-side visual feedback – server-side filtering can be wired via AJAX
        console.log('Revenue filter:', from, to, status);
        // TODO: fetch filtered data via AJAX and update charts.revLine / charts.revPie
    }

    // ── Users charts ──────────────────────────────────────────────────────────
    function initUsersCharts() {
        charts.usrLine = makeLineChart('usrLineChart', usrLineLabels, usrLineData, '#7C3AED');
        charts.usrPie  = makePieChart('usrPieChart',
            ['Active', 'Locked', 'Unverified'],
            [@Model.ActiveUsers, @Model.LockedUsers, @Model.TotalUsers - @Model.VerifiedUsers],
            ['#10B981','#EF4444','#F59E0B']);
    }

    function applyUsersFilter() {
        var from   = document.getElementById('usr-from').value;
        var to     = document.getElementById('usr-to').value;
        var status = document.getElementById('usr-status').value;
        console.log('Users filter:', from, to, status);
    }

    // ── Tasks charts ──────────────────────────────────────────────────────────
    function initTasksCharts() {
        charts.tskLine = makeLineChart('tskLineChart', tskLineLabels, tskLineData, '#10B981');
        charts.tskPie  = makePieChart('tskPieChart',
            ['Pending Proofs', 'Approved Proofs', 'Rejected Proofs'],
            [@Model.PendingProofs, @Model.ApprovedProofs, @Model.RejectedProofs],
            ['#F59E0B','#10B981','#EF4444']);
    }

    function applyTasksFilter() {
        var from  = document.getElementById('tsk-from').value;
        var to    = document.getElementById('tsk-to').value;
        var proof = document.getElementById('tsk-proof').value;
        console.log('Tasks filter:', from, to, proof);
    }

    // ── Orders charts ─────────────────────────────────────────────────────────
    function initOrdersCharts() {
        charts.ordLine = makeLineChart('ordLineChart', revLineLabels, revLineData, '#0D9488');
        charts.ordPie  = makePieChart('ordPieChart',
            ['Approved', 'Pending', 'In Progress'],
            [@Model.OrdersCompleted, @Model.OrdersPending, @Model.OrdersInProgress],
            ['#10B981','#F59E0B','#3B82F6']);
    }

    function applyOrdersFilter() {
        var from   = document.getElementById('ord-from').value;
        var to     = document.getElementById('ord-to').value;
        var status = document.getElementById('ord-status').value;
        console.log('Orders filter:', from, to, status);
    }

    // ── Profile dropdown ──────────────────────────────────────────────────────
    function toggleProfileMenu() {
        var menu = document.getElementById('profileMenu');
        menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    }
    document.addEventListener('click', function(e) {
        var pd = document.getElementById('profileDropdown');
        if (pd && !pd.contains(e.target)) {
            var m = document.getElementById('profileMenu');
            if (m) m.style.display = 'none';
        }
    });

    // ── Theme change: update open charts ─────────────────────────────────────
    var themeObserver = new MutationObserver(function() {
        Object.values(charts).forEach(function(ch) {
            if (!ch) return;
            var light = isLight();
            if (ch.config.type === 'line') {
                ch.options.scales.x.ticks.color = light ? '#64748B' : 'rgba(241,245,249,0.4)';
                ch.options.scales.x.grid.color  = light ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)';
                ch.options.scales.y.ticks.color = light ? '#64748B' : 'rgba(241,245,249,0.4)';
                ch.options.scales.y.grid.color  = light ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)';
            } else {
                ch.options.plugins.legend.labels.color = light ? '#334155' : 'rgba(241,245,249,0.65)';
            }
            ch.update();
        });
    });
    themeObserver.observe(document.body, { attributes: true, attributeFilter: ['class'] });
</script>
}
