@page "/admin/reports/users"
@model BoostingHub.frontend.Pages.Admin.Reports.UsersReportModel
@using System.Text.Json
@{
    ViewData["Title"] = "Users Report";
    ViewData["BodyClass"] = "admin-page";
}

        <div class="admin-header">
            <div class="d-flex align-items-center gap-3">
                <h3 class="mb-0"><i class="bi bi-people-fill text-primary"></i> Users Report</h3>
            </div>
            <div class="admin-header-right">
                <button id="themeToggle" class="btn btn-sm btn-outline-primary me-3 border-0" aria-label="Toggle Theme">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>
                <div class="user-profile-dropdown" id="profileDropdown">
                    <span class="admin-user-badge" onclick="toggleProfileMenu()">
                        <i class="bi bi-person-circle"></i> Admin
                        <i class="bi bi-chevron-down" style="font-size:0.65rem;margin-left:2px;"></i>
                    </span>
                    <div class="profile-menu" id="profileMenu" style="display:none;">
                        <a href="/logout" class="profile-menu-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-content">

            <!-- Action Buttons -->
            <div class="d-flex align-items-center gap-2 mb-4 no-print">
                <a href="/admin/reports" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
                <button class="btn btn-sm btn-outline-primary" onclick="printReport()">
                    <i class="bi bi-printer"></i> Print
                </button>
            </div>

            <!-- Print Header -->
            <div class="print-report-header">
                <div class="prt-brand"><i class="bi bi-rocket-takeoff"></i> Boosting Hub &nbsp;|&nbsp; Users Report</div>
                <div class="prt-meta" id="printMeta"></div>
            </div>

            <!-- Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#7C3AED 0%,#5B21B6 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-people-fill"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">Total Users</span>
                            <span class="stat-value" style="color:#fff;">@Model.TotalUsers</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#10B981 0%,#059669 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-envelope-check"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">Verified</span>
                            <span class="stat-value" style="color:#fff;">@Model.VerifiedUsers</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#3B82F6 0%,#1D4ED8 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-person-check"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">Active</span>
                            <span class="stat-value" style="color:#fff;">@Model.ActiveUsers</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="background:linear-gradient(135deg,#EF4444 0%,#B91C1C 100%);border:none;">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-shield-exclamation"></i></div>
                        <div class="stat-info">
                            <span class="stat-label" style="color:rgba(255,255,255,0.75);">Locked</span>
                            <span class="stat-value" style="color:#fff;">@Model.LockedUsers</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="card shadow-sm border-0 mb-4 no-print">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label report-filter-label">Registered From</label>
                            <input type="date" id="usr-from" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label report-filter-label">Registered To</label>
                            <input type="date" id="usr-to" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label report-filter-label">Status</label>
                            <select id="usr-status" class="form-select form-select-sm">
                                <option value="all">All Users</option>
                                <option value="Verified">Verified Only</option>
                                <option value="Pending">Unverified Only</option>
                                <option value="Active">Active Only</option>
                                <option value="Locked">Locked Only</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary btn-sm w-100" onclick="applyFilter()">
                                <i class="bi bi-funnel"></i> Apply Filter
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts -->
            <div class="row g-4 mb-4 no-print">
                <div class="col-md-8">
                    <div class="card shadow-sm border-0 chart-card chart-line">
                        <div class="card-body">
                            <h6 class="card-title fw-semibold mb-3"><i class="bi bi-graph-up text-primary"></i> Daily Registrations (Last 7 Days)</h6>
                            <canvas id="usrLineChart"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 chart-card chart-pie">
                        <div class="card-body">
                            <h6 class="card-title fw-semibold mb-3"><i class="bi bi-pie-chart text-primary"></i> User Status</h6>
                            <canvas id="usrPieChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detail Table -->
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom no-print" style="border-color:var(--border-subtle)!important;">
                        <h6 class="fw-bold mb-0"><i class="bi bi-table text-primary me-2"></i>Registered Users — Detail</h6>
                        <span class="badge bg-primary">@Model.TotalUsers records</span>
                    </div>
                    <div class="print-table-title">Registered Users — Detail</div>
                    <div class="table-responsive">
                        <table class="admin-table mb-0 align-middle" id="usrTable">
                            <thead class="admin-thead">
                                <tr>
                                    <th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Email Verified</th><th>Status</th><th>Joined</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in Model.UsersTableData)
                                {
                                    <tr>
                                        <td>@u.Id</td>
                                        <td class="fw-medium">@(u.Name ?? "—")</td>
                                        <td>@(u.Email ?? "—")</td>
                                        <td>@(u.Phone ?? "—")</td>
                                        <td>
                                            @if (u.EmailVerifiedAt != null)
                                            {
                                                <span class="report-badge report-badge-success">Verified</span>
                                            }
                                            else
                                            {
                                                <span class="report-badge report-badge-warning">Pending</span>
                                            }
                                        </td>
                                        <td>
                                            @if (u.Status == 1)
                                            {
                                                <span class="report-badge report-badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="report-badge report-badge-danger">Locked</span>
                                            }
                                        </td>
                                        <td>@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                                @if (!Model.UsersTableData.Any())
                                {
                                    <tr><td colspan="7" class="text-center py-4" style="color:var(--text-muted);">No users found</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="print-footer">
                Boosting Hub &bull; Users Report &bull; <span id="printDate"></span> &bull; Confidential
            </div>

        </div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<style>
.report-filter-label { font-size: 0.78rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
.report-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; white-space: nowrap; }
.report-badge-success  { background: #10B981; color: #fff; }
.report-badge-warning  { background: #F59E0B; color: #1a1a1a; }
.report-badge-danger   { background: #EF4444; color: #fff; }
.report-badge-info     { background: #3B82F6; color: #fff; }
.report-badge-secondary{ background: #64748B; color: #fff; }
.print-report-header, .print-footer, .print-table-title { display: none; }
@@media print {
    .no-print, .admin-sidebar, .admin-header, .sidebar-mobile-toggle, .sidebar-overlay { display: none !important; }
    .admin-main { margin-left: 0 !important; }
    .admin-content { padding: 0 !important; background: #fff !important; }
    body, html { background: #fff !important; color: #1E293B !important; }
    .print-report-header { display: flex !important; justify-content: space-between; align-items: center; border-bottom: 2px solid #334155; padding-bottom: 8px; margin-bottom: 6px; }
    .prt-brand { font-size: 16px; font-weight: 700; color: #1E293B !important; }
    .prt-meta { font-size: 9px; color: #64748B !important; text-align: right; }
    .print-table-title { display: block !important; font-size: 12px; font-weight: 700; color: #1E293B; padding: 8px 0 6px; border-bottom: 1px solid #CBD5E1; margin-bottom: 0; }
    .admin-table { width: 100% !important; border-collapse: collapse !important; border: 1px solid #CBD5E1 !important; font-size: 9px !important; }
    .admin-table thead, .admin-thead { background: #F1F5F9 !important; }
    .admin-table th { background: #F1F5F9 !important; color: #475569 !important; padding: 6px 8px !important; font-size: 8px !important; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 2px solid #CBD5E1 !important; border-right: 1px solid #E2E8F0 !important; }
    .admin-table th:last-child { border-right: none !important; }
    .admin-table td { padding: 5px 8px !important; border-bottom: 1px solid #E2E8F0 !important; border-right: 1px solid #E2E8F0 !important; color: #334155 !important; font-size: 9px !important; background: #fff !important; }
    .admin-table td:last-child { border-right: none !important; }
    .admin-table tr:nth-child(even) td { background: #F8FAFC !important; }
    .admin-table tr:last-child td { border-bottom: 2px solid #CBD5E1 !important; }
    .report-badge { font-size: 7px !important; padding: 1px 5px !important; border-radius: 3px !important; background: #E2E8F0 !important; color: #475569 !important; }
    .print-footer { display: block !important; margin-top: 20px; padding-top: 8px; border-top: 1px solid #CBD5E1; font-size: 8px; color: #94A3B8; text-align: center; }
    .row.g-3, .stat-card { display: none !important; }
    .row.g-4 { display: none !important; }
    @@page { margin: 12mm 15mm; size: A4 portrait; }
}
</style>
<script>
    var usrLineLabels = @Html.Raw(JsonSerializer.Serialize(Model.UserTrendLabels));
    var usrLineData   = @Html.Raw(JsonSerializer.Serialize(Model.UserTrendData));

    function isLight() { return document.body.classList.contains('light-mode'); }

    var usrLine = new Chart(document.getElementById('usrLineChart'), {
        type: 'line',
        data: { labels: usrLineLabels, datasets: [{ label: 'Registrations', data: usrLineData, borderColor: '#7C3AED', backgroundColor: 'rgba(124,58,237,0.12)', fill: true, tension: 0.4, pointBackgroundColor: '#7C3AED', pointRadius: 4 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { color: isLight() ? '#64748B' : 'rgba(241,245,249,0.4)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } }, y: { beginAtZero: true, ticks: { stepSize: 1, color: isLight() ? '#64748B' : 'rgba(241,245,249,0.4)' }, grid: { color: isLight() ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)' } } } }
    });

    var usrPie = new Chart(document.getElementById('usrPieChart'), {
        type: 'doughnut',
        data: { labels: ['Active', 'Locked', 'Unverified'], datasets: [{ data: [@Model.ActiveUsers, @Model.LockedUsers, @Model.TotalUsers - @Model.VerifiedUsers], backgroundColor: ['#10B981','#EF4444','#F59E0B'], borderWidth: 0, hoverOffset: 6 }] },
        options: { responsive: true, maintainAspectRatio: false, cutout: '65%', plugins: { legend: { position: 'bottom', labels: { color: isLight() ? '#334155' : 'rgba(241,245,249,0.65)', padding: 14 } } } }
    });

    function applyFilter() {
        var from   = document.getElementById('usr-from').value;
        var to     = document.getElementById('usr-to').value;
        var status = document.getElementById('usr-status').value;
        var rows = document.querySelectorAll('#usrTable tbody tr');
        rows.forEach(function(row) {
            var dateCell   = row.cells[6] ? row.cells[6].textContent.trim() : '';
            var verCell    = row.cells[4] ? row.cells[4].textContent.trim() : '';
            var statusCell = row.cells[5] ? row.cells[5].textContent.trim() : '';
            var rowDate    = dateCell ? new Date(dateCell) : null;
            var fromDate   = from ? new Date(from) : null;
            var toDate     = to ? new Date(to + 'T23:59:59') : null;
            var matchDate  = (!fromDate || (rowDate && rowDate >= fromDate)) && (!toDate || (rowDate && rowDate <= toDate));
            var matchStatus = status === 'all' ||
                (status === 'Verified'  && verCell === 'Verified') ||
                (status === 'Pending'   && verCell === 'Pending')  ||
                (status === 'Active'    && statusCell === 'Active') ||
                (status === 'Locked'    && statusCell === 'Locked');
            row.style.display = (matchDate && matchStatus) ? '' : 'none';
        });
    }

    function printReport() {
        var now = new Date().toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });
        document.getElementById('printMeta').innerHTML = 'Generated: ' + now + '<br>Boosting Hub — Admin Panel';
        document.getElementById('printDate').textContent = now;
        window.print();
    }

    function toggleProfileMenu() {
        var menu = document.getElementById('profileMenu');
        menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    }
    document.addEventListener('click', function(e) {
        var pd = document.getElementById('profileDropdown');
        if (pd && !pd.contains(e.target)) { var m = document.getElementById('profileMenu'); if (m) m.style.display = 'none'; }
    });
</script>
}
