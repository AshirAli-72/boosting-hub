@inject IReportService ReportService

<div class="report-hub-card">
    <div class="report-hub-header">
        <div class="report-hub-icon" style="background:linear-gradient(135deg,#10B981,#059669);">
            <i class="bi bi-currency-dollar"></i>
        </div>
        <div>
            <div class="report-hub-title">Revenue Report</div>
            <div class="report-hub-subtitle">Orders & earnings breakdown</div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
        </div>
    }
    else
    {
        <div class="report-metrics-grid">
            <div class="report-metric">
                <span class="report-metric-label">Total Revenue</span>
                <span class="report-metric-value" style="color:#10B981;">$@TotalRevenue.ToString("N2")</span>
            </div>
            <div class="report-metric">
                <span class="report-metric-label">Total Orders</span>
                <span class="report-metric-value">@TotalOrders</span>
            </div>
            <div class="report-metric">
                <span class="report-metric-label">Approved</span>
                <span class="report-metric-value" style="color:#10B981;">@ApprovedOrders</span>
            </div>
            <div class="report-metric">
                <span class="report-metric-label">Pending</span>
                <span class="report-metric-value" style="color:#F59E0B;">@PendingOrders</span>
            </div>
            <div class="report-metric">
                <span class="report-metric-label">Rejected</span>
                <span class="report-metric-value" style="color:#EF4444;">@RejectedOrders</span>
            </div>
            <div class="report-metric">
                <span class="report-metric-label">Avg. Order Value</span>
                <span class="report-metric-value">$@AvgOrderValue.ToString("N2")</span>
            </div>
        </div>

        @if (DailyRevenue.Any())
        {
            <div class="mt-3">
                <div class="report-chart-label">Last 7 Days Revenue</div>
                <div class="report-bar-chart">
                    @{ var maxVal = DailyRevenue.Values.Any() ? DailyRevenue.Values.Max() : 1; }
                    @foreach (var kvp in DailyRevenue)
                    {
                        var pct = maxVal > 0 ? (double)kvp.Value / (double)maxVal * 100 : 0;
                        <div class="report-bar-item">
                            <div class="report-bar-label">@kvp.Key</div>
                            <div class="report-bar-track">
                                <div class="report-bar-fill" style="width:@pct.ToString("F0")%;background:linear-gradient(90deg,#10B981,#059669);"></div>
                            </div>
                            <div class="report-bar-val">$@kvp.Value.ToString("N0")</div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private decimal TotalRevenue;
    private int TotalOrders;
    private int ApprovedOrders;
    private int PendingOrders;
    private int RejectedOrders;
    private decimal AvgOrderValue;
    private Dictionary<string, decimal> DailyRevenue = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await ReportService.GetRevenueReportAsync();
            TotalRevenue   = data.TotalRevenue;
            TotalOrders    = data.TotalOrders;
            ApprovedOrders = data.ApprovedOrders;
            PendingOrders  = data.PendingOrders;
            RejectedOrders = data.RejectedOrders;
            AvgOrderValue  = data.AvgOrderValue;
            DailyRevenue   = data.DailyRevenue;
        }
        catch { }
        finally { isLoading = false; }
    }
}
