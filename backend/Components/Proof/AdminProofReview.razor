@using BoostingHub.backend.DTOs
@inject ITaskService TaskService
@inject ILogger<AdminProofReview> Logger
@inject IJSRuntime JS

<div class="proof-review">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div>
            <p class="mt-2 text-muted">Loading proofs...</p>
        </div>
    }
    else if (hasError)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }
    else
    {
        <div class="filter-bar d-flex flex-wrap gap-2 mb-4">
            <input type="text" class="form-control" style="flex:2;min-width:160px;" placeholder="Search by worker or service..." @bind="filter.Search" @bind:event="oninput" />
            <select class="form-select" style="flex:1;min-width:120px;" @bind="filter.Platform">
                <option value="">All Platforms</option>
                @foreach (var p in platforms)
                {
                    <option value="@p">@p</option>
                }
            </select>
            <button class="btn btn-primary" @onclick="LoadProofs"><i class="bi bi-search me-1"></i>Search</button>
        </div>

        @if (proofs.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-check2-all fs-1"></i>
                <p class="mt-2">All proofs have been reviewed!</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle admin-table">
                    <thead class="admin-thead">
                        <tr>
                            <th>ID</th>
                            <th>Worker</th>
                            <th>Platform</th>
                            <th>Service</th>
                            <th>Proof URL</th>
                            <th>Submitted</th>
                            <th>Reward</th>
                            <th>Target URL</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in proofs)
                        {
                            <tr>
                                <td>#@p.ProofId</td>
                                <td>@p.UserName</td>
                                <td><span class="badge bg-info">@p.Platform</span></td>
                                <td>@p.Service</td>
                                <td>
                                    <a href="@p.ProofUrl" target="_blank" class="text-truncate d-inline-block" style="max-width:200px;" title="@p.ProofUrl">
                                        <i class="bi bi-box-arrow-up-right me-1"></i>View
                                    </a>
                                </td>
                                <td>@p.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="fw-bold" style="color:var(--success);">@GetCurrencySymbol(p.Currency)@p.Reward.ToString("F2")</td>
                                <td>
                                    <a href="@p.TaskUrl" target="_blank" class="text-truncate d-inline-block" style="max-width:200px;" title="@p.TaskUrl">
                                        <i class="bi bi-box-arrow-up-right me-1"></i>View
                                    </a>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-success" @onclick="() => Approve(p.ProofId)">
                                            <i class="bi bi-check-lg"></i> Approve
                                        </button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => ShowRejectModal(p.ProofId)">
                                            <i class="bi bi-x-lg"></i> Reject
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-4">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <span class="text-muted small">Showing @(((currentPage - 1) * filter.PageSize) + 1)-@(Math.Min(currentPage * filter.PageSize, totalCount)) of @totalCount proofs</span>
                        <ul class="pagination mb-0">
                            <li class="page-item @(!hasPrevious ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage - 1)"><i class="bi bi-chevron-left"></i></button>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var pageNum = i;
                                <li class="page-item @(pageNum == currentPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                                </li>
                            }
                            <li class="page-item @(!hasNext ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage + 1)"><i class="bi bi-chevron-right"></i></button>
                            </li>
                        </ul>
                    </div>
                </nav>
            }
        }
    }
</div>

@if (showRejectModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-semibold"><i class="bi bi-x-circle text-danger"></i> Reject Proof #@rejectProofId</h5>
                    <button type="button" class="btn-close" @onclick="CloseRejectModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium text-secondary">Rejection Reason</label>
                        <textarea class="form-control" rows="3" @bind="rejectReason" placeholder="Provide a reason for rejection..."></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button class="btn btn-secondary" @onclick="CloseRejectModal">Cancel</button>
                        <button class="btn btn-danger" @onclick="Reject" disabled="@(string.IsNullOrWhiteSpace(rejectReason))">
                            <i class="bi bi-x-lg"></i> Reject
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(operationMessage))
                    {
                        <div class="mt-2 small @(operationSuccess ? "text-success" : "text-danger")">@operationMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
}


@code {
    [Parameter, EditorRequired] public int AdminUserId { get; set; }

    private List<ProofReviewDto> proofs = new();
    private bool isLoading = true;
    private bool hasError;
    private string? errorMessage;

    private bool showRejectModal;
    private int rejectProofId;
    private string rejectReason = string.Empty;
    private string? operationMessage;
    private bool operationSuccess;

    private int currentPage = 1;
    private int totalPages = 1;
    private int totalCount;
    private bool hasPrevious;
    private bool hasNext;
    private ProofReviewFilterDto filter = new();
    private List<string> platforms = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPlatforms();
        await LoadProofs();
    }

    private async Task LoadPlatforms()
    {
        try { platforms = await TaskService.GetPlatformsAsync(); } catch { }
    }

    private async Task LoadProofs()
    {
        isLoading = true;
        hasError = false;
        errorMessage = null;
        try
        {
            filter.Page = currentPage;
            var result = await TaskService.GetProofsPendingReviewPagedAsync(filter);
            proofs = result.Items.ToList();
            totalCount = result.TotalCount;
            currentPage = result.Page;
            totalPages = result.TotalPages;
            hasPrevious = result.HasPrevious;
            hasNext = result.HasNext;
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
            Logger.LogError(ex, "Failed to load pending proofs");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangePage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        await LoadProofs();
    }

    private async Task Approve(int proofId)
    {
        try
        {
            var result = await TaskService.ApproveProofAsync(proofId);
            if (result.IsSuccess)
            {
                await JS.InvokeVoidAsync("showToast", result.Message, "success");
                await LoadProofs();
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", result.Message, "danger");
                hasError = true;
                errorMessage = result.Message;
            }
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
            Logger.LogError(ex, "Failed to approve proof {ProofId}", proofId);
        }
    }

    private void ShowRejectModal(int proofId)
    {
        rejectProofId = proofId;
        rejectReason = string.Empty;
        operationMessage = null;
        showRejectModal = true;
    }

    private void CloseRejectModal()
    {
        showRejectModal = false;
        rejectProofId = 0;
        rejectReason = string.Empty;
        operationMessage = null;
    }

    private async Task Reject()
    {
        if (string.IsNullOrWhiteSpace(rejectReason))
        {
            operationMessage = "Please provide a rejection reason.";
            operationSuccess = false;
            return;
        }

        try
        {
            var result = await TaskService.RejectProofAsync(rejectProofId, rejectReason.Trim());
            if (result.IsSuccess)
            {
                await JS.InvokeVoidAsync("showToast", "Proof rejected successfully.", "success");
                CloseRejectModal();
                await LoadProofs();
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", result.Message ?? "Failed to reject.", "danger");
                operationMessage = result.Message;
                operationSuccess = false;
            }
        }
        catch (Exception ex)
        {
            operationMessage = ex.Message;
            operationSuccess = false;
            Logger.LogError(ex, "Failed to reject proof {ProofId}", rejectProofId);
        }
    }

    private string GetCurrencySymbol(string? currency) => currency?.ToUpper() switch
    {
        "PKR" => "Rs.",
        "EUR" => "€",
        "GBP" => "£",
        "INR" => "₹",
        "BDT" => "৳",
        _ => "$"
    };
}
