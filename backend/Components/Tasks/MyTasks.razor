@using BoostingHub.backend.DTOs
@inject ITaskService TaskService

<div class="available-tasks">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="bi bi-check2-square text-primary me-2"></i>My Tasks</h4>
        <span class="badge" style="background:var(--primary);color:#fff;padding:6px 14px;border-radius:20px;font-size:0.85rem;">@tasks.Count tasks</span>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div>
            <p class="mt-2 text-muted">Loading your tasks...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (!tasks.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <p class="mt-3 text-muted fs-5">You haven't accepted any tasks yet.</p>
            <a href="/tasks" class="btn btn-primary mt-2"><i class="bi bi-list-task me-1"></i>Browse Available Tasks</a>
        </div>
    }
    else
    {
        <div class="task-grid">
            @foreach (var task in tasks)
            {
                var taskId = task.TaskId;
                <div class="task-card @(task.Status == "Completed" ? "task-card-completed" : "") @(proofingTaskId == taskId ? "task-card-proofing" : "")">
                    <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                        <span class="task-platform-badge"><i class="bi bi-globe2 me-1"></i>@task.Platform</span>
                        <span class="fw-bold fs-5" style="color:var(--success);">$@task.Reward.ToString("F2")</span>
                    </div>
                    <div class="task-title">@task.Service</div>
                    @if (!string.IsNullOrEmpty(task.Url))
                    {
                        <div class="task-meta-item mb-2">
                            <i class="bi bi-link-45deg me-1"></i>
                            <a href="@task.Url" target="_blank" class="text-primary text-truncate d-inline-block" style="max-width:220px;">@task.Url</a>
                        </div>
                    }
                    <div class="task-meta">
                        <span class="task-meta-item">
                            <i class="bi bi-hourglass me-1"></i>Pending Submission
                        </span>
                        <span class="task-meta-item">
                            <i class="bi bi-flag me-1"></i>
                            @if (task.Status == "Pending")
                            {
                                <span style="color:var(--warning);">In Progress</span>
                            }
                            else
                            {
                                <span style="color:var(--success);">Completed</span>
                            }
                        </span>
                    </div>
                    <div class="task-footer">
                        @if (task.Status == "Pending")
                        {
                            @if (proofingTaskId == taskId)
                            {
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => CancelProof()" @onclick:preventDefault="true">
                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-primary" @onclick="() => StartProof(taskId)" @onclick:preventDefault="true">
                                    <i class="bi bi-upload me-1"></i>Submit Proof
                                </button>
                            }
                        }
                        else
                        {
                            <span style="color:var(--success);"><i class="bi bi-check-circle-fill me-1"></i>Completed</span>
                            @if (!string.IsNullOrEmpty(task.ProofUrl))
                            {
                                <a href="@task.ProofUrl" target="_blank" class="text-primary small">View Proof</a>
                            }
                        }
                        <span class="text-muted small">#@task.TaskId</span>
                    </div>
                    @if (task.Status == "Pending" && proofingTaskId == taskId)
                    {
                        <div class="proof-inline-form">
                            <div class="proof-inline-row">
                                <div class="proof-inline-field">
                                    <label>Proof URL <span style="color:#EF4444;">*</span></label>
                                    <input type="url" class="proof-inline-input" @bind="proofUrl" @bind:event="oninput" placeholder="https://imgur.com/screenshot.png" />
                                </div>
                                <div class="proof-inline-field" style="flex:0 0 140px;">
                                    <label>Type</label>
                                    <select class="proof-inline-input" @bind="proofType">
                                        <option value="Screenshot">Screenshot</option>
                                        <option value="Video">Video</option>
                                        <option value="Link">Link</option>
                                        <option value="Document">Document</option>
                                    </select>
                                </div>
                                <div class="proof-inline-submit">
                                    <button type="button" class="btn btn-sm btn-primary" @onclick="() => SubmitProof(taskId)" @onclick:preventDefault="true" disabled="@isSubmitting" style="margin-top:22px;">
                                        @if (isSubmitting)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-check2 me-1"></i>Submit
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(proofError))
                            {
                                <div class="proof-inline-error">@proofError</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (showSuccess)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
            <div class="toast show align-items-center text-bg-success border-0">
                <div class="d-flex">
                    <div class="toast-body"><i class="bi bi-check-circle-fill me-2"></i>@successMessage</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => showSuccess = false"></button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public int UserId { get; set; }

    private List<MyTaskDto> tasks = new();
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;
    private bool showSuccess;
    private bool isSubmitting;
    private int? proofingTaskId;
    private string proofUrl = string.Empty;
    private string proofType = "Screenshot";
    private string? proofError;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            tasks = await TaskService.GetMyTasksAsync(UserId);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; }
    }

    private void StartProof(int taskId)
    {
        proofingTaskId = taskId;
        proofUrl = string.Empty;
        proofType = "Screenshot";
        proofError = null;
        StateHasChanged();
    }

    private void CancelProof()
    {
        proofingTaskId = null;
        proofUrl = string.Empty;
        proofError = null;
        StateHasChanged();
    }

    private async Task SubmitProof(int taskId)
    {
        if (isSubmitting) return;
        if (string.IsNullOrWhiteSpace(proofUrl))
        {
            proofError = "Please enter a proof URL.";
            return;
        }
        proofError = null;
        isSubmitting = true;
        StateHasChanged();
        try
        {
            var result = await TaskService.SubmitProofAsync(taskId, proofUrl, proofType, UserId);
            if (result.IsSuccess)
            {
                successMessage = result.Message ?? "Proof submitted!";
                showSuccess = true;
                CancelProof();
                await LoadTasks();
            }
                else
                {
                    proofError = $"{(result.ErrorCode ?? "FAIL")}: {result.Message ?? "Failed to submit."}";
                }
        }
        catch (Exception ex) { proofError = $"Error: {ex.Message}"; }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
}
