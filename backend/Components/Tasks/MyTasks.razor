@using BoostingHub.backend.DTOs
@inject ITaskService TaskService

<div class="available-tasks">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="bi bi-check2-square text-primary me-2"></i>My Tasks</h4>
        @if (!isLoading && !hasError)
        {
            <span class="badge" style="background:var(--primary);color:#fff;padding:6px 14px;border-radius:20px;font-size:0.85rem;">@tasks.Count tasks</span>
        }
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div>
            <p class="mt-2 text-muted">Loading your tasks...</p>
        </div>
    }
    else if (hasError)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }
    else if (tasks.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <p class="mt-3 text-muted fs-5">You haven't accepted any tasks yet.</p>
            <a href="/tasks" class="btn btn-primary mt-2"><i class="bi bi-list-task me-1"></i>Browse Available Tasks</a>
        </div>
    }
    else
    {
        <div class="task-grid">
            @foreach (var task in tasks)
            {
                <div class="task-card @(task.Status == "Completed" ? "task-card-completed" : task.Status == "Submitted" ? "task-card-accepted" : "")" @key="@task.TaskId">
                    <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                        <span class="task-platform-badge"><i class="bi bi-globe2 me-1"></i>@task.Platform</span>
                        <span class="fw-bold fs-5" style="color:var(--success);">$@task.Reward.ToString("F2")</span>
                    </div>
                    <div class="task-title">@task.Service</div>
                    @if (!string.IsNullOrEmpty(task.Url))
                    {
                        <div class="task-meta-item mb-2">
                            <i class="bi bi-link-45deg me-1"></i>
                            <a href="@task.Url" target="_blank" class="text-primary text-truncate d-inline-block" style="max-width:220px;">@task.Url</a>
                        </div>
                    }
                    <div class="task-meta">
                        <span class="task-meta-item">
                            <i class="bi bi-hourglass me-1"></i>
                            @if (task.Status == "Pending")
                            {
                                <span>Pending Submission</span>
                            }
                            else if (task.Status == "Submitted")
                            {
                                <span style="color:var(--warning);">Awaiting Review</span>
                            }
                            else if (task.Status == "Rejected")
                            {
                                <span style="color:var(--danger);">Rejected</span>
                            }
                            else
                            {
                                <span style="color:var(--success);">Completed</span>
                            }
                        </span>
                        <span class="task-meta-item">
                            <i class="bi bi-flag me-1"></i>
                            @if (task.Status == "Pending")
                            {
                                <span style="color:var(--warning);">In Progress</span>
                            }
                            else if (task.Status == "Submitted")
                            {
                                <span style="color:var(--info);">Under Review</span>
                            }
                            else if (task.Status == "Rejected")
                            {
                                <span style="color:var(--danger);">Needs Resubmit</span>
                            }
                            else
                            {
                                <span style="color:var(--success);">Completed</span>
                            }
                        </span>
                    </div>
                    <div class="task-footer">
                        @if (task.Status == "Pending")
                        {
                            <button type="button" class="btn btn-sm btn-primary submit-proof-btn" data-task-id="@task.TaskId">
                                <i class="bi bi-upload me-1"></i>Submit Proof
                            </button>
                        }
                        else if (task.Status == "Submitted")
                        {
                            <span style="color:var(--warning);"><i class="bi bi-clock me-1"></i>Awaiting Admin Review</span>
                        }
                        else if (task.Status == "Rejected")
                        {
                            <button type="button" class="btn btn-sm btn-primary submit-proof-btn" data-task-id="@task.TaskId">
                                <i class="bi bi-upload me-1"></i>Resubmit
                            </button>
                        }
                        else
                        {
                            <span style="color:var(--success);"><i class="bi bi-check-circle-fill me-1"></i>Completed</span>
                        }
                        <span class="text-muted small">#@task.TaskId</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public int UserId { get; set; }

    private List<MyTaskDto> tasks = new();
    private bool isLoading = true;
    private bool hasError;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        isLoading = true;
        hasError = false;
        errorMessage = null;
        try
        {
            tasks = await TaskService.GetMyTasksAsync(UserId);
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
